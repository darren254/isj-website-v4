---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  category: string;
  categoryHref: string;
  heroImage?: string;
  heroAlt?: string;
  author?: string;
  publishedDate: string;
  updatedDate?: string;
  summary: string;
}

const {
  title,
  description,
  canonicalUrl,
  category,
  categoryHref,
  heroImage,
  heroAlt,
  author = 'ISJ',
  publishedDate,
  updatedDate,
  summary,
} = Astro.props;

const hasHero = !!heroImage;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>

  {hasHero ? (
    <!-- Style A: Full-bleed hero -->
    <div class="relative w-full h-[70vh] min-h-[500px] overflow-hidden">
      <img
        src={heroImage!}
        alt={heroAlt || ''}
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-12 pt-24">
        <div class="mx-auto max-w-[var(--content-narrow)]">
          <a href={categoryHref} class="text-[length:var(--text-xs)] tracking-[0.2em] uppercase text-white/70 font-medium hover:text-white transition-colors">{category}</a>
          <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-white leading-[1.1] mt-3">{title}</h1>
        </div>
      </div>
    </div>
  ) : (
    <!-- Style B: Text-only header -->
    <div class="pt-32 lg:pt-40 px-6">
      <div class="mx-auto max-w-[var(--content-narrow)]">
        <a href={categoryHref} class="label hover:text-navy transition-colors">{category}</a>
        <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mt-4">{title}</h1>
      </div>
    </div>
  )}

  <!-- Article Meta -->
  <section class="px-6 mt-10">
    <div class="mx-auto max-w-[var(--content-narrow)]">

      <!-- TL;DR -->
      <div class="mb-10 pt-6 pb-6" style="border-top: 1px solid var(--color-charcoal, #3a3a3a); border-bottom: 1px solid rgba(58,58,58,0.15);">
        <p class="text-[length:var(--text-xs)] tracking-[0.2em] uppercase font-medium mb-5" style="color: var(--color-gold-muted);">TL;DR</p>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.875rem;">
          {summary.split('|').map(point => point.trim()).filter(Boolean).map(point => (
            <li class="flex items-baseline gap-4">
              <span class="shrink-0 text-[length:var(--text-xs)] tracking-[0.15em]" style="color: var(--color-gold-muted);">—</span>
              <span class="text-[length:var(--text-sm)] leading-relaxed" style="color: var(--color-charcoal);">{point}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Share + Meta bar -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 py-5 border-t border-b border-charcoal/10 mb-12">
        <div class="text-[length:var(--text-xs)] text-charcoal-muted">
          <span>By {author}</span>
          <span class="mx-2">·</span>
          <span>{publishedDate}</span>
          {updatedDate && (
            <>
              <span class="mx-2">·</span>
              <span>Updated {updatedDate}</span>
            </>
          )}
        </div>
        <div class="flex items-center gap-4">
          <a href={`https://wa.me/?text=${encodeURIComponent(title + ' — ' + 'https://international-school-jakarta.id' + canonicalUrl)}`} target="_blank" rel="noopener noreferrer" class="text-charcoal-muted hover:text-navy transition-colors" aria-label="Share on WhatsApp">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
          <a href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent('https://international-school-jakarta.id' + canonicalUrl)}`} class="text-charcoal-muted hover:text-navy transition-colors" aria-label="Share by email">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </a>
          <button onclick="navigator.clipboard.writeText(window.location.href); this.querySelector('span').textContent='Copied'" class="text-charcoal-muted hover:text-navy transition-colors flex items-center gap-1.5" aria-label="Copy link">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.54a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.5 8.688" /></svg>
            <span class="text-[length:var(--text-xs)]">Link</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <article class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)] article-body">
      <slot />
    </div>
  </article>

  <!-- Related Articles -->
  <slot name="related" />

  <!-- Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "author": {
      "@type": "Person",
      "name": author
    },
    "publisher": {
      "@type": "Organization",
      "name": "The Independent School of Jakarta",
      "url": "https://international-school-jakarta.id"
    },
    "datePublished": publishedDate,
    ...(updatedDate ? { "dateModified": updatedDate } : {}),
    ...(heroImage ? { "image": `https://international-school-jakarta.id${heroImage}` } : {}),
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://international-school-jakarta.id${canonicalUrl}`
    }
  })} />

</BaseLayout>

<style>
  /* Article body typography */
  .article-body :global(p) {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-charcoal);
    margin-bottom: 1.5em;
  }
  .article-body :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-navy);
    line-height: 1.15;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }
  .article-body :global(h3) {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-navy);
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .article-body :global(blockquote) {
    border-left: 2px solid var(--color-gold);
    padding-left: 1.5rem;
    margin: 2em 0;
    font-style: italic;
    color: var(--color-charcoal-light);
  }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.5em;
  }
  .article-body :global(li) {
    margin-bottom: 0.5em;
    color: var(--color-charcoal);
  }
  /* Image widths */
  .article-body :global(.img-wide) {
    width: calc(100% + 200px);
    margin-left: -100px;
    margin-right: -100px;
    margin-top: 2em;
    margin-bottom: 2em;
    display: block;
    max-width: none;
  }
  .article-body :global(.img-text) {
    width: 100%;
    margin-top: 2em;
    margin-bottom: 2em;
  }
  .article-body :global(.img-narrow) {
    width: 75%;
    margin: 2em auto;
    display: block;
  }
  .article-body :global(figcaption) {
    font-size: var(--text-xs);
    color: var(--color-charcoal-muted);
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .article-body :global(.img-wide) {
      width: 100%;
      margin-left: 0;
    }
  }
</style>
