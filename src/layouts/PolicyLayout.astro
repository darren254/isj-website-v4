---
/**
 * PolicyLayout — Aman-grade policy page.
 *
 * Design principles (from Aman legal pages):
 * - Narrow centered column (~640px)
 * - Generous whitespace between sections (~60-70px)
 * - Section headings: ALL CAPS, tracked, normal weight, same size as body
 * - Sub-headings: bold, same size as body, title case
 * - TOC: plain underlined links, tight spacing, no label
 * - Bullets: tight gaps within lists
 * - Monochromatic: dark charcoal text on cream
 * - No decorative elements, borders between sections, or icons
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  policyName: string;
  lastReviewed: string;
  category: string;
  canonicalUrl: string;
}

const { title, description, policyName, lastReviewed, category, canonicalUrl } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
>

  <section class="pt-32 lg:pt-40 pb-20 lg:pb-28 px-6">
    <div class="mx-auto max-w-[640px]">

      <!-- Back link -->
      <a href=/policies class="inline-flex items-center gap-2 text-[13px] text-charcoal-muted hover:text-navy transition-colors duration-[var(--transition-base)] mb-16">
        <span aria-hidden="true">&larr;</span> All Policies
      </a>

      <!-- Title block — centered like Aman -->
      <div class="text-center mb-16">
        <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">{policyName}</h1>
      </div>

      <!-- Policy content -->
      <div class="policy-content">
        <slot />
      </div>

      <!-- Back link (bottom) -->
      <div class="mt-20">
        <a href=/policies class="inline-flex items-center gap-2 text-[13px] text-charcoal-muted hover:text-navy transition-colors duration-[var(--transition-base)]">
          <span aria-hidden="true">&larr;</span> All Policies
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style is:global>
  /* Base text */
  .policy-content {
    font-size: 15px;
    line-height: 1.75;
    color: var(--charcoal-light);
  }

  /* Sections: generous spacing between them (Aman uses ~60-70px) */
  .policy-content > div {
    margin-bottom: 3.5rem;
  }

  /*
   * Section headings (h2): Aman model
   * ALL CAPS, tracked, normal weight, ~same size as body
   * Differentiated by caps + tracking only, not size or weight
   */
  .policy-content h2 {
    font-family: var(--font-body);
    font-size: 13px;
    font-style: normal;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: 1.25rem;
    margin-top: 0;
  }

  /*
   * Sub-headings (h3): Aman model
   * Title case, bold, same size as body
   */
  .policy-content h3 {
    font-family: var(--font-body);
    font-size: 15px;
    font-style: normal;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.5rem;
    margin-top: 1.5rem;
  }

  /* Paragraphs */
  .policy-content p {
    margin-bottom: 0.875rem;
  }
  .policy-content p:last-child {
    margin-bottom: 0;
  }

  /* Lists: tight spacing like Aman (~6-8px between items) */
  .policy-content ul,
  .policy-content ol {
    margin-top: 0.5rem;
    margin-bottom: 0.875rem;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .policy-content ol {
    list-style: decimal;
  }
  .policy-content ul {
    list-style: disc;
  }
  .policy-content li {
    line-height: 1.65;
  }

  /* Links: underlined, same dark color (no blue — Aman style) */
  .policy-content a {
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--navy-light);
    transition: text-decoration-color var(--transition-base);
  }
  .policy-content a:hover {
    text-decoration-color: var(--navy);
  }

  /*
   * Table of contents nav: Aman style
   * Plain underlined links, tight line spacing, no numbered list chrome
   */
  .policy-content nav {
    margin-bottom: 3.5rem;
  }
  .policy-content nav p {
    display: none; /* Hide the "Contents" label — Aman doesn't use one */
  }
  .policy-content nav ol {
    list-style: none;
    padding-left: 0;
    gap: 0.2rem;
    display: flex;
    flex-direction: column;
  }
  .policy-content nav ol li {
    line-height: 1.6;
  }
  .policy-content nav ol li a {
    font-size: 14px;
    color: var(--charcoal-light);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--charcoal-muted);
  }
  .policy-content nav ol li a:hover {
    color: var(--navy);
    text-decoration-color: var(--navy);
  }

  /* Tables (for policies that have them) */
  .policy-content table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.75rem;
    margin-bottom: 1rem;
    font-size: 14px;
  }
  .policy-content th,
  .policy-content td {
    border: 1px solid rgba(27, 42, 74, 0.1);
    padding: 0.625rem 0.75rem;
    text-align: left;
    vertical-align: top;
    line-height: 1.5;
  }
  .policy-content th {
    font-weight: 600;
    color: var(--navy);
    background: rgba(27, 42, 74, 0.03);
  }

  /* Strong text */
  .policy-content strong {
    font-weight: 600;
    color: var(--navy);
  }
</style>
