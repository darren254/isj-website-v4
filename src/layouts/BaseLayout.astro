---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage = '/images/og-default.jpg', canonicalUrl } = Astro.props;
const siteUrl = 'https://international-school-jakarta.id';
const fullCanonical = canonicalUrl ? `${siteUrl}${canonicalUrl}` : Astro.url.href;

// Breadcrumb display names
const breadcrumbNames: Record<string, string> = {
  'about': 'About',
  'why-isj': 'Why ISJ',
  'our-head': 'Our Head',
  'the-schools-trust': 'The Schools Trust',
  'academics': 'Academics',
  'pre-prep': 'Pre-Prep',
  'prep-school': 'Prep School',
  'senior-school': 'Senior School',
  'curriculum': 'Curriculum',
  'results': 'Results & Outcomes',
  'gcses': 'GCSEs',
  'a-levels': 'A-Levels',
  'admissions': 'Admissions',
  'how-to-apply': 'How to Apply',
  'arrange-a-tour': 'Arrange a Tour',
  'fees': 'Tuition Fees',
  'age-guide': 'Age Guide',
  'scholarships': 'Scholarships',
  'terms-and-conditions': 'Admissions T&Cs',
  'virtual-tour': 'Virtual Tour',
  'school-life': 'School Life',
  'campus': 'Campus & Facilities',
  'sport': 'Sport',
  'arts-music': 'Arts & Music',
  'character': 'Character & Values',
  'calendar': 'School Calendar',
  'insights': 'Insights',
  'news': 'News',
  'careers': 'Careers',
  'contact': 'Contact',
  'faqs': 'FAQs',
  'policies': 'Policies',
  'privacy': 'Privacy',
  'terms': 'Terms',
  'cookies': 'Cookies',
  'brand': 'Brand',
};

// Build breadcrumb items from URL path
const rawPath = canonicalUrl || Astro.url.pathname;
const cleanPath = rawPath.replace(/^\/+/, '').replace(/\/+$/, '');
const pathSegments = cleanPath ? cleanPath.split('/') : [];

const breadcrumbItems = [
  { name: 'Home', url: `${siteUrl}/` }
];

let cumulativePath = '';
for (const segment of pathSegments) {
  cumulativePath += `/${segment}`;
  breadcrumbItems.push({
    name: breadcrumbNames[segment] || segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    url: `${siteUrl}${cumulativePath}`
  });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
<!--
   ______                            __
  / ____/___  ____ ___  ____  __  __/ /____  _____
 / /   / __ \/ __ `__ \/ __ \/ / / / __/ _ \/ ___/
/ /___/ /_/ / / / / / / /_/ / /_/ / /_/  __/ /
\____/\____/_/ /_/ /_/ .___/\__,_/\__/\___/_/
                    /_/
        Created with Perplexity Computer
        https://www.perplexity.ai/computer
-->

<!-- Perplexity Computer Attribution — SEO Meta Tags -->
<meta name="generator" content="Perplexity Computer">
<meta name="author" content="Perplexity Computer">
<meta property="og:see_also" content="https://www.perplexity.ai/computer">
<link rel="author" href="https://www.perplexity.ai/computer">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:site_name" content="The Independent School of Jakarta" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Google Analytics 4 — only loaded when cookies accepted -->
  <script is:inline>
  (function() {
    if (localStorage.getItem('cookie-consent') !== 'accepted') return;
    var id = 'G-TDE52R9LB1';
    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + id;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('config', id);
  })();
  </script>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "The Independent School of Jakarta",
    "alternateName": "ISJ",
    "url": siteUrl,
    "description": "British independent school in Pondok Indah, Jakarta offering the English National Curriculum from EYFS through A-Levels for ages 2 to 18",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Jl. R.A. Kartini No. Kav. 12",
      "addressLocality": "Pondok Indah, South Jakarta",
      "addressRegion": "DKI Jakarta",
      "postalCode": "12310",
      "addressCountry": "ID"
    },
    "telephone": "+62-21-2782-6788",
    "email": "info@isj.id",
    "foundingDate": "2021",
    "parentOrganization": {
      "@type": "Organization",
      "name": "The Schools Trust",
      "url": "https://theschoolstrust.com"
    }
  })} />

  {/* BreadcrumbList schema — on all pages except homepage */}
  {breadcrumbItems.length > 1 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": item.name,
        "item": item.url
      }))
    })} />
  )}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
  <CookieConsent />

  <!-- Scroll reveal observer -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    });
  </script>
</body>
</html>
