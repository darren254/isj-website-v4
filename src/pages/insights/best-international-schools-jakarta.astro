    mapInstance = map;

    map.addControl(new window.mapboxgl.AttributionControl({ compact: true }), "bottom-right");

    map.on("load", function () {
      // ── Aman-grade base-map treatment ────────────────────────────────────────
      var layers = map.getStyle().layers;
      for (var i = 0; i < layers.length; i++) {
        var l = layers[i];
        var lid = l.id;
        var ltype = l.type;

        if (ltype === "background") {
          try { map.setPaintProperty(lid, "background-color", "#f7f7f7"); } catch(e) {}
        }
        else if (ltype === "fill") {
          if (lid.indexOf("water") !== -1) {
            try { map.setPaintProperty(lid, "fill-color", "#DCEBEF"); } catch(e) {}
            try { map.setPaintProperty(lid, "fill-opacity", 1); } catch(e) {}
          }
          else if (lid.indexOf("park") !== -1 || lid.indexOf("green") !== -1 ||
                   lid.indexOf("grass") !== -1 || lid.indexOf("vegetation") !== -1 ||
                   lid.indexOf("national-park") !== -1) {
            try { map.setPaintProperty(lid, "fill-color", "rgba(210,217,192,0.8)"); } catch(e) {}
            try { map.setPaintProperty(lid, "fill-opacity", 1); } catch(e) {}
          }
          else if (lid.indexOf("landuse") !== -1) {
            try { map.setPaintProperty(lid, "fill-color", "rgba(242,244,236,0.5)"); } catch(e) {}
            try { map.setPaintProperty(lid, "fill-opacity", 1); } catch(e) {}
          }
          else if (lid.indexOf("building") !== -1) {
            try { map.setPaintProperty(lid, "fill-color", "#e8e8e8"); } catch(e) {}
            try { map.setPaintProperty(lid, "fill-opacity", 0.6); } catch(e) {}
          }
          else {
            try { map.setPaintProperty(lid, "fill-color", "#f2f2f0"); } catch(e) {}
            try { map.setPaintProperty(lid, "fill-opacity", 0.5); } catch(e) {}
          }
        } else if (ltype === "line") {
          if (lid.indexOf("road") !== -1 || lid.indexOf("bridge") !== -1 || lid.indexOf("tunnel") !== -1) {
            try { map.setPaintProperty(lid, "line-color", "#ffffff"); } catch(e) {}
            try { map.setPaintProperty(lid, "line-opacity", 0.8); } catch(e) {}
          } else {
            try { map.setPaintProperty(lid, "line-opacity", 0.15); } catch(e) {}
          }
        } else if (ltype === "symbol") {
          var layout = l.layout || {};
          if (lid.indexOf("poi") !== -1 || lid.indexOf("transit") !== -1 ||
              (layout["icon-image"] && !layout["text-field"])) {
            try { map.setLayoutProperty(lid, "visibility", "none"); } catch(e) {}
          }
          else if (lid.indexOf("road") !== -1) {
            try { map.setPaintProperty(lid, "text-color", "#a1a1a1"); } catch(e) {}
            try { map.setPaintProperty(lid, "text-opacity", 0.7); } catch(e) {}
          }
          else {
            try { map.setPaintProperty(lid, "text-color", "hsl(22,8%,62%)"); } catch(e) {}
            try { map.setPaintProperty(lid, "text-opacity", 0.8); } catch(e) {}
          }
        }
        else if (ltype === "hillshade") {
          try { map.setPaintProperty(lid, "hillshade-shadow-color", "rgba(74,44,44,0.08)"); } catch(e) {}
          try { map.setPaintProperty(lid, "hillshade-highlight-color", "rgba(255,255,255,0.12)"); } catch(e) {}
        }
      }

      // ── District source + labels only (no fill) ──────────────────────────────
      map.addSource(SOURCE_ID, { type: "geojson", data: REGIONS, generateId: true });

      // District labels — very subtle
      map.addLayer({
        id:     SOURCE_ID + "-labels",
        type:   "symbol",
        source: SOURCE_ID,
        layout: {
          "text-field":          ["get", "displayName"],
          "text-font":           ["DIN Pro Regular", "Arial Unicode MS Regular"],
          "text-size":           11,
          "text-transform":      "uppercase",
          "text-letter-spacing": 0.12
        },
        paint: {
          "text-color":       "rgba(80,70,55,0.35)",
          "text-halo-color":  "rgba(255,255,255,0.7)",
          "text-halo-width":  1.5
        }
      });

      // ── School markers ───────────────────────────────────────────────────────
      addSchoolMarkers();

      // Lock all map interaction after markers are placed
      map.scrollZoom.disable();
      map.dragPan.disable();
      map.touchZoomRotate.disable();
      map.doubleClickZoom.disable();
      map.boxZoom.disable();
      map.keyboard.disable();

      // ── Canvas: draw + bind map events ──────────────────────────────────────
      drawNeighbourhoods();
      map.on("move",   drawNeighbourhoods);
      map.on("zoom",   drawNeighbourhoods);
      map.on("resize", drawNeighbourhoods);
    });

    // ── Canvas mouse interactions ────────────────────────────────────────────
    var el = container;
    el.addEventListener("mousemove", function (e) {
      if (!showNeighbourhoods) return;
      var rect  = el.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var hit   = getNeighbourhoodAtPoint(x, y);
      var newId = hit ? hit.id : null;
      if (newId !== hoveredNhId) {
        hoveredNhId = newId;
        drawNeighbourhoods();
      }
    });

    el.addEventListener("click", function (e) {
      if (!showNeighbourhoods || !mapInstance) return;
      var rect  = el.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      var hit   = getNeighbourhoodAtPoint(x, y);
      if (!hit) return;
      var pixels = projectRing(hit.ring);
      var cx = 0, cy = 0;
      for (var pi = 0; pi < pixels.length; pi++) { cx += pixels[pi][0]; cy += pixels[pi][1]; }
      cx /= pixels.length;
      cy /= pixels.length;
      var lngLat = mapInstance.unproject([cx, cy]);
      new window.mapboxgl.Popup({ offset: 10, maxWidth: "220px" })
        .setLngLat(lngLat)
        .setHTML(hit.popupContent)
        .addTo(mapInstance);
    });

    el.addEventListener("mouseleave", function () {
      if (hoveredNhId !== null) {
        hoveredNhId = null;
        drawNeighbourhoods();
      }
    });
  }

  // ─── SCHOOL MARKERS ─────────────────────────────────────────────────────────

  function addSchoolMarkers() {
    var map = mapInstance;
    if (!map || !window.mapboxgl) return;

    for (var i = 0; i < SCHOOLS.length; i++) {
      var school  = SCHOOLS[i];
      var isISJ   = school.name === "ISJ";
      var dotSize = isISJ ? 14 : 10;

      // Dot marker element
      var dot = document.createElement("div");
      dot.style.cssText = [
        "width:" + dotSize + "px",
        "height:" + dotSize + "px",
        "border-radius:50%",
        "background:#1B2A4A",
        "border:1.5px solid " + (isISJ ? "#FFC43D" : "white"),
        "box-shadow:0 1px 4px rgba(0,0,0,0.25)",
        "cursor:pointer",
        "transition:transform 0.2s ease",
        isISJ ? "box-shadow:0 1px 4px rgba(0,0,0,0.25),0 0 0 1.5px rgba(255,196,61,0.35)" : ""
      ].join(";");

      (function(d) {
        d.addEventListener("mouseenter", function () { d.style.transform = "scale(1.45)"; });
        d.addEventListener("mouseleave", function () { d.style.transform = "scale(1)";    });
      }(dot));

      var popup = new window.mapboxgl.Popup({ offset: 10, maxWidth: "180px", closeButton: false })
        .setHTML('<h4>' + school.name + '</h4>');

      var marker = new window.mapboxgl.Marker({ element: dot, anchor: "center" })
        .setLngLat([school.lng, school.lat])
        .setPopup(popup)
        .addTo(map);
      schoolMarkers.push(marker);

      // Text label element
      var label      = document.createElement("div");
      label.textContent = school.label;
      label.style.cssText = [
        "white-space:nowrap",
        "pointer-events:none",
        "font-family:'DM Sans',-apple-system,sans-serif",
        "font-size:10px",
        "font-weight:600",
        "color:#1B2A4A",
        "text-shadow:0 0 3px rgba(255,255,255,0.95),0 0 6px rgba(255,255,255,0.8),1px 1px 2px rgba(255,255,255,0.9)"
      ].join(";");

      var labelMarker = new window.mapboxgl.Marker({ element: label, anchor: school.labelAnchor })
        .setOffset(school.labelOffset)
        .setLngLat([school.lng, school.lat])
        .addTo(map);
      labelMarkers.push(labelMarker);
    }
  }

  // ─── LEGEND POPULATION ──────────────────────────────────────────────────────

  function buildLegend() {
    // Neighbourhood swatches
    var nhEl = document.getElementById("jakarta-legend-neighbourhoods");
    if (nhEl) {
      for (var ni = 0; ni < NEIGHBOURHOODS.length; ni++) {
        var n     = NEIGHBOURHOODS[ni];
        var r = n.color[0], g = n.color[1], b = n.color[2];
        var item2 = document.createElement("div");
        item2.className = "jakarta-legend-item";
        item2.innerHTML = '<span class="jakarta-legend-swatch" style="background:rgba(' + r + ',' + g + ',' + b + ',0.45)"></span><span>' + n.name + '</span>';
        nhEl.appendChild(item2);
      }
    }
  }

  // ─── LEGEND TOGGLE ───────────────────────────────────────────────────────────

  function setupLegend() {
    var btn  = document.getElementById("jakarta-legend-toggle-btn");
    var body = document.getElementById("jakarta-legend-body");
    var svg  = btn ? btn.querySelector("svg") : null;
    if (!btn || !body) return;

    btn.addEventListener("click", function () {
      var isOpen = body.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(isOpen));
      if (svg) {
        svg.classList.toggle("open",   isOpen);
        svg.classList.toggle("closed", !isOpen);
      }
    });

    // Layer toggles
    function bindToggle(id, getter, setter, applyFn) {
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener("change", function () {
        setter(el.checked);
        applyFn(el.checked);
      });
    }

    bindToggle("toggle-neighbourhoods", function(){ return showNeighbourhoods; }, function(v){ showNeighbourhoods = v; }, function() {
      drawNeighbourhoods();
    });

    bindToggle("toggle-labels", function(){ return showLabels; }, function(v){ showLabels = v; }, function(v) {
      if (!mapInstance) return;
      try { mapInstance.setLayoutProperty(SOURCE_ID + "-labels", "visibility", v ? "visible" : "none"); } catch(e) {}
    });

    bindToggle("toggle-schools", function(){ return showSchools; }, function(v){ showSchools = v; }, function(v) {
      var vis = v ? "visible" : "hidden";
      for (var i = 0; i < schoolMarkers.length; i++)  schoolMarkers[i].getElement().style.visibility  = vis;
      for (var j = 0; j < labelMarkers.length;  j++)  labelMarkers[j].getElement().style.visibility   = vis;
    });
  }

  // ─── BOOT ────────────────────────────────────────────────────────────────────

  function boot() {
    buildLegend();
    setupLegend();
    initMap();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
}());
</script>


  <h3>South Jakarta</h3>

  <figure class="img-text">
    <img src=/images/insights/expat-guide-pondok-indah.webp alt="Pondok Indah neighbourhood in South Jakarta" loading="lazy" />
    <figcaption>Pondok Indah, South Jakarta. The heartland of the expat community, and home to JIS, ISJ, and several other international schools.</figcaption>
  </figure>

  <p>
    Spanning Pondok Indah, Kemang, Cipete, and Cilandak, this is the centre of gravity for internationally minded families. The city's best lifestyle infrastructure (Pondok Indah Mall, Lotte Mall, golf courses, the Water Park) plus the highest concentration of cafes, restaurants, and children's activities.
  </p>

  <p><strong>Schools nearby:</strong> JIS, ISJ, NZ School, AIS, Nord Anglia</p>

  <h3>Central Jakarta: The CBD</h3>

  <p>
    SCBD, Senopati Business District, has a strong dining and nightlife scene, plus shopping at Grand Indonesia. A good fit for professionals and expatriates without school-age children.
  </p>

  <p><strong>Schools nearby:</strong> Few international options in the immediate area</p>

  <h3>North Jakarta: PIK and Kelapa Gading</h3>

  <p>
    PIK is popular with Indonesian-Chinese and mainland Chinese expat communities, functioning as a self-contained city with excellent restaurants, particularly for Chinese and Japanese cuisine. A growing international community is developing here.
  </p>

  <p><strong>Schools nearby:</strong> NJIS, Tzu Chi School, SIS Kelapa Gading</p>

  <h3>East Jakarta</h3>

  <p>
    Largely industrial and local residential. Worth considering only if you happen to work in the area, though a handful of international schools have campuses here.
  </p>

  <p><strong>Schools nearby:</strong> ACS, Global Sevilla</p>

  <h3>West Jakarta</h3>

  <p>
    Strong Indonesian-Chinese demographic, offering a more local lifestyle geographically separated from expat hubs. Note: 'local-international' schools here may differ in management culture and workload from schools in Singapore, Hong Kong, or Europe.
  </p>

  <p><strong>Schools nearby:</strong> Sampoerna Academy, Tunas Muda</p>

  <h3>Bintaro (Outside Jakarta)</h3>

  <figure class="img-text">
    <img src=/images/insights/expat-guide-bintaro.jpg alt="Bintaro Jaya residential area in South Tangerang, Jakarta" loading="lazy" />
    <figcaption>Bintaro offers green suburbia and a quieter pace of life, but sits a significant distance from central Jakarta.</figcaption>
  </figure>

  <p>
    A trade-off: green suburbia and less local traffic, but significant distance from the city centre. A growing number of families are making the move, drawn primarily by the large British School Jakarta campus and a more relaxed pace of life.
  </p>

  <p><strong>Schools nearby:</strong> British School Jakarta</p>

