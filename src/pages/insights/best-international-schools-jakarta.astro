  // ─── HELPERS ────────────────────────────────────────────────────────────────

  function pointInPolygon(x, y, ring) {
    var inside = false;
    for (var i = 0, j = ring.length - 1; i < ring.length; j = i++) {
      var xi = ring[i][0], yi = ring[i][1];
      var xj = ring[j][0], yj = ring[j][1];
      if ((yi > y) !== (yj > y) && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi) {
        inside = !inside;
      }
    }
    return inside;
  }

  function projectRing(ring) {
    if (!mapInstance) return [];
    return ring.map(function(coord) {
      var pt = mapInstance.project(coord);
      return [pt.x, pt.y];
    });
  }

  // ─── CANVAS DRAWING ─────────────────────────────────────────────────────────

  function drawNeighbourhoods() {
    var canvas    = document.getElementById("jakarta-map-canvas");
    var container = document.getElementById("jakarta-map-container");
    if (!canvas || !container || !mapInstance) return;

    var ctx = canvas.getContext("2d");
    if (!ctx) return;

    var dpr = window.devicePixelRatio || 1;
    canvas.width  = container.clientWidth  * dpr;
    canvas.height = container.clientHeight * dpr;
    canvas.style.width  = container.clientWidth  + "px";
    canvas.style.height = container.clientHeight + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (!showNeighbourhoods) return;

    for (var ni = 0; ni < NEIGHBOURHOODS.length; ni++) {
      var n      = NEIGHBOURHOODS[ni];
      var pixels = projectRing(n.ring);
      if (!pixels.length) continue;

      var cx = 0, cy = 0;
      for (var pi = 0; pi < pixels.length; pi++) { cx += pixels[pi][0]; cy += pixels[pi][1]; }
      cx /= pixels.length;
      cy /= pixels.length;

      var maxR = 0;
      for (var ri = 0; ri < pixels.length; ri++) {
        var dx = pixels[ri][0] - cx, dy = pixels[ri][1] - cy;
        var d  = Math.sqrt(dx * dx + dy * dy);
        if (d > maxR) maxR = d;
      }
      if (maxR < 5) continue;

      var isHovered  = hoveredNhId === n.id;
      var baseAlpha  = isHovered ? 0.225 : 0.15;
      var r = n.color[0], g = n.color[1], b = n.color[2];

      // Clip to polygon
      ctx.save();
      ctx.beginPath();
      for (var ci = 0; ci < pixels.length; ci++) {
        if (ci === 0) ctx.moveTo(pixels[ci][0], pixels[ci][1]);
        else          ctx.lineTo(pixels[ci][0], pixels[ci][1]);
      }
      ctx.closePath();
      ctx.clip();

      // Radial gradient fill
      var gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxR);
      gradient.addColorStop(0,    "rgba(" + r + "," + g + "," + b + "," + baseAlpha + ")");
      gradient.addColorStop(0.45, "rgba(" + r + "," + g + "," + b + "," + (baseAlpha * 0.6) + ")");
      gradient.addColorStop(0.75, "rgba(" + r + "," + g + "," + b + "," + (baseAlpha * 0.25) + ")");
      gradient.addColorStop(1,    "rgba(" + r + "," + g + "," + b + ",0.02)");
      ctx.fillStyle = gradient;
      ctx.fillRect(cx - maxR * 1.5, cy - maxR * 1.5, maxR * 3, maxR * 3);

      // Crosshatch — diagonal NW→SE
      var hatchAlpha = isHovered ? 0.15 : 0.09;
      ctx.strokeStyle = "rgba(" + r + "," + g + "," + b + "," + hatchAlpha + ")";
      ctx.lineWidth   = 1.2;
      var spacing = 8, extent = maxR * 1.5;
      for (var off = -extent * 2; off <= extent * 2; off += spacing) {
        ctx.beginPath();
        ctx.moveTo(cx + off - extent, cy - extent);
        ctx.lineTo(cx + off + extent, cy + extent);
        ctx.stroke();
      }
      // Crosshatch — diagonal NE→SW
      ctx.strokeStyle = "rgba(" + r + "," + g + "," + b + "," + (hatchAlpha * 0.6) + ")";
      ctx.lineWidth   = 0.8;
      for (var off2 = -extent * 2; off2 <= extent * 2; off2 += spacing) {
        ctx.beginPath();
        ctx.moveTo(cx + off2 + extent, cy - extent);
        ctx.lineTo(cx + off2 - extent, cy + extent);
        ctx.stroke();
      }
      ctx.restore();

      // Neighbourhood label
      ctx.save();
      ctx.font        = "600 11px 'DM Sans', -apple-system, sans-serif";
      ctx.textAlign   = "center";
      ctx.textBaseline= "middle";
      var lr = Math.max(0, r - 40), lg = Math.max(0, g - 40), lb = Math.max(0, b - 40);
      ctx.strokeStyle = "rgba(255,255,255,0.9)";
      ctx.lineWidth   = 3;
      ctx.lineJoin    = "round";
      ctx.strokeText(n.name, cx, cy);
      ctx.fillStyle   = "rgb(" + lr + "," + lg + "," + lb + ")";
      ctx.fillText(n.name, cx, cy);
      ctx.restore();
    }
  }

  function getNeighbourhoodAtPoint(px, py) {
    if (!showNeighbourhoods) return null;
    for (var i = NEIGHBOURHOODS.length - 1; i >= 0; i--) {
      var n      = NEIGHBOURHOODS[i];
      var pixels = projectRing(n.ring);
      if (pointInPolygon(px, py, pixels)) return n;
    }
    return null;
  }

