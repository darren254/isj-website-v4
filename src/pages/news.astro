---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);
import BaseLayout from '../layouts/BaseLayout.astro';

const featured = {
  title: 'International Week at ISJ',
  excerpt: 'ISJ celebrated the cultures that make up the school community, with performances, food, and traditions from around the world.',
  date: '9 Mar 2026',
  category: 'School Life',
  href: link('/news/international-week-2026'),
  image: asset('/images/news/international-week.jpg'),
};

const news = [
  { title: 'Lewis Wins the Inter-House Quiz', excerpt: 'Lewis House clinched victory for the second year in a row, earning Oswald the Owl for the 2026 academic year.', date: '10 Feb 2026', category: 'School Life', href: link('/news/inter-house-quiz-2026'), image: asset('/images/news/inter-house-quiz.jpg') },
  { title: 'ISJ Creates British Boarding School Pathways', excerpt: 'ISJ is creating direct pathways for senior pupils to continue their education at leading British boarding schools.', date: '15 Jan 2026', category: 'School Life', href: link('/news/boarding-pathways'), image: asset('/images/news/boarding-pathways.jpg') },
  { title: 'A Starry Night: The ISJ Christmas Concert', excerpt: 'From Glockenspiel ensembles to Coldplay, ISJ pupils filled the campus with music and joyful harmonies.', date: '19 Dec 2025', category: 'Arts', href: link('/news/christmas-concert-2025'), image: asset('/images/news/christmas-concert.jpg') },
];

const moreNews = [
  { title: 'Christmas Fair: A Celebration of Community', date: '19 Dec 2025', category: 'Community', href: link('/news/christmas-fair-2025') },
  { title: 'Learning Trip to PIK Bumbi Journey', date: '25 Nov 2025', category: 'School Life', href: link('/news/mangrove-trip-2025') },
  { title: 'Intan Dewiyani Shortlisted for Tes Awards', date: '13 Nov 2025', category: 'Achievements', href: link('/news/tes-awards-2025') },
  { title: 'Early Morning Swimming Begins', date: '13 Nov 2025', category: 'Sport', href: link('/news/early-swimming-2025') },
  { title: 'Emotional Regulation and Behaviour Workshop', date: '9 Oct 2025', category: 'Community', href: link('/news/emotion-workshop-2025') },
  { title: 'Education, Excitement and Exploration: The ISJ Residential', date: '23 May 2025', category: 'School Life', href: link('/news/residential-2025') },
];
---

<BaseLayout
  title="News & Events | ISJ Jakarta"
  description="Stay up to date with the latest news, events, and achievements from The Independent School of Jakarta."
  canonicalUrl="/news"
>

  <!-- ═══════ Header ═══════ -->
  <section class="pt-32 lg:pt-40 section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="label mb-4">News</p>
          <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Latest from ISJ</h1>
        </div>
        <p class="text-[length:var(--text-base)] text-charcoal-light max-w-md md:text-right">
          News, events, and stories from the school.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════ Featured ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <a href={featured.href} class="block group reveal">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div class="overflow-hidden">
            <img
              src={asset(featured.image)}
              alt=""
              loading="lazy"
              class="w-full aspect-[4/3] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.02]"
            />
          </div>
          <div>
            <p class="label label-gold">{featured.category}</p>
            <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mt-3 mb-4">{featured.title}</h2>
            <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">{featured.excerpt}</p>
            <p class="text-[length:var(--text-xs)] text-charcoal-muted mt-4">{featured.date}</p>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════ Three-up Cards ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {news.map((item) => (
          <a href={item.href} class="group reveal">
            <div class="overflow-hidden">
              <img
                src={asset(item.image)}
                alt=""
                loading="lazy"
                class="w-full aspect-[4/3] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.02]"
              />
            </div>
            <p class="label label-gold mt-4">{item.category}</p>
            <h3 class="text-[length:var(--text-base)] text-navy font-medium leading-snug mt-1 mb-2 group-hover:text-navy-light transition-colors">{item.title}</h3>
            <p class="text-[length:var(--text-sm)] text-charcoal-light leading-relaxed line-clamp-2">{item.excerpt}</p>
            <p class="text-[length:var(--text-xs)] text-charcoal-muted mt-3">{item.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ All News + Highlight ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

        <!-- All News list -->
        <div class="lg:col-span-2 reveal">
          <p class="label mb-8">All News</p>
          {moreNews.map((item) => (
            <a href={item.href} class="flex justify-between items-baseline py-4 border-b border-charcoal/5 group">
              <div>
                <p class="text-[length:var(--text-xs)] text-gold-muted uppercase tracking-wider mb-1">{item.category}</p>
                <p class="text-[length:var(--text-base)] text-navy group-hover:text-navy-light transition-colors">{item.title}</p>
              </div>
              <span class="text-[length:var(--text-xs)] text-charcoal-muted ml-4 shrink-0">{item.date}</span>
            </a>
          ))}
        </div>

        <!-- Highlight article -->
        <a href={link("/news/residential-2025")} class="lg:col-span-3 group reveal flex flex-col">
          <div class="overflow-hidden flex-1">
            <img
              src={asset('/images/news/residential.jpg')}
              alt=""
              loading="lazy"
              class="w-full h-full min-h-[300px] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.02]"
            />
          </div>
          <p class="label label-gold mt-5">School Life</p>
          <h3 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mt-2 mb-3">Education, Excitement and Exploration: The ISJ Residential</h3>
          <p class="text-[length:var(--text-sm)] text-charcoal-light leading-relaxed">Year 6 and 7 pupils experienced the best of education, adventure, and personal growth on the ISJ residential trip.</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-muted mt-3">23 May 2025</p>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
