---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | ISJ Jakarta"
  description="The page you're looking for doesn't exist. Return to The Independent School of Jakarta homepage."
  canonicalUrl="/404"
>

  <section class="pt-40 pb-[var(--space-section)] px-6 text-center">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <p class="label mb-5">404</p>
      <h1 class="font-heading text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-8">Page Not Found</h1>
      <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed mb-10">
        The page you are looking for may have moved or no longer exists.
      </p>
      <a href={link('/')} class="whisper-link">Return to the homepage</a>
    </div>
  </section>

</BaseLayout>
