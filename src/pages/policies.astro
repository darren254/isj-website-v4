---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';

const policyGroups = [
  {
    category: 'Safeguarding and Welfare',
    policies: [
      { name: 'Child Protection and Safeguarding Policy', href: '/policies/safeguarding', reviewed: '2025' },
      { name: 'Behaviour Policy', href: '/policies/behaviour', reviewed: '2025' },
      { name: 'Missing Child Policy', href: '/policies/missing-child', reviewed: '2025' },
      { name: 'Online Safety and Acceptable Use Policy', href: '/policies/online-safety', reviewed: '2025' },
      { name: 'Campus Access and Security Policy', href: '/policies/campus-security', reviewed: '2025' },
      { name: 'Fire Safety and Lockdown Procedures', href: '/policies/fire-safety', reviewed: '2025' },
    ],
  },
  {
    category: 'Academic',
    policies: [
      { name: 'SEND Policy', href: '/policies/send', reviewed: '2025' },
      { name: 'EAL Policy', href: '/policies/eal', reviewed: '2025' },
      { name: 'Attendance and Punctuality Policy', href: '/policies/attendance', reviewed: '2025' },
    ],
  },
  {
    category: 'Admissions and Operations',
    policies: [
      { name: 'Admissions Terms and Conditions', href: '/admissions/terms-and-conditions', reviewed: '2025' },
      { name: 'Complaints Policy', href: '/policies/complaints', reviewed: '2025' },
      { name: 'Health and Safety Policy', href: '/policies/health-and-safety', reviewed: '2025' },
      { name: 'First Aid and Medical Needs Policy', href: '/policies/first-aid', reviewed: '2025' },
      { name: 'Educational Visits and Trips Policy', href: '/policies/educational-visits', reviewed: '2025' },
      { name: 'Data Protection and Privacy Policy', href: '/policies/data-protection', reviewed: '2025' },
    ],
  },
];
---

<BaseLayout
  title="School Policies | ISJ Jakarta"
  description="School policies for The International School of Jakarta. Safeguarding, admissions, behaviour, health and safety, and more."
  canonicalUrl="/policies"
>

  <section class="pt-32 lg:pt-40 section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">

      <SectionIntro headingLevel="h1" label="Governance" heading="School Policies">
        <p>ISJ publishes key policies for the school community. All policies are reviewed annually by the Senior Leadership Team.</p>
      </SectionIntro>

      <div class="mt-16 space-y-14">
        {policyGroups.map((group) => (
          <div>
            <h2 class="label mb-6">{group.category}</h2>
            <div class="divide-y divide-navy/8">
              {group.policies.map((policy) => (
                <a
                  href={link(policy.href)}
                  class="flex items-baseline justify-between gap-4 py-4 group transition-colors duration-[var(--transition-base)]"
                >
                  <span class="text-[length:var(--text-base)] text-navy group-hover:text-navy-light transition-colors duration-[var(--transition-base)]">
                    {policy.name}
                  </span>
                  <span class="text-[length:var(--text-xs)] text-charcoal-muted whitespace-nowrap shrink-0">
                    {policy.reviewed}
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>



    </div>
  </section>

</BaseLayout>
