---
import BaseLayout from '../layouts/BaseLayout.astro';

const policyGroups = [
  {
    category: 'Safeguarding and Welfare',
    policies: [
      { name: 'Child Protection and Safeguarding Policy', href: '/policies/safeguarding', desc: 'ISJ\'s responsibilities for child protection, recognising harm, and working with external agencies.' },
      { name: 'Behaviour Policy (incl. Anti-Bullying)', href: '/policies/behaviour', desc: 'Expectations for pupil conduct, the positive reward system, sanctions, and how bullying is addressed.' },
      { name: 'Missing Child Policy', href: '/policies/missing-child', desc: 'Procedures for responding to an unaccounted-for child on or off campus.' },
      { name: 'Online Safety and Acceptable Use Policy', href: '/policies/online-safety', desc: 'Safe and responsible use of technology, devices, and the internet by pupils and staff.' },
      { name: 'Campus Access and Security Policy', href: '/policies/campus-security', desc: 'Site access controls, visitor management, and physical security arrangements.' },
      { name: 'Fire Safety and Lockdown Procedures', href: '/policies/fire-safety', desc: 'Evacuation procedures, lockdown protocols, and fire safety responsibilities.' },
      { name: 'Supervision of Pupils Policy', href: '/policies/supervision-of-pupils', desc: 'Standards for supervising pupils throughout the school day, including before and after school.' },
    ],
  },
  {
    category: 'Academic',
    policies: [
      { name: 'SEND Policy', href: '/policies/send', desc: 'Identification, support, and provision for pupils with special educational needs and disabilities.' },
      { name: 'EAL Policy', href: '/policies/eal', desc: 'Support and provision for pupils developing English as an Additional Language.' },
      { name: 'Attendance and Punctuality Policy', href: '/policies/attendance', desc: 'Expectations for attendance and punctuality, absence reporting, and intervention procedures.' },
      { name: 'Teaching and Learning Policy', href: '/policies/teaching-and-learning', desc: 'ISJ\'s approach to effective teaching, lesson planning, and creating positive learning environments.' },
      { name: 'Curriculum Policy', href: '/policies/curriculum', desc: 'The breadth and balance of the curriculum from Year 1 to Year 8, aligned to UK independent school standards.' },
      { name: 'Assessment, Recording, and Reporting Policy', href: '/policies/assessment-and-reporting', desc: 'How pupil progress is assessed, recorded, and communicated to parents.' },
      { name: 'More Able and Gifted and Talented Policy', href: '/policies/more-able', desc: 'Provision for pupils who are identified as more able, gifted, or talented.' },
      { name: 'Marking and Feedback Policy', href: '/policies/marking-and-feedback', desc: 'Standards for how work is marked and how feedback is given to support pupil progress.' },
    ],
  },
  {
    category: 'Admissions and Operations',
    policies: [
      { name: 'Admissions Policy', href: '/policies/admissions', desc: 'How places are allocated, the application process, English and SEND requirements, and withdrawal terms.' },
      { name: 'Admissions Terms and Conditions', href: '/admissions/terms-and-conditions', desc: 'The legal agreement between ISJ and families, covering fees, notice periods, and conduct expectations.' },
      { name: 'Complaints Policy', href: '/policies/complaints', desc: 'How to raise a concern, the stages of the complaints process, and escalation routes.' },
      { name: 'Health and Safety Policy', href: '/policies/health-and-safety', desc: 'ISJ\'s responsibilities for maintaining a safe environment for pupils, staff, and visitors.' },
      { name: 'First Aid and Medical Needs Policy', href: '/policies/first-aid', desc: 'First aid provision, management of medical conditions, and medication administration.' },
      { name: 'Educational Visits and Trips Policy', href: '/policies/educational-visits', desc: 'Planning, approval, and risk management for off-site activities and residential trips.' },
      { name: 'Data Protection and Privacy Policy', href: '/policies/data-protection', desc: 'How ISJ collects, uses, stores, and protects personal data for pupils, families, and staff.' },
    ],
  },
  {
    category: 'Staff and Employment',
    policies: [
      { name: 'Staff Code of Conduct', href: '/policies/staff-code-of-conduct', desc: 'Professional standards, ethical conduct, and expectations for all members of staff.' },
      { name: 'Safer Recruitment Policy', href: '/policies/safer-recruitment', desc: 'Recruitment procedures designed to safeguard pupils, including DBS checks and reference requirements.' },
      { name: 'Whistleblowing Policy', href: '/policies/whistleblowing', desc: 'How staff can raise serious concerns about conduct or malpractice, and the protections afforded to them.' },
      { name: 'Staff Appraisal and Development Policy', href: '/policies/staff-appraisal', desc: 'The appraisal cycle, professional development expectations, and performance management.' },
    ],
  },
  {
    category: 'Operations and Governance',
    policies: [
      { name: 'Equal Opportunities Policy', href: '/policies/equal-opportunities', desc: 'ISJ\'s commitment to non-discrimination across admissions, curriculum delivery, and employment.' },
      { name: 'Remote Learning and Continuity of Education Policy', href: '/policies/remote-learning', desc: 'How ISJ maintains educational provision when on-site learning is not possible.' },
      { name: 'Accessibility Statement', href: '/policies/accessibility', desc: 'ISJ\'s commitment to web accessibility and how to report any accessibility issue.' },
      { name: 'Parent Communication and Engagement Policy', href: '/policies/parent-communication', desc: 'How ISJ communicates with families and how parents can engage constructively with the school.' },
      { name: 'Policy Management and Review', href: '/policies/policy-management', desc: 'How policies are written, approved, reviewed, and published.' },
      { name: 'Risk Management and Business Continuity Policy', href: '/policies/risk-management', desc: 'ISJ\'s approach to identifying and managing risk, and maintaining operations during disruption.' },
    ],
  },
];
---

<BaseLayout
  title="School Policies | ISJ Jakarta"
  description="School policies for The International School of Jakarta. Safeguarding, admissions, behaviour, health and safety, and more."
  canonicalUrl="/policies"
>

  <section class="pt-32 lg:pt-40 pb-24 lg:pb-32 px-6">
    <div class="mx-auto max-w-[680px]">

      <!-- Header -->
      <div class="text-center mb-5">
        <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">School Policies</h1>
      </div>
      <p class="text-center text-[14px] text-charcoal-muted mb-3 max-w-[480px] mx-auto leading-relaxed" style="font-family: var(--font-body);">
        All policies are aligned with UK independent school standards and Indonesian regulatory requirements.
        See also the <a href="/privacy" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Privacy Policy</a> and <a href="/terms" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Terms of Service</a>.
      </p>
      <p class="text-center text-[13px] text-charcoal-muted mb-16 max-w-[480px] mx-auto" style="font-family: var(--font-body);">
        Queries: <a href="mailto:admissions@isj.id" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">admissions@isj.id</a>
      </p>

      <!-- Policy groups -->
      <div class="space-y-14">
        {policyGroups.map((group) => (
          <div>
            <!-- Category header with rule -->
            <div class="flex items-center gap-4 mb-6">
              <span class="text-[11px] font-semibold tracking-[0.12em] uppercase text-charcoal-muted whitespace-nowrap" style="font-family: var(--font-body);">{group.category}</span>
              <div class="flex-1 h-px bg-navy/[0.08]"></div>
            </div>

            <!-- Policy cards -->
            <div>
              {group.policies.map((policy) => (
                <a
                  href={policy.href}
                  class="group flex items-start justify-between gap-6 py-4 border-b border-navy/[0.05] last:border-0 hover:bg-navy/[0.015] -mx-3 px-3 rounded-sm transition-colors duration-200"
                  style="font-family: var(--font-body);"
                >
                  <div class="flex-1 min-w-0">
                    <div class="text-[14px] font-medium text-navy leading-snug mb-1 group-hover:text-navy/70 transition-colors">{policy.name}</div>
                    <div class="text-[12.5px] text-charcoal-muted leading-relaxed">{policy.desc}</div>
                  </div>
                  <svg class="flex-shrink-0 mt-0.5 w-3.5 h-3.5 text-navy/30 group-hover:text-navy/60 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
