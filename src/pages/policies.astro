---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionIntro from '../components/SectionIntro.astro';
---

<BaseLayout
  title="School Policies | ISJ Jakarta"
  description="Access school policies for The Independent School of Jakarta, including safeguarding, behaviour, and admissions policies."
  canonicalUrl="/policies"
>
  <section class="pt-32 lg:pt-40 section-pad px-6">
    <SectionIntro headingLevel="h1" label="Resources" heading="School Policies">
      <p>School policies are available on request from the admissions team at <a href="mailto:admissions@isj.id" class="whisper-link">admissions@isj.id</a>.</p>
    </SectionIntro>
  </section>
</BaseLayout>
