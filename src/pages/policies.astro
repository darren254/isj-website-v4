---
import BaseLayout from '../layouts/BaseLayout.astro';

const policyGroups = [
  {
    category: 'Safeguarding and Welfare',
    policies: [
      { name: 'Child Protection and Safeguarding Policy', href: '/policies/safeguarding' },
      { name: 'Behaviour Policy (incl. Anti-Bullying)', href: '/policies/behaviour' },
      { name: 'Missing Child Policy', href: '/policies/missing-child' },
      { name: 'Online Safety and Acceptable Use Policy', href: '/policies/online-safety' },
      { name: 'Campus Access and Security Policy', href: '/policies/campus-security' },
      { name: 'Fire Safety and Lockdown Procedures', href: '/policies/fire-safety' },
      { name: 'Supervision of Pupils Policy', href: '/policies/supervision-of-pupils' },
    ],
  },
  {
    category: 'Academic',
    policies: [
      { name: 'SEND Policy', href: '/policies/send' },
      { name: 'EAL Policy', href: '/policies/eal' },
      { name: 'Attendance and Punctuality Policy', href: '/policies/attendance' },
      { name: 'Teaching and Learning Policy', href: '/policies/teaching-and-learning' },
      { name: 'Curriculum Policy', href: '/policies/curriculum' },
      { name: 'Assessment, Recording, and Reporting Policy', href: '/policies/assessment-and-reporting' },
      { name: 'More Able and Gifted and Talented Policy', href: '/policies/more-able' },
      { name: 'Marking and Feedback Policy', href: '/policies/marking-and-feedback' },
    ],
  },
  {
    category: 'Admissions and Operations',
    policies: [
      { name: 'Admissions Policy', href: '/policies/admissions' },
      { name: 'Admissions Terms and Conditions', href: '/admissions/terms-and-conditions' },
      { name: 'Complaints Policy', href: '/policies/complaints' },
      { name: 'Health and Safety Policy', href: '/policies/health-and-safety' },
      { name: 'First Aid and Medical Needs Policy', href: '/policies/first-aid' },
      { name: 'Educational Visits and Trips Policy', href: '/policies/educational-visits' },
      { name: 'Data Protection and Privacy Policy', href: '/policies/data-protection' },
    ],
  },
  {
    category: 'Staff and Employment',
    policies: [
      { name: 'Staff Code of Conduct', href: '/policies/staff-code-of-conduct' },
      { name: 'Safer Recruitment Policy', href: '/policies/safer-recruitment' },
      { name: 'Whistleblowing Policy', href: '/policies/whistleblowing' },
      { name: 'Staff Appraisal and Development Policy', href: '/policies/staff-appraisal' },
    ],
  },
  {
    category: 'Operations and Governance',
    policies: [
      { name: 'Equal Opportunities Policy', href: '/policies/equal-opportunities' },
      { name: 'Remote Learning and Continuity of Education Policy', href: '/policies/remote-learning' },
      { name: 'Accessibility Statement', href: '/policies/accessibility' },
      { name: 'Parent Communication and Engagement Policy', href: '/policies/parent-communication' },
      { name: 'Policy Management and Review', href: '/policies/policy-management' },
      { name: 'Risk Management and Business Continuity Policy', href: '/policies/risk-management' },
    ],
  },
];
---

<BaseLayout
  title="School Policies | ISJ Jakarta"
  description="School policies for The International School of Jakarta. Safeguarding, admissions, behaviour, health and safety, and more."
  canonicalUrl="/policies"
>

  <section class="pt-32 lg:pt-40 pb-20 lg:pb-28 px-6">
    <div class="mx-auto max-w-[640px]">

      <!-- Title — centered, Aman style -->
      <div class="text-center mb-10">
        <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">School Policies</h1>
      </div>
      <p class="text-center text-[15px] text-charcoal-muted mb-6 max-w-[520px] mx-auto leading-relaxed">ISJ maintains a full set of school policies aligned with UK independent school standards and Indonesian regulatory requirements. All policies are published here for the school community. See also the <a href=/privacy class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Privacy Policy</a>, <a href=/terms class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Terms of Service</a>, and <a href=/contact class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Contact</a> pages.</p>
      <p class="text-center text-[14px] text-charcoal-muted mb-20 max-w-[520px] mx-auto leading-relaxed">For queries about any policy, contact <a href="mailto:admissions@isj.id" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">admissions@isj.id</a>.</p>

      <!-- Policy groups -->
      <div class="space-y-16">
        {policyGroups.map((group) => (
          <div>
            <h2 class="text-[13px] font-semibold tracking-[0.08em] uppercase text-charcoal-muted mb-8" style="font-family: var(--font-body);">{group.category}</h2>
            <div class="space-y-0">
              {group.policies.map((policy) => (
                <a
                  href={policy.href}
                  class="block py-3 text-[15px] text-navy hover:text-navy-light transition-colors duration-[var(--transition-base)] border-b border-navy/[0.04] last:border-0"
                  style="font-family: var(--font-body);"
                >
                  {policy.name}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</BaseLayout>
