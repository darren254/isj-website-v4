---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | ISJ Jakarta"
  description="Get in touch with The Independent School of Jakarta. Contact the admissions team, visit the Pondok Indah campus, or send a message."
  canonicalUrl="/contact"
>

  <!-- ═══════ Contact Split ═══════ -->
  <section class="pt-28 lg:pt-32">
    <div class="mx-auto max-w-[var(--content-max)]">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[80vh]">

        <!-- Left: Contact Info -->
        <div class="px-6 lg:px-16 py-16 lg:py-24 flex flex-col justify-center">
          <div class="max-w-md">

            <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-10">Get in Touch</h1>

            <div class="space-y-8">

              <div>
                <p class="text-[length:var(--text-sm)] font-medium text-navy mb-1">Admissions</p>
                <a href="mailto:admissions@isj.id" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">admissions@isj.id</a><br />
                <a href="https://wa.me/6281110007672" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">+62 811 1000 7672 <span class="text-[length:var(--text-xs)] text-charcoal-muted">(WhatsApp)</span></a>
              </div>

              <div>
                <p class="text-[length:var(--text-sm)] font-medium text-navy mb-1">Reception</p>
                <a href="tel:+622127826788" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">+62 21-2782-6788</a><br />
                <a href="mailto:info@isj.id" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">info@isj.id</a>
              </div>

              <div>
                <p class="text-[length:var(--text-sm)] font-medium text-navy mb-1">Address</p>
                <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
                  Jl. R.A. Kartini No. Kav. 12<br />
                  Pondok Indah, South Jakarta 12310<br />
                  Indonesia
                </p>
                <a href="https://www.google.com/maps/search/?api=1&query=-6.290732016331623,106.78383491761785" target="_blank" rel="noopener noreferrer" class="whisper-link text-[length:var(--text-sm)] mt-2 inline-block">View on Google Maps</a>
              </div>

              <div>
                <p class="text-[length:var(--text-sm)] font-medium text-navy mb-1">Office Hours</p>
                <p class="text-[length:var(--text-base)] text-charcoal-light">
                  Monday to Friday, 7:30am to 3:30pm
                </p>
              </div>

            </div>

            <div class="mt-12 pt-8 border-t border-charcoal/10">
              <a
                href={link("/admissions/arrange-a-tour")}
                class="whisper-link"
              >
                Arrange a Tour
              </a>
            </div>

          </div>
        </div>

        <!-- Right: Image -->
        <div class="hidden lg:block relative overflow-hidden">
          <img
            src={asset('/images/father-daughter.jpg')}
            alt="A father and daughter at The Independent School of Jakarta"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Enquiry Form ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-lg">
      <div class="mb-12 reveal">
        <p class="label mb-5">Send a Message</p>
        <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
          If you prefer, leave a message and the admissions team will be in touch within one working day. For step-by-step guidance, visit the <a href={link('/admissions/how-to-apply')} class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">How to Apply</a> page.
        </p>
      </div>

      <form id="contact-form" class="space-y-6 reveal" novalidate>
        <div>
          <label for="contact-name" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Your Name</label>
          <input type="text" id="contact-name" name="name" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="Full name" />
        </div>

        <div>
          <label for="contact-email" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Email Address</label>
          <input type="email" id="contact-email" name="email" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="you@example.com" />
        </div>

        <div>
          <label for="contact-message" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Message</label>
          <textarea id="contact-message" name="message" rows="5" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors resize-y" placeholder="How can we help?"></textarea>
        </div>

        <div class="pt-2">
          <button type="submit" class="inline-flex items-center px-10 py-3.5 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)]">
            Send Message
          </button>
        </div>

        <div id="contact-success" class="hidden bg-cream border border-gold/30 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-navy font-medium">Thank you for your message.</p>
          <p class="text-[length:var(--text-sm)] text-charcoal-light mt-2">The team will be in touch within one working day.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ═══════ Map ═══════ -->
  <section class="pb-0">
    <div class="w-full aspect-[16/9] lg:aspect-[2.4/1] overflow-hidden relative" id="map-container">
      <div id="contact-map" class="w-full h-full"></div>
    </div>
    <!-- Address bar -->
    <div class="bg-[#F7F5F0] border-t border-[rgba(27,42,74,0.06)]">
      <div class="mx-auto max-w-[var(--content-wide)] px-6 lg:px-16 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-start gap-3">
          <svg class="w-4 h-4 mt-0.5 text-navy/40 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          <div>
            <p class="text-[length:var(--text-sm)] text-navy font-medium leading-snug">Jl. R.A. Kartini No. Kav. 12</p>
            <p class="text-[length:var(--text-xs)] text-charcoal-muted leading-snug">Pondok Indah, South Jakarta 12310</p>
          </div>
        </div>
        <a href="https://www.google.com/maps/search/?api=1&query=-6.290732016331623,106.78383491761785" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[length:var(--text-xs)] tracking-[0.1em] uppercase font-medium text-navy/60 hover:text-navy transition-colors">
          Get directions
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0V15" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Mapbox GL CSS -->
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />

  <style>
    #map-container .mapboxgl-ctrl-group {
      border-radius: 4px;
      box-shadow: 0 1px 6px rgba(27,42,74,0.08);
    }
    #map-container .mapboxgl-ctrl-attrib {
      font-size: 9px;
    }
  </style>

</BaseLayout>

<!-- Mapbox GL JS -->
<script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var mapEl = document.getElementById('contact-map');
    if (!mapEl || typeof mapboxgl === 'undefined') return;

    mapboxgl.accessToken = ['pk.eyJ1IjoiZGFycmVuYnJvd25pc2oiLC','JhIjoiY21qdjY4MGNuNDhlaDNjcTVwdjg1NXU0MiJ9','.dj49JN1L3jFniAtX-wxrRA'].join('');

    var ISJ = { lat: -6.290732, lng: 106.783835 };
    var POIS = [
      { lat: -6.2637, lng: 106.7835, label: 'Pondok Indah Mall' },
      { lat: -6.2840, lng: 106.7805, label: 'Pondok Indah Hospital' },
      { lat: -6.2680, lng: 106.7780, label: 'Pondok Indah Golf Course' }
    ];

    // Compute bounds
    var allPts = POIS.concat([ISJ]);
    var sw = [999, 999], ne = [-999, -999];
    for (var i = 0; i < allPts.length; i++) {
      if (allPts[i].lng < sw[0]) sw[0] = allPts[i].lng;
      if (allPts[i].lat < sw[1]) sw[1] = allPts[i].lat;
      if (allPts[i].lng > ne[0]) ne[0] = allPts[i].lng;
      if (allPts[i].lat > ne[1]) ne[1] = allPts[i].lat;
    }

    var map = new mapboxgl.Map({
      container: 'contact-map',
      style: 'mapbox://styles/mapbox/light-v11',
      center: [(sw[0]+ne[0])/2, (sw[1]+ne[1])/2],
      zoom: 13,
      minZoom: 10,
      maxZoom: 17,
      cooperativeGestures: true,
      dragRotate: false,
      pitchWithRotate: false,
      attributionControl: false
    });

    map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), 'top-left');
    map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');

    map.on('load', function() {
      map.fitBounds([sw, ne], { padding: { top: 100, bottom: 100, left: 80, right: 80 }, maxZoom: 14, duration: 0 });

      // ── Aman-grade base-map treatment ────────────────────────────────────
      // Matched to Aman's actual Mapbox Studio style values:
      // Background: near-white #f7f7f7, water: pale ice #DCEBEF,
      // vegetation: muted sage, roads: white on white, labels: warm grey

      var layers = map.getStyle().layers;
      for (var li = 0; li < layers.length; li++) {
        var layer = layers[li];
        var id = layer.id;
        var t = layer.type;

        if (t === 'background') {
          try { map.setPaintProperty(id, 'background-color', '#f7f7f7'); } catch(e) {}
        }
        else if (t === 'fill') {
          // Water: pale ice blue (Aman uses #DCEBEF)
          if (id.indexOf('water') !== -1) {
            try { map.setPaintProperty(id, 'fill-color', '#DCEBEF'); } catch(e) {}
            try { map.setPaintProperty(id, 'fill-opacity', 1); } catch(e) {}
          }
          // Parks, green, vegetation: muted sage (Aman uses rgba(210,217,192,0.8))
          else if (id.indexOf('park') !== -1 || id.indexOf('green') !== -1 ||
                   id.indexOf('grass') !== -1 || id.indexOf('vegetation') !== -1 ||
                   id.indexOf('national-park') !== -1) {
            try { map.setPaintProperty(id, 'fill-color', 'rgba(210,217,192,0.8)'); } catch(e) {}
            try { map.setPaintProperty(id, 'fill-opacity', 1); } catch(e) {}
          }
          // Landuse: very pale warm (Aman uses rgba(242,244,236,0.6) for agriculture)
          else if (id.indexOf('landuse') !== -1) {
            try { map.setPaintProperty(id, 'fill-color', 'rgba(242,244,236,0.5)'); } catch(e) {}
            try { map.setPaintProperty(id, 'fill-opacity', 1); } catch(e) {}
          }
          // Buildings: light neutral
          else if (id.indexOf('building') !== -1) {
            try { map.setPaintProperty(id, 'fill-color', '#e8e8e8'); } catch(e) {}
            try { map.setPaintProperty(id, 'fill-opacity', 0.6); } catch(e) {}
          }
          // Everything else: near-white
          else {
            try { map.setPaintProperty(id, 'fill-color', '#f2f2f0'); } catch(e) {}
            try { map.setPaintProperty(id, 'fill-opacity', 0.5); } catch(e) {}
          }
        }
        else if (t === 'line') {
          // Roads: white on near-white (Aman approach)
          if (id.indexOf('road') !== -1 || id.indexOf('bridge') !== -1 || id.indexOf('tunnel') !== -1) {
            try { map.setPaintProperty(id, 'line-color', '#ffffff'); } catch(e) {}
            try { map.setPaintProperty(id, 'line-opacity', 0.8); } catch(e) {}
          }
          // Other lines (admin borders etc): very subtle
          else {
            try { map.setPaintProperty(id, 'line-opacity', 0.15); } catch(e) {}
          }
        }
        else if (t === 'symbol') {
          // Hide POI and transit labels entirely
          if (id.indexOf('poi') !== -1 || id.indexOf('transit') !== -1) {
            try { map.setLayoutProperty(id, 'visibility', 'none'); } catch(e) {}
          }
          // Road labels: warm grey like Aman (#a1a1a1)
          else if (id.indexOf('road') !== -1) {
            try { map.setPaintProperty(id, 'text-color', '#a1a1a1'); } catch(e) {}
            try { map.setPaintProperty(id, 'text-opacity', 0.7); } catch(e) {}
          }
          // Settlement / place labels: warm taupe (Aman uses hsl(22,8%,62%))
          else {
            try { map.setPaintProperty(id, 'text-color', 'hsl(22,8%,62%)'); } catch(e) {}
            try { map.setPaintProperty(id, 'text-opacity', 0.8); } catch(e) {}
          }
        }
        // Hillshade: add subtle warm shadow (Aman uses rgba(74,44,44,0.06))
        else if (t === 'hillshade') {
          try { map.setPaintProperty(id, 'hillshade-shadow-color', 'rgba(74,44,44,0.08)'); } catch(e) {}
          try { map.setPaintProperty(id, 'hillshade-highlight-color', 'rgba(255,255,255,0.12)'); } catch(e) {}
        }
      }

      // ── ISJ marker: clean dot + uppercase label (Aman style) ────────────
      var isjEl = document.createElement('div');
      isjEl.innerHTML = '<div style="display:flex;align-items:center;gap:7px;">' +
        '<div style="width:10px;height:10px;border-radius:50%;background:#1B2A4A;border:2px solid white;box-shadow:0 0 0 1px rgba(27,42,74,0.15);"></div>' +
        '<span style="font-family:DM Sans,system-ui,sans-serif;font-size:13px;font-weight:600;color:#525252;letter-spacing:0.1em;text-transform:uppercase;white-space:nowrap;">The Independent School of Jakarta</span>' +
        '</div>';
      new mapboxgl.Marker({ element: isjEl, anchor: 'left', offset: [-5, 0] })
        .setLngLat([ISJ.lng, ISJ.lat])
        .addTo(map);

      // ── POI markers: small dot + muted label ────────────────────────────
      for (var pi = 0; pi < POIS.length; pi++) {
        var poi = POIS[pi];
        var el = document.createElement('div');
        el.innerHTML = '<div style="display:flex;align-items:center;gap:5px;">' +
          '<div style="width:5px;height:5px;border-radius:50%;background:#525252;"></div>' +
          '<span style="font-family:DM Sans,system-ui,sans-serif;font-size:10px;font-weight:500;color:#a1a1a1;letter-spacing:0.02em;white-space:nowrap;text-transform:uppercase;">' + poi.label + '</span>' +
          '</div>';
        new mapboxgl.Marker({ element: el, anchor: 'left', offset: [-2, 0] })
          .setLngLat([poi.lng, poi.lat])
          .addTo(map);
      }

    });
  });
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var name = form.querySelector('#contact-name').value.trim();
      var email = form.querySelector('#contact-email').value.trim();
      var message = form.querySelector('#contact-message').value.trim();

      if (!name || !email || !message) return;

      var subject = 'Enquiry from ' + name;
      var body = 'Name: ' + name + '\nEmail: ' + email + '\n\n' + message;

      window.location.href = 'mailto:admissions@isj.id?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      form.querySelectorAll(':scope > div').forEach(function(el) {
        if (el.id !== 'contact-success') el.style.display = 'none';
      });
      document.getElementById('contact-success').classList.remove('hidden');
    });
  });
</script>
