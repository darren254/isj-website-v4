---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionIntro from '../components/SectionIntro.astro';
---

<BaseLayout
  title="Contact Us | ISJ Jakarta"
  description="Get in touch with The Independent School of Jakarta. Contact our admissions team, visit our Pondok Indah campus, or send us a message."
  canonicalUrl="/contact"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/campus-aerial.jpg"
    imageAlt="Aerial view of ISJ campus in Pondok Indah"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="Contact"
      heading="Get in Touch"
    >
      <p>
        Whether you are considering ISJ for your family or have a general enquiry, we are here to help.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ Contact Details ═══════ -->
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-lg">
      <div class="space-y-0 reveal">

        <div class="flex justify-between items-baseline py-4 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">Admissions</span>
          <a href="mailto:admissions@isj.id" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">admissions@isj.id</a>
        </div>

        <div class="flex justify-between items-baseline py-4 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">WhatsApp</span>
          <a href="https://wa.me/6281110007672" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">+62 811 1000 7672</a>
        </div>

        <div class="flex justify-between items-baseline py-4 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">Reception</span>
          <a href="tel:+622127826788" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">+62 21-2782-6788</a>
        </div>

        <div class="flex justify-between items-baseline py-4 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">General</span>
          <a href="mailto:info@isj.id" class="text-[length:var(--text-base)] text-charcoal-light hover:text-navy transition-colors">info@isj.id</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Enquiry Form ═══════ -->
  <section id="enquiry" class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-lg">
      <div class="text-center mb-12 reveal">
        <p class="label mb-5">Send a Message</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Enquiry Form</h2>
      </div>

      <form id="contact-form" class="space-y-6 reveal" novalidate>
        <div>
          <label for="contact-name" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Your Name</label>
          <input type="text" id="contact-name" name="name" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="Full name" />
        </div>

        <div>
          <label for="contact-email" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Email Address</label>
          <input type="email" id="contact-email" name="email" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="you@example.com" />
        </div>

        <div>
          <label for="contact-subject" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Subject</label>
          <select id="contact-subject" name="subject" class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors appearance-none" style="background-image: url('data:image/svg+xml;utf8,<svg fill=\'none\' stroke=\'%231B2A4A\' stroke-width=\'2\' viewBox=\'0 0 24 24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'m6 9 6 6 6-6\'/></svg>'); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1rem;">
            <option value="admissions">Admissions Enquiry</option>
            <option value="general">General Enquiry</option>
            <option value="careers">Careers</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="contact-message" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Message</label>
          <textarea id="contact-message" name="message" rows="5" required class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors resize-y" placeholder="How can we help?"></textarea>
        </div>

        <div class="pt-2">
          <button type="submit" class="inline-flex items-center px-10 py-3.5 border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)] w-full sm:w-auto justify-center">
            Send Message
          </button>
        </div>

        <div id="contact-success" class="hidden bg-cream border border-gold/30 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-navy font-medium">Thank you for your message.</p>
          <p class="text-[length:var(--text-sm)] text-charcoal-light mt-2">We will be in touch within one working day.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ═══════ Location ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-lg">

      <div class="reveal mb-12">
        <p class="label mb-6">Our Location</p>
        <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          Jl. R.A. Kartini No. Kav. 12<br />
          Pondok Indah, South Jakarta 12310<br />
          Indonesia
        </p>
      </div>

      <div class="reveal mb-12">
        <p class="label mb-6">Office Hours</p>
        <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          Monday to Friday, 7:30am to 3:30pm<br />
          The admissions team is available during school hours and will respond to emails within one working day.
        </p>
      </div>

    </div>

    <!-- Map -->
    <div class="mx-auto max-w-[var(--content-wide)] reveal">
      <div class="w-full aspect-[16/7] overflow-hidden relative" id="map-container">
        <div id="contact-map" class="w-full h-full"></div>
        <a
          href="https://www.google.com/maps/search/?api=1&query=-6.290732016331623,106.78383491761785"
          target="_blank"
          rel="noopener noreferrer"
          class="absolute bottom-4 left-4 z-[500] bg-white/90 px-4 py-2 text-[length:var(--text-xs)] tracking-[0.1em] uppercase text-navy font-medium hover:bg-white transition-colors"
        >
          Open in Google Maps
        </a>
      </div>
    </div>
  </section>

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

</BaseLayout>

<!-- Leaflet JS + Map Init -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var mapEl = document.getElementById('contact-map');
    if (!mapEl || typeof L === 'undefined') return;

    // ISJ at -6.2907. Centre the map NORTH of ISJ so ISJ appears in the lower quarter.
    // More negative lat = further south. We want centre further north = less negative.
    var isjLat = -6.290732;
    var isjLng = 106.783835;
    var centreOffset = 0.012;

    var map = L.map('contact-map', {
      center: [isjLat + centreOffset, isjLng],
      zoom: 14,
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: false,
      touchZoom: false,
      doubleClickZoom: false
    });

    // CartoDB Positron — clean, minimal
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png', {
      maxZoom: 19
    }).addTo(map);

    // Road and place labels (no POI icons)
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_only_labels/{z}/{x}/{y}{r}.png', {
      maxZoom: 19
    }).addTo(map);

    // Golf course green overlay
    L.polygon([
      [-6.2655, 106.7795],
      [-6.2655, 106.7895],
      [-6.2735, 106.7895],
      [-6.2735, 106.7795]
    ], {
      color: 'transparent',
      fillColor: '#C5D9B2',
      fillOpacity: 0.35
    }).addTo(map);

    // ISJ marker — clean circle with gold ring
    var isjIcon = L.divIcon({
      className: '',
      html: '<div style="width:18px;height:18px;border-radius:50%;background:#1B2A4A;border:3px solid #FFC43D;box-shadow:0 2px 8px rgba(0,0,0,0.25);"></div>',
      iconSize: [18, 18],
      iconAnchor: [9, 9]
    });
    L.marker([isjLat, isjLng], { icon: isjIcon }).addTo(map);

    // ISJ label
    L.marker([isjLat, isjLng], {
      icon: L.divIcon({
        className: '',
        html: '<div style="font-family:DM Sans,system-ui,sans-serif;font-size:11px;font-weight:600;color:#1B2A4A;letter-spacing:0.08em;text-transform:uppercase;white-space:nowrap;text-shadow:0 0 4px #F7F5F0,0 0 4px #F7F5F0,0 0 4px #F7F5F0;">ISJ</div>',
        iconSize: [40, 16],
        iconAnchor: [-12, 14]
      })
    }).addTo(map);

    // POI helper — small muted dot + label
    function addPoi(lat, lng, label) {
      L.circleMarker([lat, lng], {
        radius: 3,
        color: 'transparent',
        fillColor: '#8a8780',
        fillOpacity: 0.6
      }).addTo(map);
      L.marker([lat, lng], {
        icon: L.divIcon({
          className: '',
          html: '<div style="font-family:DM Sans,system-ui,sans-serif;font-size:9px;color:#8a8780;letter-spacing:0.05em;white-space:nowrap;text-shadow:0 0 3px #F7F5F0,0 0 3px #F7F5F0;">' + label + '</div>',
          iconSize: [120, 14],
          iconAnchor: [-6, 12]
        })
      }).addTo(map);
    }

    addPoi(-6.2665, 106.7830, 'Pondok Indah Mall');
    addPoi(-6.2840, 106.7815, 'RS Pondok Indah');
    addPoi(-6.2695, 106.7855, 'Pondok Indah Golf Course');
  });
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var name = form.querySelector('#contact-name').value.trim();
      var email = form.querySelector('#contact-email').value.trim();
      var subject = form.querySelector('#contact-subject').value;
      var message = form.querySelector('#contact-message').value.trim();

      if (!name || !email || !message) return;

      var mailSubject = subject === 'admissions' ? 'Admissions Enquiry from ' + name
        : subject === 'careers' ? 'Careers Enquiry from ' + name
        : 'Enquiry from ' + name;

      var body = 'Name: ' + name + '\n';
      body += 'Email: ' + email + '\n';
      body += 'Subject: ' + subject + '\n\n';
      body += message;

      var to = subject === 'admissions' ? 'admissions@isj.id' : 'info@isj.id';
      window.location.href = 'mailto:' + to + '?subject=' + encodeURIComponent(mailSubject) + '&body=' + encodeURIComponent(body);

      form.querySelectorAll(':scope > div').forEach(function(el) {
        if (el.id !== 'contact-success') el.style.display = 'none';
      });
      document.getElementById('contact-success').classList.remove('hidden');
    });
  });
</script>
