---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import ImageBlock from '../components/ImageBlock.astro';
import EditorialCard from '../components/EditorialCard.astro';
import StatBar from '../components/StatBar.astro';
import Testimonial from '../components/Testimonial.astro';
import AccreditationBar from '../components/AccreditationBar.astro';
---

<BaseLayout
  title="ISJ | British International School Jakarta | Ages 2–18"
  description="The Independent School of Jakarta offers a world-class British education for ages 2 to 18 in Pondok Indah, South Jakarta. English National Curriculum, GCSEs and A-Levels."
  canonicalUrl="/"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/pupils-prep.jpg"
    imageAlt="Prep School pupils at The Independent School of Jakarta"
    aspectRatio="tall"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="British International School · Pondok Indah, South Jakarta"
      heading="A British Education in the Heart of Jakarta"
    >
      <p>
        Your child's teacher knows what they had for breakfast, which friendships are thriving, and exactly where they are in long division. At ISJ, every child is known — by name, by character, and by what they need to flourish.
      </p>
      <p>
        We follow the English National Curriculum from age 2 through to A-Levels, taught by teachers recruited from the UK's leading independent schools. We are part of The Schools Trust — a UK charity whose schools are ranked 1st and 2nd across 200+ British schools internationally for A-Level and GCSE results.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ Stats ═══════ -->
  <StatBar stats={[
    { value: '30+', label: 'Nationalities' },
    { value: '1:9', label: 'Staff-Pupil Ratio' },
    { value: '100%', label: 'UK-Qualified Teachers' },
  ]} />

  <!-- ═══════ Full-bleed image break ═══════ -->
  <div class="my-4">
    <ImageBlock
      src="/images/campus-aerial.jpg"
      alt="Aerial view of ISJ campus in Pondok Indah — swimming pool, football pitch, and playing fields"
      aspect="wide"
      loading="lazy"
      slowZoom={true}
    />
  </div>

  <!-- ═══════ Academic Phases ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center mb-[var(--space-element)] reveal">
      <p class="label mb-5">Ages 2 to 18 · English National Curriculum</p>
      <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Three Schools, One Journey</h2>
    </div>

    <div class="mx-auto max-w-[var(--content-wide)] grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 reveal-stagger">
      <EditorialCard
        imageSrc="/images/pre-prep.jpg"
        imageAlt="Pre-Prep children sitting together and laughing during circle time"
        label="Pre-Prep"
        title="Early Years & Foundation Stage"
        description="Ages 2–6. Learning through play, curiosity, and structured exploration. Maximum 15 children per class."
        href="/academics/pre-prep"
      />
      <EditorialCard
        imageSrc="/images/primary-classroom.jpg"
        imageAlt="Prep School pupils working together on a science experiment"
        label="Prep School"
        title="The English National Curriculum"
        description="Ages 7–13. Specialist teaching, co-curricular breadth, residential trips, and a house system."
        href="/academics/prep-school"
      />
      <EditorialCard
        imageSrc="/images/senior-school.jpg"
        imageAlt="Senior School students in blazers and ties"
        label="Senior School"
        title="GCSEs & A-Levels in Jakarta"
        description="Ages 14–18. British qualifications taught by experienced UK-trained teachers, preparing students for leading universities worldwide."
        href="/academics/senior-school"
      />
    </div>
  </section>

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="High-calibre teaching staff with strong subject knowledge and a real commitment to pupils' learning and wellbeing."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
    variant="dark"
  />

  <!-- ═══════ Head's Profile ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div class="overflow-hidden">
          <img
            src="/images/eileen-fisher.jpg"
            alt="Eileen Fisher, Academic Director of ISJ, with two pupils"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[3/4] md:aspect-[4/5] object-cover object-top"
          />
        </div>
        <div>
          <p class="label mb-5">Our Head</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">Eileen Fisher</h2>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed mb-5">
            Edinburgh-born, with 31 years in education and experience leading schools across three continents. An accredited ISI and Penta Inspector, Eileen joined ISJ in 2024 and knows every child and every family in the school.
          </p>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed mb-8">
            Her door is open to every parent — and she means it.
          </p>
          <a href="/about/our-head" class="whisper-link">Read Eileen's full profile</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Full-bleed image break ═══════ -->
  <div class="my-4">
    <ImageBlock
      src="/images/prep-engineering.jpg"
      alt="Prep School pupils proudly holding their mini projectors after an engineering project"
      aspect="wide"
      loading="lazy"
    />
  </div>

  <!-- ═══════ School Life editorial ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="Beyond the Classroom"
      heading="Life at ISJ"
    >
      <p>
        On a typical Wednesday, a five-year-old finishes swimming and heads to Mandarin. A Year 6 pupil rehearses for the school play. A Year 8 is on the football pitch before an afternoon of science in the lab. Sport, music, drama, and art are part of every child's week — not optional extras.
      </p>
      <p>
        Our Pondok Indah campus has a 25-metre swimming pool, a full-size football pitch, a theatre, and dedicated creative arts spaces. Each year, our older pupils travel to Woolverstone Hall in Suffolk, England — an 87-acre estate where they experience British boarding school life first-hand.
      </p>
    </SectionIntro>

    <div class="mt-[var(--space-element)] flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="/school-life/campus" class="whisper-link">Explore our campus</a>
      <a href="/admissions/virtual-tour" class="whisper-link">Take the virtual tour</a>
    </div>
  </section>

  <!-- ═══════ Second testimonial ═══════ -->
  <Testimonial
    quote="A warm, family-like environment. The school's strength lies in the kindness of the teachers. My children love all the staff."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- ═══════ Accreditation ═══════ -->
  <AccreditationBar />

</BaseLayout>
