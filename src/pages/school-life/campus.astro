---
import { asset } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Campus & Facilities | ISJ Pondok Indah"
  description="Explore ISJ's campus in Pondok Indah. Swimming pool, football pitch, theatre, creative arts spaces, and outdoor learning areas in South Jakarta."
  canonicalUrl="/school-life/campus"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/campus-aerial.jpg"
    imageAlt="Aerial view of ISJ campus in Pondok Indah"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="School Life"
      heading="The Campus"
    >
      <p>
        Set in Pondok Indah, one of South Jakarta's most established residential areas. Space to learn, play, and grow from age 2 to 18.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ Swimming Pool — asymmetric split ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-16 items-center reveal">
        <div class="md:col-span-3 overflow-hidden">
          <img
            src={asset('/images/swimming-pool.jpg')}
            alt="25-metre swimming pool at ISJ"
            loading="lazy"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div class="md:col-span-2">
          <p class="label mb-4">Swimming</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-4">25-Metre Pool</h2>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
            Swimming is part of the curriculum from Pre-Nursery. By the time children leave Pre-Prep, they are confident in the water.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Football Pitch — reversed split ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-16 items-center reveal">
        <div class="md:col-span-2 md:order-1">
          <p class="label mb-4">Sport</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-4">Playing Fields</h2>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
            A full-size football pitch, 20+ sports including netball, athletics, gymnastics, bouldering, badminton, and dance. A new gymnasium is under construction.
          </p>
        </div>
        <div class="md:col-span-3 md:order-2 overflow-hidden">
          <img
            src={asset('/images/football-pitch.jpg')}
            alt="Full-size football pitch at ISJ"
            loading="lazy"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="Lovely campus and facilities."
    attribution="ISJ Parent, Annual Survey 2025"
  />

  <!-- ═══════ Three-up: Creative, Classroom, Outdoor ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">

        <div class="reveal">
          <div class="overflow-hidden">
            <img
              src={asset('/images/art-class.jpg')}
              alt="Creative arts at ISJ"
              loading="lazy"
              class="w-full aspect-[3/4] object-cover"
            />
          </div>
          <p class="label mt-4">Creative Arts</p>
        </div>

        <div class="reveal">
          <div class="overflow-hidden">
            <img
              src={asset('/images/primary-classroom.jpg')}
              alt="Classroom at ISJ"
              loading="lazy"
              class="w-full aspect-[3/4] object-cover"
            />
          </div>
          <p class="label mt-4">Classrooms</p>
        </div>

        <div class="reveal">
          <div class="overflow-hidden">
            <img
              src={asset('/images/playground.jpg')}
              alt="Outdoor play area at ISJ"
              loading="lazy"
              class="w-full aspect-[3/4] object-cover"
            />
          </div>
          <p class="label mt-4">Outdoor Learning</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Performance — wide image with text alongside ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 lg:gap-16 items-center reveal">
        <div class="md:col-span-3 overflow-hidden">
          <img
            src={asset('/images/news/christmas-concert.jpg')}
            alt="ISJ pupil performing violin at the Christmas concert"
            loading="lazy"
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div class="md:col-span-2">
          <p class="label mb-4">Performance</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-4">Theatre and Music</h2>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
            A dedicated theatre space for drama, concerts, and assemblies. Music tuition across a range of instruments.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Looking Ahead ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-6">Looking Ahead</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-4">New Secondary Campus</h2>
        <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          A dedicated secondary campus opens in 2028, 300 metres from the current site. Purpose-built for GCSEs and A-Levels, with the facilities and spaces that older students need.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
