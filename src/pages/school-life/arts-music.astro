---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Arts, Music & Drama | ISJ Jakarta"
  description="Music, art, and drama at ISJ. Specialist teaching from the first week, individual instrument tuition, school productions, and a dedicated art studio in Pondok Indah."
  canonicalUrl="/school-life/arts-music"
>

  <!-- Hero: Christmas concert, atmospheric -->
  <Hero
    imageSrc="/images/news/christmas-concert.jpg"
    imageAlt="ISJ pupil performing violin at the Christmas concert"
    aspectRatio="standard"
    objectPosition="center 30%"
  />

  <!-- Introduction — centred, brief -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
      <p class="label label-gold mb-5">School Life</p>
      <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-6">Arts, Music and Drama</h1>
      <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
        Every child at ISJ explores music, art, and drama from their first week. These are part of the curriculum, taught by specialists, and taken as seriously as any academic subject.
      </p>
    </div>
  </section>

  <!-- Art — asymmetric split: text left, painting girl right -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div>
          <p class="label mb-5">Art and Design</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Seeing the World Differently</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Drawing, painting, sculpture, printmaking, textiles, digital art. The specialist art studio is where children learn techniques, develop their own voice, and discover that creativity is a way of thinking, not just a skill.
            </p>
            <p>
              Children are encouraged to experiment and take risks. The creative process matters as much as the finished piece. Artwork is displayed throughout the <a href=/school-life/campus class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">school campus</a>, and pupils contribute to exhibitions and collaborative projects throughout the year.
            </p>
          </div>
        </div>
        <div class="overflow-hidden">
          <img
            src=/images/art-class.jpg
            alt="ISJ pupil painting at an easel"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/5] object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Full-bleed: choir singing -->
  <ImageBlock
    src="/images/choir.jpg"
    alt="ISJ school choir singing in blazers and ties"
    aspectRatio="cinematic"
  />

  <!-- Music — narrow column -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Music</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">From First Notes to the Stage</h2>
        <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            All pupils receive specialist music teaching from their first week. Classroom lessons develop rhythm, pitch, and musical literacy. The peripatetic programme offers individual and small-group tuition in piano, violin, guitar, drums, and more.
          </p>
          <p>
            Pupils perform regularly: in assemblies, termly concerts, and annual showcase events. The Christmas concert, with children in blazers performing violin under stage lights, is one of the highlights of the school year. Music builds confidence and stage presence alongside musical skill.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <Testimonial
    quote="A lovely campus with great teachers... it makes the place more joyful."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- Drama — narrow column -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Drama</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Confidence, Empathy, Voice</h2>
        <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            All pupils take part in drama as part of the curriculum. They learn to project their voice, work as a team, and bring stories to life. Opportunities range from class assemblies to full-scale productions in The Hall.
          </p>
          <p>
            Annual school productions bring the whole community together. Pupils take acting, singing, and backstage roles. Drama at ISJ builds the confidence to speak up, the creativity to imagine new possibilities, and the empathy to understand different perspectives — qualities central to the <a href=/school-life/character class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">character and values</a> programme.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
