---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Sport at ISJ | Swimming, Football, Gymnastics & More | ISJ Jakarta"
  description="20+ sports from swimming and football to bouldering and gymnastics. House competitions, inter-school fixtures, and on-site facilities at ISJ Pondok Indah."
  canonicalUrl="/school-life/sport"
>

  <!-- Hero: girls playing rugby -->
  <Hero
    imageSrc="/images/rugby.jpg"
    imageAlt="ISJ girls playing rugby on the school pitch"
    aspectRatio="standard"
    objectPosition="center 35%"
  />

  <!-- Introduction — centred, short -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
      <p class="label label-gold mb-5">School Life</p>
      <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-6">Sport</h1>
      <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
        20+ sports. Swimming from age two. House competitions, inter-school fixtures, and co-curricular sessions every day until 4:00pm.
      </p>
    </div>
  </section>

  <!-- Swimming — asymmetric split: image left, text right -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div class="overflow-hidden">
          <img
            src=/images/insights/physical.jpg
            alt="ISJ pupils swimming during a lesson"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/5] object-cover"
          />
        </div>
        <div>
          <p class="label mb-5">Swimming</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">In the Water from Day One</h2>
          <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            Swimming is part of the curriculum from Pre-Nursery. Regular lessons in the on-site pool ensure that every child becomes a confident, capable swimmer. By the end of Pre-Prep, they are comfortable in the water. By the end of Prep School, they are strong. Facilities are detailed on the <a href=/school-life/campus class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">campus page</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Full-bleed image: house sports medal ceremony -->
  <ImageBlock
    src="/images/house-sports.jpg"
    alt="ISJ pupil receiving a medal at a house sports event, house colours visible"
    aspectRatio="cinematic"
  />

  <!-- House competition — centred text -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
      <p class="label mb-5">Competition</p>
      <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Potter. Tolkien. Lewis. Rowling.</h2>
      <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
        Every child belongs to a house. Houses compete across football, netball, athletics, and more throughout the year. Weekly fixtures and inter-school competitions give pupils the chance to compete, to win and lose with grace, and to develop as teammates. Older pupils plan events, lead teams, and mentor younger children — all part of the <a href=/school-life/character class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">character and values</a> programme at ISJ.
      </p>
    </div>
  </section>

  <!-- Testimonial -->
  <Testimonial
    quote="Clean facilities, friendly teachers, and a good balance of learning and play."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- Programme — narrow column -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">The Programme</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Breadth and Choice</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            Specialist PE teachers lead sessions in gymnastics, athletics, football, badminton, dance, and swimming. 30+ clubs rotate each term. Co-curricular sport runs every afternoon, so children can explore widely and find what they love.
          </p>
          <p>
            Facilities include an on-site swimming pool, a football pitch, a theatre and gym, bouldering, and dedicated play areas. A new gym is currently under construction. Off-campus activities include bouldering sessions at IndoClimb Kemang.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
