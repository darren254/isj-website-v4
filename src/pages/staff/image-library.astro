---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Image Library | ISJ Staff"
  description="ISJ school image library for staff use."
  canonicalUrl="/staff/image-library"
>

  <section class="pt-32 lg:pt-40 pb-20 px-6">
    <div class="mx-auto max-w-[640px] text-center">
      <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">Image Library</h1>
      <p class="text-[15px] text-charcoal-muted leading-relaxed mb-8" style="font-family: var(--font-body);">
        The ISJ image library is being set up. School photographs, event images, and brand assets will be accessible here for staff use once the solution is in place.
      </p>
      <p class="text-[14px] text-charcoal-muted" style="font-family: var(--font-body);">
        In the meantime, contact <a href="mailto:admissions@isj.id" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">admissions@isj.id</a> for access to school images.
      </p>
    </div>
  </section>

</BaseLayout>
