---
import { asset } from '../../utils/paths';
const link = (path: string) => asset(path);
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="The English National Curriculum | ISJ Jakarta"
  description="ISJ follows the English National Curriculum from Early Years to A-Levels. A framework for rigorous, broad education adapted for an international school in Jakarta."
  canonicalUrl="/academics/curriculum"
>

  <!-- Hero -->
  <Hero
    imageSrc="/images/primary-classroom.jpg"
    imageAlt="ISJ pupils in a classroom in Pondok Indah"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- Introduction -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label label-gold mb-4">Academics</p>
        <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-8">The English National Curriculum</h1>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            ISJ follows the English National Curriculum from the Early Years Foundation Stage through GCSEs and A-Levels. The same curriculum taught in the best independent schools in England, delivered in full.
          </p>
          <p>
            The curriculum is treated as a framework, not a script. It provides the structure and rigour of a British education while leaving room for teachers to respond to the children in front of them. Bahasa Indonesia, Indonesian history, and local culture are woven throughout, grounding the experience in Jakarta.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Image -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <img
        src={asset('/images/teacher-pupils.jpg')}
        alt="ISJ teacher working with pupils"
        loading="lazy"
        decoding="async"
        class="w-full aspect-[16/9] object-cover"
      />
    </div>
  </section>

  <!-- Pre-Prep -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Ages 2 to 6</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">Pre-Prep</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            The Early Years Foundation Stage and Key Stage 1. Learning through play, structured teaching, and specialist instruction in music, art, drama, PE, swimming, Bahasa Indonesia, and Mandarin Chinese. Children develop confidence, curiosity, and the foundations of literacy and numeracy in classes of up to 15.
          </p>
        </div>
        <div class="mt-6">
          <a href={link("/academics/pre-prep")} class="whisper-link">Discover Pre-Prep</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Prep -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Ages 7 to 13</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">Prep School</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            Key Stages 2 and 3. Class teachers lead each year group, supported by specialists as children move through the school. The curriculum broadens to include modern foreign languages, design technology, and deeper study in the sciences and humanities. Academic rigour sits alongside 30+ clubs, house competitions, and an annual residential trip to Woolverstone Hall in England.
          </p>
        </div>
        <div class="mt-6">
          <a href={link("/academics/prep-school")} class="whisper-link">Discover Prep School</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Senior -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Ages 14 to 18</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">Senior School</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            GCSEs in Years 10 and 11, A-Levels in Years 12 and 13. Subject specialists teach across the sciences, humanities, languages, and creative arts. The Senior School prepares students for leading universities worldwide, with the same personal attention and high expectations that define ISJ from the earliest years.
          </p>
        </div>
        <div class="mt-6">
          <a href={link("/academics/senior-school")} class="whisper-link">Discover Senior School</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <Testimonial
    quote="A personalised teaching approach and strong support for each child."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- Assessment -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Assessment</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">How Progress Is Measured</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            ISJ uses GL Education assessments to benchmark pupils against international norms. These are independent, standardised tests taken by schools worldwide. The results speak clearly: ISJ pupils score a mean of 122 in English (international norm: 104.6), 118.7 in Maths (norm: 101), and 119.7 in Science (norm: 103.1). That places ISJ in the top 10% of international schools globally.
          </p>
          <p>
            Beyond standardised benchmarking, assessment at ISJ is continuous. Teachers track progress through classwork, observation, and termly reports. Parents receive detailed written reports each term and meet teachers face-to-face for consultations throughout the year.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
