---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Pre-Prep (Ages 2–6) | EYFS & Key Stage 1 | ISJ Jakarta"
  description="EYFS and Key Stage 1 for ages 2 to 6 in Pondok Indah, Jakarta. Dedicated class teachers with specialist music, art, PE, and swimming from age 2."
  canonicalUrl="/academics/pre-prep"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/pre-prep.jpg"
    imageAlt="Pre-Prep children laughing together during circle time at ISJ"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro headingLevel="h1"
      label="Pre-Prep · Ages 2 to 6"
      heading="Where It All Begins"
    >
      <p>
        Pre-Nursery, Nursery, Reception, Year 1, and Year 2. The years that shape how your child feels about learning, about school, and about themselves. ISJ takes them seriously.
      </p>
      <p>
        ISJ Pre-Prep follows the Early Years Foundation Stage and Key Stage 1 of the <a href=/academics/curriculum class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">English National Curriculum</a>. Children learn through structured play, curiosity, and exploration, with specialist teaching in music, art, drama, PE, swimming, Bahasa Indonesia, and Mandarin Chinese.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ A Typical Day ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div>
          <p class="label mb-5">The Day</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">7:50am to 2:00pm</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              The school day runs from 7:50am to 2:00pm, with co-curricular activities available until 4:00pm. Morning drop-off is calm and structured. Children are greeted by name.
            </p>
            <p>
              A typical morning might move from phonics to swimming to free play in the garden. Afternoons bring art, music, or Bahasa Indonesia with specialist teachers. Every day is varied, every day has rhythm.
            </p>
          </div>
        </div>
        <div class="overflow-hidden">
          <img
            src=/images/playground.jpg
            alt="Young children playing on the outdoor climbing structure at ISJ"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/5] object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="The delicate care shown to preschool children is a real strength."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- ═══════ Personal Attention ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div class="overflow-hidden md:order-1">
          <img
            src=/images/happy-children-outdoor.jpg
            alt="Pre-Prep children playing with hoops outdoors"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[4/5] object-cover"
          />
        </div>
        <div class="md:order-2">
          <p class="label mb-5">Personal Attention</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">15 Children Per Class</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              With a staff-to-pupil ratio of 1:5 in Early Years, every child gets the attention they need. Teachers know who is confident and who needs encouragement. They know who needs a quiet word and who needs a challenge.
            </p>
            <p>
              This is the age where children form their relationship with learning. ISJ makes sure that relationship starts off on the right foot.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Image ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <img
        src=/images/tortoises-girls.jpg
        alt="ISJ Pre-Prep children meeting tortoises during an outdoor learning session"
        loading="lazy"
        decoding="async"
        class="w-full aspect-[16/9] object-cover"
      />
    </div>
  </section>

  <!-- ═══════ Specialist Teaching ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="Specialist Teaching"
      heading="More Than Just a Classroom Teacher"
    >
      <p>
        From the earliest years, children at ISJ are taught by specialists in music, art, drama, PE, and swimming. They also begin Bahasa Indonesia and Mandarin Chinese, building language skills that serve them throughout their time at the school and beyond.
      </p>
      <p>
        Swimming starts at age 2 in the on-campus 25-metre pool. By the time children leave Pre-Prep, they are confident in the water.
      </p>
    </SectionIntro>
  </section>


  <!-- ═══════ What Comes Next ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
      <p class="label mb-5">What Comes Next</p>
      <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">Into Prep School</h2>
      <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed mb-8">
        At the end of Year 2, children move into <a href=/academics/prep-school class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Prep School</a> (Ages 7 to 13), where they continue with the English National Curriculum through Key Stages 2 and 3. The transition is seamless because the teachers already know your child.
      </p>
      <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed mt-6">
        To see the school, <a href=/admissions/arrange-a-tour class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">arrange a visit</a>.
      </p>
      <a href=/academics/prep-school class="whisper-link">Discover Prep School</a>
    </div>
  </section>


</BaseLayout>
