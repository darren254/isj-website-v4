---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Results & Outcomes | ISJ Jakarta"
  description="Academic results at ISJ and The Schools Trust network. GL Assessment data, GCSE and A-Level outcomes, and university destinations."
  canonicalUrl="/academics/results"
>

  <!-- Hero -->
  <Hero
    imageSrc="/images/prep-engineering.jpg"
    imageAlt="ISJ pupils working on an engineering project"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- Introduction -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label label-gold mb-4">Academics</p>
        <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-8">Results and Outcomes</h1>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            ISJ is a young school with a strong academic record. Independent standardised assessments place ISJ pupils in the top 10% of international schools worldwide. The broader <a href=/about/the-schools-trust class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Schools Trust</a> network, built by the same trustees over two decades, has a track record of outstanding GCSE and A-Level results and university placements at the highest level.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- GL Assessments -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">ISJ Assessment Data</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">GL Education Assessments</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            ISJ uses GL Education assessments to benchmark pupils against tens of thousands of students in international schools worldwide. These are independent, externally administered tests. A score of 100 represents the international average.
          </p>
        </div>

        <!-- Bar chart -->
        <div class="mt-10 space-y-8" id="gl-chart">
          <div class="gl-subject">
            <p class="text-[length:var(--text-sm)] text-navy mb-2.5">English</p>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-[#E0DDD6]" style="width:0%" data-target="36.5%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">104.6 <span class="opacity-60">Norm</span></span></div>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-charcoal-muted/45" style="width:0%" data-target="56.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">112.5 <span class="opacity-60">UK Selective</span></span></div>
            <div class="flex items-center gap-2.5 h-3.5"><div class="gl-bar bg-navy" style="width:0%" data-target="80%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-navy font-medium whitespace-nowrap">122 <span class="opacity-70">ISJ</span></span></div>
          </div>
          <div class="gl-subject">
            <p class="text-[length:var(--text-sm)] text-navy mb-2.5">Mathematics</p>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-[#E0DDD6]" style="width:0%" data-target="27.5%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">101 <span class="opacity-60">Norm</span></span></div>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-charcoal-muted/45" style="width:0%" data-target="56.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">112.5 <span class="opacity-60">UK Selective</span></span></div>
            <div class="flex items-center gap-2.5 h-3.5"><div class="gl-bar bg-navy" style="width:0%" data-target="71.75%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-navy font-medium whitespace-nowrap">118.7 <span class="opacity-70">ISJ</span></span></div>
          </div>
          <div class="gl-subject">
            <p class="text-[length:var(--text-sm)] text-navy mb-2.5">Science</p>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-[#E0DDD6]" style="width:0%" data-target="32.75%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">103.1 <span class="opacity-60">Norm</span></span></div>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-charcoal-muted/45" style="width:0%" data-target="56.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">112.5 <span class="opacity-60">UK Selective</span></span></div>
            <div class="flex items-center gap-2.5 h-3.5"><div class="gl-bar bg-navy" style="width:0%" data-target="74.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-navy font-medium whitespace-nowrap">119.7 <span class="opacity-70">ISJ</span></span></div>
          </div>
          <div class="gl-subject">
            <p class="text-[length:var(--text-sm)] text-navy mb-2.5">Reading</p>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-[#E0DDD6]" style="width:0%" data-target="25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">100 <span class="opacity-60">Norm</span></span></div>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-charcoal-muted/45" style="width:0%" data-target="56.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">112.5 <span class="opacity-60">UK Selective</span></span></div>
            <div class="flex items-center gap-2.5 h-3.5"><div class="gl-bar bg-navy" style="width:0%" data-target="57.75%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-navy font-medium whitespace-nowrap">113.1 <span class="opacity-70">ISJ</span></span></div>
          </div>
          <div class="gl-subject">
            <p class="text-[length:var(--text-sm)] text-navy mb-2.5">Spelling</p>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-[#E0DDD6]" style="width:0%" data-target="25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">100 <span class="opacity-60">Norm</span></span></div>
            <div class="flex items-center gap-2.5 mb-1 h-3.5"><div class="gl-bar bg-charcoal-muted/45" style="width:0%" data-target="56.25%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-charcoal-muted whitespace-nowrap">112.5 <span class="opacity-60">UK Selective</span></span></div>
            <div class="flex items-center gap-2.5 h-3.5"><div class="gl-bar bg-navy" style="width:0%" data-target="66.75%"></div><span class="text-[length:var(--text-xs)] tabular-nums text-navy font-medium whitespace-nowrap">116.7 <span class="opacity-70">ISJ</span></span></div>
          </div>
        </div>

        <p class="text-[length:var(--text-sm)] text-charcoal-light mt-8">
          Selective independent schools in the UK typically score between 110 and 115.
        </p>
      </div>
    </div>
  </section>

  <!-- Image -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <img
        src=/images/science-experiment.jpg
        alt="ISJ pupils working on a science project"
        loading="lazy"
        decoding="async"
        class="w-full aspect-[16/9] object-cover"
      />
    </div>
  </section>

  <!-- Network Results -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Schools Trust Network</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">GCSE and A-Level Results</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            ISJ is part of The Schools Trust, a UK-registered charity whose trustees have founded 16 British schools across 11 countries since 2004. The exam results across these schools give a clear picture of the academic standard ISJ is built on.
          </p>
          <p>
            At <a href="/academics/senior-school/gcses" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">GCSE</a> and IGCSE, schools founded by Trust trustees consistently achieve 65-81% of grades at A*/A, against a UK national average of around 22%. At <a href="/academics/senior-school/a-levels" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">A-Level</a>, results across the network range from 42-69% at A*/A, with one school placed in the ALPS top 1% of British schools worldwide for value-added.
          </p>
          <p>
            Every school operated by Trust trustees has achieved "Excellent" in all categories of UK government-accredited ISI inspections. The International School of Moscow achieved this rating three consecutive times. The British School of Kuala Lumpur was the first school in Malaysia rated "Excellent" in all areas and the first in Asia to receive COBIS Patron's Accreditation.
          </p>
          <p>
            94% of students attending Trust-operated schools outperform the UK national average.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <Testimonial
    quote="A strong academic focus and high-quality learning."
    attribution="ISJ Parent"
    detail="Annual Survey, November 2025"
  />

  <!-- University Destinations -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">University Destinations</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">Where Students Go Next</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            Graduates from schools founded by Trust trustees study at universities across five continents. The network's track record includes placements at the most competitive institutions in the UK, the US, Europe, and Asia.
          </p>
          <p>
            A-Level students from the network routinely secure places at Russell Group and Ivy League universities. At the British School of Brasilia, 25% of graduates have entered top-30 universities in the UK and the US, with 95% attending their first-choice institution.
          </p>
        </div>
        <!-- University logo grid -->
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 mt-10">
          <a href="https://www.ox.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/oxford.jpg" alt="University of Oxford" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.cam.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/cambridge.jpg" alt="University of Cambridge" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.imperial.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/imperial.jpg" alt="Imperial College London" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.lse.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/lse.jpg" alt="LSE" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.ucl.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/ucl.jpg" alt="UCL" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.kcl.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/kings.jpg" alt="King's College London" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.ed.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/edinburgh.jpg" alt="University of Edinburgh" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.st-andrews.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/st-andrews.jpg" alt="University of St Andrews" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.durham.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/durham.jpg" alt="Durham University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.bristol.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/bristol.jpg" alt="University of Bristol" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.manchester.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/manchester.jpg" alt="University of Manchester" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.bath.ac.uk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/bath.jpg" alt="University of Bath" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.princeton.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/princeton.jpg" alt="Princeton University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.stanford.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/stanford.jpg" alt="Stanford University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.brown.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/brown.jpg" alt="Brown University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.dartmouth.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/dartmouth.jpg" alt="Dartmouth College" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.duke.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/duke.jpg" alt="Duke University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.berkeley.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/berkeley.jpg" alt="UC Berkeley" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.ucla.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/ucla.jpg" alt="UCLA" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.utoronto.ca" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/toronto.jpg" alt="University of Toronto" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.mcgill.ca" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/mcgill.jpg" alt="McGill University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.ubc.ca" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/ubc.jpg" alt="UBC" class="uni-logo" loading="lazy" /></a>
          <a href="https://english.pku.edu.cn" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/peking.jpg" alt="Peking University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.hku.hk" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/hku.jpg" alt="University of Hong Kong" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.nus.edu.sg" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/nus.jpg" alt="NUS Singapore" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.kaist.ac.kr" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/kaist.jpg" alt="KAIST" class="uni-logo" loading="lazy" /></a>
          <a href="https://en.snu.ac.kr" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/snu.jpg" alt="Seoul National University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.sydney.edu.au" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/sydney.jpg" alt="University of Sydney" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.monash.edu" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/monash.jpg" alt="Monash University" class="uni-logo" loading="lazy" /></a>
          <a href="https://www.unimelb.edu.au" target="_blank" rel="noopener noreferrer" class="uni-card"><img src="/images/universities/melbourne.jpg" alt="University of Melbourne" class="uni-logo" loading="lazy" /></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ISJ's Path -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Looking Ahead</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">ISJ's Senior School</h2>
        <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            <a href=/academics/senior-school class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">ISJ's Senior School</a> GCSE and A-Level programmes are now underway. The first GCSE cohort will sit examinations in 2028. The school applies the same governance, teaching standards, and expectations that produced the results above across the Trust network.
          </p>
          <p>
            University preparation at ISJ includes UCAS guidance from Year 11, personal statement support, and structured advice on courses and destinations. For students considering universities in the US, Europe, Asia, or Australia, that guidance is adapted accordingly. The goal is a clear, well-supported pathway from ISJ to the right university for each student. The <a href=/academics/curriculum class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">English National Curriculum</a> runs from Early Years through to A-Levels, providing continuity across every year group.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .uni-card {
    background: #fff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 12px;
    transition: box-shadow 0.3s ease;
  }
  .uni-card:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .uni-logo {
    max-width: 90px;
    max-height: 48px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .uni-card:hover .uni-logo {
    opacity: 0.9;
  }
  .gl-bar {
    height: 6px;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

<script is:inline>
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var bars = entry.target.querySelectorAll('.gl-bar');
          bars.forEach(function(bar, i) {
            setTimeout(function() {
              bar.style.width = bar.dataset.target;
            }, i * 80);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.gl-subject').forEach(function(group) {
      observer.observe(group);
    });
  })();
</script>
