<PolicyLayout
  title="Campus Access and Security Policy | ISJ Jakarta"
  description="The Campus Access and Security Policy for The International School of Jakarta, covering visitor management, access control, and campus security procedures."
  policyName="Campus Access and Security Policy"
  lastReviewed="August 2025"
  category="Safeguarding and Welfare"
  canonicalUrl="/policies/campus-security"
>

  <!-- Table of Contents -->
  <nav>
    <p>Contents</p>
    <ol>
      <li><a href="#purpose" >1. Purpose of This Policy</a></li>
      <li><a href="#scope" >2. Scope</a></li>
      <li><a href="#procedures" >3. Procedures</a></li>
      <li><a href="#drop-off-pick-up" >4. Drop-Off and Pick-Up Arrangements</a></li>
      <li><a href="#deliveries" >5. Deliveries</a></li>
