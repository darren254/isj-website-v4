---
/**
 * Brand Guide — Internal staff resource.
 * Logo downloads, colour palette, and usage guidelines.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const colours = [
  { name: 'Navy', hex: '#1B2A4A', css: '--color-navy', text: 'white' },
  { name: 'Navy Light', hex: '#2A3D66', css: '--color-navy-light', text: 'white' },
  { name: 'Gold', hex: '#FFC43D', css: '--color-gold', text: '#1B2A4A' },
  { name: 'Gold Muted', hex: '#D4A84A', css: '--color-gold-muted', text: 'white' },
  { name: 'Cream', hex: '#F7F5F0', css: '--color-cream', text: '#2C2B29' },
  { name: 'Charcoal', hex: '#2C2B29', css: '--color-charcoal', text: 'white' },
];

const logoSets = [
  {
    label: 'Navy',
    colourKey: 'blue',
    bg: 'bg-[#F7F5F0]',
    border: 'border-charcoal/10',
    note: null,
  },
  {
    label: 'White',
    colourKey: 'white',
    bg: 'bg-navy',
    border: 'border-navy-light',
    note: 'White logo on transparent background. Will appear invisible when opened in Finder or on a white surface — this is correct. Place on navy or dark photography.',
  },
  {
    label: 'Gold',
    colourKey: 'gold',
    bg: 'bg-navy',
    border: 'border-navy-light',
    note: null,
  },
];

const sizes = [400, 800, 1600];

const houses = [
  { name: 'Lewis',   colours: ['#14967A', '#A8B89C'], mascot: 'Mouse'  },
  { name: 'Potter',  colours: ['#EAA01A', '#C9A01A'], mascot: 'Rabbit' },
  { name: 'Rowling', colours: ['#CE2611', '#FFFFFF'],  mascot: 'Stag'   },
  { name: 'Tolkien', colours: ['#244780', '#7695C9'], mascot: 'Wizard' },
];

const downloadIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
---

<BaseLayout
  title="Brand Guide — ISJ"
  description="ISJ logo assets, colour palette, typography, and brand guidelines for staff use. Includes downloadable assets and usage rules."
  canonicalUrl="/brand"
  hideCta={true}
>

  <!-- Hero -->
  <section style="padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 460px;">
      <p class="label label-gold mb-4">Staff Resource</p>
      <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy">Brand Guide</h1>
      <p class="mt-4 text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
        Logo assets, colour palette, and usage guidance for The Independent School of Jakarta.
      </p>
    </div>
  </section>

  <!-- Logo Assets -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label mb-8" style="letter-spacing: 0.12em; font-size: 0.7rem;">LOGO ASSETS</p>

      {logoSets.map((set) => (
        <div style="margin-bottom: 64px;">
          <!-- Variant heading -->
          <h2 class="font-heading text-[length:var(--text-lg)] font-light text-navy" style="margin-bottom: 24px;">{set.label}</h2>

          <!-- Two containers on one row -->
          <div style="display: flex; align-items: flex-start; gap: 24px; flex-wrap: wrap;">

            <!-- Horizontal lockup -->
            <div style="flex: 0 0 auto;">
              <p class="label" style="font-size: 0.65rem; letter-spacing: 0.14em; margin-bottom: 10px; color: rgba(44,43,41,0.5);">HORIZONTAL</p>
              <div
                class={`${set.bg} ${set.border} border rounded-sm`}
                style="width: 460px; height: 200px; display: flex; align-items: center; justify-content: center;"
              >
                <img
                  src={`/images/brand/isj-logo-horizontal-${set.colourKey}-800.png`}
                  alt={`ISJ logo horizontal — ${set.label}`}
                  loading="lazy"
                  style="max-width: 260px; max-height: 80px; width: auto; height: auto; display: block;"
                />
              </div>
              {set.note && (
                <div style="margin-top: 10px; padding: 10px 14px; background: rgba(44,43,41,0.04); border-left: 3px solid rgba(44,43,41,0.2); max-width: 460px;">
                  <p class="text-[length:var(--text-xs)] text-charcoal-light leading-relaxed">{set.note}</p>
                </div>
              )}
              <div style="margin-top: 12px; display: flex; flex-wrap: wrap; gap: 8px;">
                {sizes.map((s) => (
                  <a
                    href={`/images/brand/isj-logo-horizontal-${set.colourKey}-${s}.png`}
                    download={`isj-logo-horizontal-${set.colourKey}-${s}.png`}
                    class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
                    style="padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
                    set:html={`${downloadIcon} ${s}px`}
                  />
                ))}
              </div>
            </div>

            <!-- Square / Social -->
            <div style="flex: 0 0 auto;">
              <p class="label" style="font-size: 0.65rem; letter-spacing: 0.14em; margin-bottom: 10px; color: rgba(44,43,41,0.5);">SQUARE / SOCIAL</p>
              <div
                class={`${set.bg} ${set.border} border rounded-sm`}
                style="width: 200px; height: 200px; display: flex; align-items: center; justify-content: center;"
              >
                <img
                  src={`/images/brand/isj-logo-square-${set.colourKey}-800.png`}
                  alt={`ISJ logo square — ${set.label}`}
                  loading="lazy"
                  style="max-width: 110px; max-height: 110px; width: auto; height: auto; display: block;"
                />
              </div>
              {set.note && (
                <div style="margin-top: 10px; padding: 10px 14px; background: rgba(44,43,41,0.04); border-left: 3px solid rgba(44,43,41,0.2); max-width: 200px;">
                  <p class="text-[length:var(--text-xs)] text-charcoal-light leading-relaxed">{set.note}</p>
                </div>
              )}
              <div style="margin-top: 12px; display: flex; flex-wrap: wrap; gap: 8px;">
                {sizes.map((s) => (
                  <a
                    href={`/images/brand/isj-logo-square-${set.colourKey}-${s}.png`}
                    download={`isj-logo-square-${set.colourKey}-${s}.png`}
                    class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
                    style="padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
                    set:html={`${downloadIcon} ${s}px`}
                  />
                ))}
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lion Mark -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 10px;">LION MARK</p>
      <p class="text-[length:var(--text-sm)] text-charcoal-light" style="margin-bottom: 32px; max-width: 52ch;">
        Standalone mark for contexts where the full lockup is too large — favicons, watermarks, embossing, social avatars.
      </p>
      <div style="display: flex; gap: 20px; flex-wrap: wrap;">

        <!-- Navy on cream -->
        <div style="flex: 0 0 auto;">
          <div
            class="bg-[#F7F5F0] border border-charcoal/10 rounded-sm"
            style="width: 160px; height: 160px; display: flex; align-items: center; justify-content: center;"
          >
            <img src="/images/brand/isj-lion-blue.png" alt="ISJ lion mark — Navy" loading="lazy" style="max-width: 80px; max-height: 80px; width: auto; height: auto; display: block;" />
          </div>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 8px;">Navy on cream</p>
          <a
            href="/images/brand/isj-lion-blue.png"
            download="isj-lion-navy.png"
            class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
            style="margin-top: 8px; padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
            set:html={`${downloadIcon} Download`}
          />
        </div>

        <!-- Gold on cream -->
        <div style="flex: 0 0 auto;">
          <div
            class="bg-[#F7F5F0] border border-charcoal/10 rounded-sm"
            style="width: 160px; height: 160px; display: flex; align-items: center; justify-content: center;"
          >
            <img src="/images/brand/isj-lion-gold.png" alt="ISJ lion mark — Gold" loading="lazy" style="max-width: 80px; max-height: 80px; width: auto; height: auto; display: block;" />
          </div>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 8px;">Gold on cream</p>
          <a
            href="/images/brand/isj-lion-gold.png"
            download="isj-lion-gold.png"
            class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
            style="margin-top: 8px; padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
            set:html={`${downloadIcon} Download`}
          />
        </div>

        <!-- Gold on navy -->
        <div style="flex: 0 0 auto;">
          <div
            class="bg-navy border border-navy-light rounded-sm"
            style="width: 160px; height: 160px; display: flex; align-items: center; justify-content: center;"
          >
            <img src="/images/brand/isj-lion-gold-800.png" alt="ISJ lion mark — Gold on navy" loading="lazy" style="max-width: 80px; max-height: 80px; width: auto; height: auto; display: block;" />
          </div>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 8px;">Gold on navy</p>
          <a
            href="/images/brand/isj-lion-gold-800.png"
            download="isj-lion-gold-800.png"
            class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
            style="margin-top: 8px; padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
            set:html={`${downloadIcon} Download`}
          />
        </div>

        <!-- Watermark -->
        <div style="flex: 0 0 auto;">
          <div
            class="bg-[#F7F5F0] border border-charcoal/10 rounded-sm overflow-hidden"
            style="width: 160px; height: 160px; display: flex; align-items: center; justify-content: center;"
          >
            <img src="/images/brand/isj-lion-watermark.jpg" alt="ISJ lion watermark" loading="lazy" style="max-width: 80px; max-height: 80px; width: auto; height: auto; display: block; opacity: 0.6;" />
          </div>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 8px;">Watermark</p>
          <a
            href="/images/brand/isj-lion-watermark.jpg"
            download="isj-lion-watermark.jpg"
            class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
            style="margin-top: 8px; padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
            set:html={`${downloadIcon} Download`}
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Houses -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 10px;">HOUSES</p>
      <p class="text-[length:var(--text-sm)] text-charcoal-light" style="margin-bottom: 32px; max-width: 52ch;">
        Four houses, each with a dedicated badge and colour palette. Use for certificates, scorecards, newsletters, and event materials.
      </p>
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
        {houses.map((house) => (
          <div>
            <div class="rounded-sm overflow-hidden" style="aspect-ratio: 1;">
              <img
                src={`/images/brand/houses/${house.name.toLowerCase()}-back.png`}
                alt={`${house.name} house badge`}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <p class="text-[length:var(--text-sm)] font-medium text-charcoal" style="margin-top: 12px;">{house.name}</p>
            <div style="margin-top: 6px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              {house.colours.map((hex) => (
                <div style="display: flex; align-items: center; gap: 6px;">
                  <div
                    class="rounded-full border border-charcoal/20 flex-shrink-0"
                    style={`width: 14px; height: 14px; background-color: ${hex};`}
                  />
                  <span class="text-[length:var(--text-xs)] text-charcoal-light font-mono">{hex}</span>
                </div>
              ))}
            </div>
            <a
              href={`/images/brand/houses/${house.name.toLowerCase()}-back.png`}
              download={`isj-house-${house.name.toLowerCase()}.png`}
              class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
              style="margin-top: 12px; padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem;"
              set:html={`${downloadIcon} Badge`}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Colour Palette -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 32px;">COLOUR PALETTE</p>
      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px;">
        {colours.map((c) => (
          <div class="group">
            <div
              class="rounded-sm transition-transform duration-[var(--transition-base)] group-hover:scale-[1.02]"
              style={`aspect-ratio: 1; background-color: ${c.hex}; display: flex; align-items: flex-end; padding: 12px;${c.hex === '#F7F5F0' ? ' border: 1px solid rgba(44,43,41,0.15);' : ''}`}
            >
              <span
                class="text-[length:var(--text-xs)] font-medium tracking-wide"
                style={`color: ${c.text}; opacity: 0.85; font-size: 0.65rem; font-family: monospace;`}
              >
                {c.hex}
              </span>
            </div>
            <p class="text-[length:var(--text-sm)] text-charcoal font-medium" style="margin-top: 8px;">{c.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 32px;">TYPOGRAPHY</p>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px;">

        <!-- Cormorant Garamond -->
        <div>
          <p class="label" style="font-size: 0.65rem; letter-spacing: 0.14em; color: rgba(44,43,41,0.5); margin-bottom: 16px;">HEADINGS</p>
          <p class="font-heading text-navy" style="font-size: 2.8rem; font-weight: 300; line-height: 1.1; margin-bottom: 8px;">The quick brown fox</p>
          <p class="font-heading text-navy" style="font-size: 1.4rem; font-weight: 300; line-height: 1.3; margin-bottom: 16px;">jumps over the lazy dog</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="letter-spacing: 0.04em;">Cormorant Garamond — Light 300</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 4px;">All headings and display text.</p>
        </div>

        <!-- DM Sans -->
        <div>
          <p class="label" style="font-size: 0.65rem; letter-spacing: 0.14em; color: rgba(44,43,41,0.5); margin-bottom: 16px;">BODY</p>
          <p class="text-charcoal" style="font-size: 2rem; font-weight: 400; line-height: 1.15; margin-bottom: 8px;">The quick brown fox</p>
          <p class="text-charcoal" style="font-size: 1.1rem; font-weight: 400; line-height: 1.5; margin-bottom: 16px;">jumps over the lazy dog</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="letter-spacing: 0.04em;">DM Sans — Regular 400</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-light" style="margin-top: 4px;">Body copy, labels, and UI elements.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Lions Sports Identity -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 10px;">LIONS — SPORTS IDENTITY</p>
      <p class="text-[length:var(--text-sm)] text-charcoal-light" style="margin-bottom: 32px; max-width: 52ch;">
        Used for all competitive sport — kit, match programmes, fixture lists, and social posts. Navy and Gold, consistent with the main palette.
      </p>
      <div style="display: flex; gap: 40px; align-items: flex-start; flex-wrap: wrap;">
        <div
          class="bg-white border border-charcoal/10 rounded-sm"
          style="width: 180px; height: 180px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
        >
          <img
            src="/images/brand/isj-lions-sports.jpg"
            alt="ISJ Lions sports badge"
            loading="lazy"
            style="max-width: 140px; max-height: 140px; width: auto; height: auto; display: block; object-fit: contain;"
          />
        </div>
        <div style="display: flex; flex-direction: column; justify-content: center; gap: 16px; padding-top: 8px;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div class="rounded-sm border border-charcoal/10 flex-shrink-0" style="width: 28px; height: 28px; background-color: #1B2A4A;"></div>
            <div>
              <p class="text-[length:var(--text-sm)] text-charcoal font-medium">Navy</p>
              <p class="text-[length:var(--text-xs)] text-charcoal-muted font-mono">#1B2A4A</p>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 12px;">
            <div class="rounded-sm border border-charcoal/10 flex-shrink-0" style="width: 28px; height: 28px; background-color: #FFC43D;"></div>
            <div>
              <p class="text-[length:var(--text-sm)] text-charcoal font-medium">Gold</p>
              <p class="text-[length:var(--text-xs)] text-charcoal-muted font-mono">#FFC43D</p>
            </div>
          </div>
          <a
            href="/images/brand/isj-lions-sports.jpg"
            download="isj-lions-sports.jpg"
            class="inline-flex items-center gap-1.5 text-charcoal-light hover:text-navy hover:border-navy/30 transition-colors duration-[var(--transition-base)]"
            style="padding: 6px 12px; border: 1px solid rgba(44,43,41,0.15); border-radius: 2px; font-size: 0.7rem; width: fit-content;"
            set:html={`${downloadIcon} Download badge`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Usage Notes -->
  <section style="border-top: 1px solid rgba(44,43,41,0.06); padding-top: 64px; padding-bottom: 64px; padding-left: clamp(24px, 5vw, 80px); padding-right: clamp(24px, 5vw, 80px);">
    <div style="max-width: 600px; margin: 0 auto 0 0;">
      <p class="label" style="font-size: 0.7rem; letter-spacing: 0.12em; margin-bottom: 32px;">USAGE NOTES</p>
      <ul class="text-[length:var(--text-sm)] text-charcoal-light leading-relaxed" style="display: flex; flex-direction: column; gap: 16px; list-style: none; padding: 0;">
        <li>Use the <strong class="text-charcoal font-medium">navy logo</strong> on light backgrounds (cream, white).</li>
        <li>Use the <strong class="text-charcoal font-medium">white logo</strong> on dark backgrounds (navy, photography). The file has a transparent background — it will appear invisible on white.</li>
        <li>Use the <strong class="text-charcoal font-medium">gold logo</strong> sparingly — accent and special applications only.</li>
        <li>Maintain clear space around the logo equal to the height of the crown element.</li>
        <li>Never stretch, rotate, recolour, or add effects to any logo.</li>
        <li>For web use, 400px and 800px exports are sufficient. Use 1600px for print and large-format.</li>
      </ul>
    </div>
  </section>

</BaseLayout>
