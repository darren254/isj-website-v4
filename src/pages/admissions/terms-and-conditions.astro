---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
---

<BaseLayout
  title="Admissions Terms & Conditions | ISJ Jakarta"
  description="Admissions terms and conditions for The Independent School of Jakarta."
  canonicalUrl="/admissions/terms-and-conditions"
>

  <section class="pt-32 lg:pt-40 section-pad px-6">
    <SectionIntro headingLevel="h1"
      label="Admissions"
      heading="Admissions Terms and Conditions"
    >
      <p>
        This page is being prepared. For questions about admissions terms, fee payment, or withdrawal policies, contact the admissions team at <a href="mailto:admissions@isj.id" class="whisper-link">admissions@isj.id</a>. See also the <a href="/admissions/fees" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">fees page</a>, <a href="/admissions/how-to-apply" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">how to apply</a>, and the school's <a href="/privacy" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">privacy policy</a>.
      </p>
    </SectionIntro>
  </section>

</BaseLayout>
