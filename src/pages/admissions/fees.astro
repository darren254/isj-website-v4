---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionIntro from '../../components/SectionIntro.astro';

const prePrep = [
  { year: 'Pre-Nursery', ages: 'Age 2+', annual: '148,524,000', perTerm: '50,993,240' },
  { year: 'Nursery', ages: 'Age 3+', annual: '173,277,795', perTerm: '59,492,043' },
  { year: 'Reception', ages: 'Age 4+', annual: '289,357,440', perTerm: '99,346,054' },
];

const prep = [
  { year: 'Year 1', ages: 'Age 5+', annual: '419,702,400', perTerm: '144,097,824' },
  { year: 'Year 2', ages: 'Age 6+', annual: '419,702,400', perTerm: '144,097,824' },
  { year: 'Year 3', ages: 'Age 7+', annual: '437,819,200', perTerm: '150,317,925' },
  { year: 'Year 4', ages: 'Age 8+', annual: '437,819,200', perTerm: '150,317,925' },
  { year: 'Year 5', ages: 'Age 9+', annual: '464,984,000', perTerm: '159,644,507' },
  { year: 'Year 6', ages: 'Age 10+', annual: '464,984,000', perTerm: '159,644,507' },
];

const senior = [
  { year: 'Year 7', ages: 'Age 11+', annual: '484,733,600', perTerm: '166,425,203' },
  { year: 'Year 8', ages: 'Age 12+', annual: '484,733,600', perTerm: '166,425,203' },
  { year: 'Year 9', ages: 'Age 13+', annual: '484,733,600', perTerm: '166,425,203' },
  { year: 'Year 10 (GCSE)', ages: 'Age 14+', annual: '484,733,600', perTerm: '166,425,203' },
  { year: 'Year 11 (GCSE)', ages: 'Age 15+', annual: '484,733,600', perTerm: '166,425,203' },
  { year: 'Year 12 (A-Level)', ages: 'Age 16+', annual: '493,787,700', perTerm: '169,533,777' },
  { year: 'Year 13 (A-Level)', ages: 'Age 17+', annual: '504,957,600', perTerm: '173,368,776' },
];

const phases = [
  { name: 'Pre-Prep', rows: prePrep },
  { name: 'Prep School', rows: prep },
  { name: 'Senior School', rows: senior },
];
---

<BaseLayout
  title="Tuition Fees 2026/27 | ISJ Jakarta"
  description="View tuition fees for The Independent School of Jakarta. Transparent pricing from Pre-Nursery to A-Levels, with sibling discounts and clear payment terms."
  canonicalUrl="/admissions/fees"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/boys-laughing-together.jpg"
    imageAlt="Three boys in blue polo shirts laughing together at ISJ"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro headingLevel="h1"
      label="Admissions"
      heading="Tuition Fees 2026/27"
    >
      <p>
        All fees are in Indonesian Rupiah (IDR) for the 2026/27 academic year. Payable annually or by term. <a href=/admissions/scholarships class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">Bursaries and scholarships</a> are available for eligible families.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ Fee Tables ═══════ -->
  {phases.map(({ name, rows }) => (
    <section class="px-6 pb-20">
      <div class="mx-auto max-w-lg reveal">
        <p class="label mb-6">{name}</p>
        <table class="w-full">
          <thead>
            <tr class="border-b border-charcoal/10">
              <th class="text-[length:var(--text-xs)] tracking-[0.1em] uppercase text-charcoal-light font-medium text-left py-2.5">Year Group</th>
              <th class="text-[length:var(--text-xs)] tracking-[0.1em] uppercase text-charcoal-light font-medium text-right py-2.5">Per Year (IDR)</th>
              <th class="text-[length:var(--text-xs)] tracking-[0.1em] uppercase text-charcoal-light font-medium text-right py-2.5">Per Term (IDR)</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr class="border-b border-charcoal/5">
                <td class="text-[length:var(--text-sm)] text-navy py-3">{row.year}</td>
                <td class="text-[length:var(--text-sm)] text-charcoal py-3 text-right tabular-nums">{row.annual}</td>
                <td class="text-[length:var(--text-sm)] text-charcoal-light py-3 text-right tabular-nums">{row.perTerm}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ))}

  <!-- ═══════ Enrolment & Sibling Discounts ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-lg">

      <div class="reveal mb-16">
        <p class="label mb-8">Enrolment</p>
        <div class="flex justify-between items-baseline py-3 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">Application Fee</span>
          <span class="text-[length:var(--text-base)] text-charcoal tabular-nums">4,680,000</span>
        </div>
        <div class="flex justify-between items-baseline py-3 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">Enrolment Deposit</span>
          <span class="text-[length:var(--text-base)] text-charcoal tabular-nums">16,328,000</span>
        </div>
        <p class="text-[length:var(--text-sm)] text-charcoal-light mt-4">
          The application fee is non-refundable. The enrolment deposit is refundable when your child leaves the school.
        </p>
      </div>

      <div class="reveal">
        <p class="label mb-8">Sibling Discounts</p>
        <div class="flex justify-between items-baseline py-3 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">3rd child</span>
          <span class="text-[length:var(--text-base)] text-charcoal">5%</span>
        </div>
        <div class="flex justify-between items-baseline py-3 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">4th child</span>
          <span class="text-[length:var(--text-base)] text-charcoal">10%</span>
        </div>
        <div class="flex justify-between items-baseline py-3 border-b border-charcoal/5">
          <span class="text-[length:var(--text-base)] text-navy">5th child and beyond</span>
          <span class="text-[length:var(--text-base)] text-charcoal">15%</span>
        </div>
        <p class="text-[length:var(--text-sm)] text-charcoal-light mt-4">
          Applied to the youngest children's fees. The first two pay the standard rate.
        </p>
      </div>

    </div>
  </section>

  <!-- ═══════ What's Included ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-lg">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">

        <div class="reveal">
          <p class="label mb-6">Included in Fees</p>
          <ul class="space-y-2.5 text-[length:var(--text-sm)] text-charcoal-light leading-relaxed">
            <li>Teaching and the full curriculum</li>
            <li>Learning materials and textbooks</li>
            <li>Use of all campus facilities</li>
            <li>Pastoral care and academic support</li>
            <li>Co-curricular activities</li>
          </ul>
        </div>

        <div class="reveal">
          <p class="label mb-6">Charged Separately</p>
          <ul class="space-y-2.5 text-[length:var(--text-sm)] text-charcoal-light leading-relaxed">
            <li>Lunch</li>
            <li>School trips and events</li>
            <li>External exam fees</li>
            <li>Uniforms and transport</li>
            <li>Individual music lessons</li>
            <li>UK residential programme</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Payment ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-6">Payment</p>
        <div class="space-y-4 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          <p>
            Fees are payable annually or by term (three terms per year). Payment is due 14 days before the start of each term.
          </p>
          <p>
            Full payment terms, withdrawal notice periods, and refund policies are set out in the <a href=/admissions/terms-and-conditions class="whisper-link">Admissions Terms and Conditions</a>. To begin the enrolment process, visit the <a href=/admissions/how-to-apply class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">How to Apply</a> page.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
