---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Arrange a Tour | Visit ISJ Pondok Indah"
  description="Arrange a personalised tour of ISJ. See the Pondok Indah campus, meet the teachers, and discover why families choose a British education in Jakarta."
  canonicalUrl="/admissions/arrange-a-tour"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/girls-playing-lawn.jpg"
    imageAlt="Two girls in gingham dresses playing on the ISJ campus lawn"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Form + Contact — first thing after hero ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

        <!-- LEFT: Heading + trust signals + direct contact -->
        <div class="reveal">
          <p class="label mb-5">Admissions</p>
          <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-6">Come and See for Yourself</h1>
          <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light mb-8">
            Most families say the visit is what made their decision. Walk the corridors, look in on a lesson, meet the teachers who will know your child by name.
          </p>

          <!-- Trust signals -->
          <div class="border-t border-charcoal/10 pt-8 mb-8 space-y-4">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <p class="text-[length:var(--text-sm)] text-charcoal-light">Personalised — each tour covers the year groups and areas that matter to your family</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <p class="text-[length:var(--text-sm)] text-charcoal-light">Guided by a senior member of staff who knows every child and classroom</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <p class="text-[length:var(--text-sm)] text-charcoal-light">During a live school day — see ISJ as it really is, not a staged open day</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <p class="text-[length:var(--text-sm)] text-charcoal-light">Children welcome — and <a href="/admissions/virtual-tour" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">video tours</a> available for families still overseas</p>
            </div>
          </div>

          <!-- Parent quote — social proof next to the form -->
          <blockquote class="border-l-2 border-gold/40 pl-5 mb-10">
            <p class="text-[length:var(--text-sm)] text-charcoal-light italic leading-relaxed">"Small class sizes, strong pastoral care and warm staff — our children are genuinely cared for and encouraged."</p>
            <cite class="block text-[length:var(--text-xs)] text-charcoal/50 mt-2 not-italic">ISJ Parent, 2025 Survey</cite>
          </blockquote>

          <!-- Direct contact — email & phone (WhatsApp is the floating button) -->
          <div class="border-t border-charcoal/10 pt-8">
            <p class="text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-4">Prefer to get in touch directly?</p>
            <div class="space-y-3">
              <a href="mailto:admissions@isj.id" class="flex items-center gap-3 text-[length:var(--text-sm)] text-charcoal-light hover:text-navy transition-colors">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                admissions@isj.id
              </a>
              <a href="tel:+622127826788" class="flex items-center gap-3 text-[length:var(--text-sm)] text-charcoal-light hover:text-navy transition-colors">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                +62 21-2782-6788
              </a>
            </div>
          </div>
        </div>

        <!-- RIGHT: The form -->
        <div class="reveal">
          <div class="bg-white border border-charcoal/10 p-8 md:p-10">
            <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-2">Book a Tour</h2>
            <p class="text-[length:var(--text-sm)] text-charcoal-light mb-8">
              The admissions team will confirm your visit within one working day.
            </p>

            <form id="tour-form" class="space-y-5" novalidate>
              <!-- Parent Name -->
              <div>
                <label for="parent-name" class="block text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-2">Your Name *</label>
                <input
                  type="text"
                  id="parent-name"
                  name="parent_name"
                  required
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="Full name"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-2">Email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="you@example.com"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-2">Phone / WhatsApp</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="+62 xxx xxxx xxxx"
                />
              </div>

              <!-- Children -->
              <div id="children-section">
                <p class="text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-3">Your Children</p>
                <div class="space-y-3" id="children-list">
                  <div class="grid grid-cols-2 gap-3 child-row">
                    <div>
                      <label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1">Child's Name</label>
                      <input
                        type="text"
                        name="child_name_1"
                        class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                        placeholder="First name"
                      />
                    </div>
                    <div>
                      <label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1">Date of Birth</label>
                      <input
                        type="text"
                        name="child_dob_1"
                        class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                        placeholder="e.g. March 2020"
                      />
                    </div>
                  </div>
                </div>
                <button
                  type="button"
                  id="add-child-btn"
                  class="mt-3 text-[length:var(--text-sm)] text-navy/60 hover:text-navy transition-colors flex items-center gap-1.5"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  Add another child
                </button>
              </div>

              <!-- Preferred Date -->
              <div>
                <label for="preferred-date" class="block text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-2">Preferred Date (optional)</label>
                <input
                  type="text"
                  id="preferred-date"
                  name="preferred_date"
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="e.g. Any Tuesday in April"
                />
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-[length:var(--text-xs)] tracking-[0.12em] uppercase font-medium text-navy mb-2">Anything Else? (optional)</label>
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors resize-y"
                  placeholder="Questions, current school, or anything that helps the team prepare."
                ></textarea>
              </div>

              <!-- Submit -->
              <div class="pt-1">
                <button
                  type="submit"
                  class="inline-flex items-center justify-center px-10 py-3.5 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)] w-full"
                >
                  Request a Tour
                </button>
              </div>

              <!-- Success / Error -->
              <div id="form-success" class="hidden bg-cream border border-gold/30 p-6 text-center">
                <p class="text-[length:var(--text-base)] text-navy font-medium">Thank you for your enquiry.</p>
                <p class="text-[length:var(--text-sm)] text-charcoal-light mt-2">The admissions team will be in touch within one working day to arrange your visit.</p>
              </div>
              <div id="form-error" class="hidden bg-red-50 border border-red-200 p-6 text-center">
                <p class="text-[length:var(--text-base)] text-red-800 font-medium">Something went wrong.</p>
                <p class="text-[length:var(--text-sm)] text-red-600 mt-2">Please email the admissions team directly at <a href="mailto:admissions@isj.id" class="underline">admissions@isj.id</a> or WhatsApp <a href="https://wa.me/6281110007672" class="underline">+62 811 1000 7672</a>.</p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="A lovely campus with great teachers… it makes the place more joyful."
    attribution="ISJ Parent, Annual Survey 2025"
  />

  <!-- ═══════ What to Expect — below form for those who want detail ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div>
          <p class="label mb-5">What to Expect</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">A Morning at ISJ</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Tours run on school days between 8:30am and 11:00am, when lessons are in full swing. Each visit lasts around an hour.
            </p>
            <p>
              Bring your child along. The admissions team will tailor the route to the year groups that matter to your family, and your guide can answer questions about the curriculum, class sizes, and daily routines as you walk.
            </p>
            <p>
              If you decide ISJ is right, the admissions team will walk you through the <a href="/admissions/how-to-apply" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">next steps</a>. You can also explore <a href="/admissions/fees" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">fees</a> and the <a href="/admissions/age-guide" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">age guide</a> ahead of your visit.
            </p>
          </div>
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/teacher-pupils.jpg"
            alt="A teacher working with pupils at ISJ"
            loading="lazy"
            class="w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Practical Details ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Where to Find Us</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Jl. R.A. Kartini No. Kav. 12, Pondok Indah, South Jakarta. Reception will welcome you on arrival. Visitor parking available on site.
          </p>
        </div>
        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Relocating to Jakarta?</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            ISJ offers live <a href="/admissions/virtual-tour" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">video tours</a> for families still overseas. The same personal experience, wherever you are.
          </p>
        </div>
        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Questions First?</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Check the <a href="/faqs" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">FAQs</a> or reach the admissions team on <a href="https://wa.me/6281110007672" class="text-navy hover:text-navy/70 transition-colors underline underline-offset-2 decoration-charcoal/20">WhatsApp</a> for a quick answer.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var childCount = 1;
    var addBtn = document.getElementById('add-child-btn');
    var childrenList = document.getElementById('children-list');

    if (addBtn && childrenList) {
      addBtn.addEventListener('click', function() {
        childCount++;
        var row = document.createElement('div');
        row.className = 'grid grid-cols-2 gap-3 child-row';
        row.innerHTML = '<div>' +
          '<label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1">Child\'s Name</label>' +
          '<input type="text" name="child_name_' + childCount + '" class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="First name" />' +
          '</div><div>' +
          '<label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1">Date of Birth</label>' +
          '<input type="text" name="child_dob_' + childCount + '" class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="e.g. March 2020" />' +
          '</div>';
        childrenList.appendChild(row);
        if (childCount >= 5) addBtn.style.display = 'none';
      });
    }

    // Form handling — mailto fallback until Cloudflare Workers + Resend
    var form = document.getElementById('tour-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var name = form.querySelector('#parent-name').value.trim();
      var email = form.querySelector('#email').value.trim();
      var phone = form.querySelector('#phone').value.trim();
      var prefDate = form.querySelector('#preferred-date').value.trim();
      var message = form.querySelector('#message').value.trim();

      if (!name || !email) {
        form.querySelector('#parent-name').focus();
        return;
      }

      // Gather children
      var children = [];
      var rows = form.querySelectorAll('.child-row');
      rows.forEach(function(row, i) {
        var cName = row.querySelector('input[name="child_name_' + (i+1) + '"]');
        var cDob = row.querySelector('input[name="child_dob_' + (i+1) + '"]');
        if (cName && cName.value.trim()) {
          children.push(cName.value.trim() + (cDob && cDob.value.trim() ? ' (DOB: ' + cDob.value.trim() + ')' : ''));
        }
      });

      var subject = 'Tour Request from ' + name;
      var body = 'Tour Request\n\n';
      body += 'Name: ' + name + '\n';
      body += 'Email: ' + email + '\n';
      if (phone) body += 'Phone/WhatsApp: ' + phone + '\n';
      if (children.length) body += 'Children: ' + children.join(', ') + '\n';
      if (prefDate) body += 'Preferred date: ' + prefDate + '\n';
      if (message) body += '\nMessage: ' + message + '\n';

      window.location.href = 'mailto:admissions@isj.id?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      // Show success state
      var formElements = form.querySelectorAll(':scope > div');
      formElements.forEach(function(el) {
        if (el.id !== 'form-success' && el.id !== 'form-error') {
          el.style.display = 'none';
        }
      });
      form.querySelector('.pt-1').style.display = 'none';
      document.getElementById('form-success').classList.remove('hidden');
    });
  });
</script>
