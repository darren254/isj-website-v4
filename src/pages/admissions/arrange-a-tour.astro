---
import { asset } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import Testimonial from '../../components/Testimonial.astro';
import CTABlock from '../../components/CTABlock.astro';
---

<BaseLayout
  title="Arrange a Tour | Visit ISJ Pondok Indah"
  description="Arrange a personalised tour of ISJ. See our Pondok Indah campus, meet the teachers, and discover why families choose a British education in Jakarta."
  canonicalUrl="/admissions/arrange-a-tour"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/happy-children-outdoor.jpg"
    imageAlt="Children at The Independent School of Jakarta"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="Admissions"
      heading="Come and See for Yourself"
    >
      <p>
        The best way to know whether ISJ is right for your family is to visit. Walk the corridors, look in on a lesson, meet the teachers who will know your child by name. Most families tell us the visit is what made their decision.
      </p>
      <p>
        Tours are personalised. We will show you the parts of the school that matter to your family, answer your questions honestly, and give you the time you need.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ What to Expect ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div>
          <p class="label mb-5">What to Expect</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">A Morning with Us</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Your tour is guided by a senior member of staff who knows every child and every classroom. You will see lessons in progress, meet teachers, and get a real sense of the school day.
            </p>
            <p>
              Tours typically last around an hour. We schedule them during the school day so you see ISJ as it really is, not an empty building.
            </p>
            <p>
              Bring your child if you like. There is no pressure, no hard sell. We want you to leave with a clear picture and honest answers.
            </p>
          </div>
        </div>
        <div class="overflow-hidden">
          <img
            src={asset('/images/teacher-pupils.jpg')}
            alt="A teacher working with pupils at ISJ"
            loading="lazy"
            class="w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Full-bleed Image ═══════ -->
  <ImageBlock
    src="/images/playground.jpg"
    alt="Children playing at ISJ Pondok Indah"
  />

  <!-- ═══════ Tour Options ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="text-center mb-16 reveal">
        <p class="label mb-5">Tour Options</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Choose What Works for You</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">

        <!-- In-Person Tour -->
        <div class="reveal">
          <div class="mb-5">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">In-Person Tour</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Visit during the school day. See lessons, meet teachers, explore the campus. This is what we recommend for families in Jakarta.
          </p>
        </div>

        <!-- Virtual Tour -->
        <div class="reveal">
          <div class="mb-5">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Virtual Tour</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            For families relocating to Jakarta, we offer a live video tour with our admissions team. The same personal experience, wherever you are.
          </p>
        </div>

        <!-- Open Morning -->
        <div class="reveal">
          <div class="mb-5">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Open Mornings</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            We hold Open Mornings throughout the year. A chance to meet the Head, talk to current parents, and see the school with other prospective families.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="A lovely campus with great teachers… it makes the place more joyful."
    attribution="ISJ Parent, Annual Survey 2025"
  />

  <!-- ═══════ Booking Form ═══════ -->
  <section id="book" class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="text-center mb-12 reveal">
        <p class="label mb-5">Arrange Your Visit</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Book a Tour</h2>
        <p class="text-[length:var(--text-base)] text-charcoal-light mt-4 leading-relaxed">
          Fill in the form below and our admissions team will be in touch within one working day to confirm your visit.
        </p>
      </div>

      <form id="tour-form" class="space-y-6 reveal" novalidate>
        <!-- Parent Name -->
        <div>
          <label for="parent-name" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Your Name</label>
          <input
            type="text"
            id="parent-name"
            name="parent_name"
            required
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="Full name"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="you@example.com"
          />
        </div>

        <!-- Phone / WhatsApp -->
        <div>
          <label for="phone" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Phone or WhatsApp</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="+62 xxx xxxx xxxx"
          />
        </div>

        <!-- Child's Age / Year Group -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="child-age" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Child's Age</label>
            <input
              type="text"
              id="child-age"
              name="child_age"
              class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
              placeholder="e.g. 4"
            />
          </div>
          <div>
            <label for="current-school" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Current School (optional)</label>
            <input
              type="text"
              id="current-school"
              name="current_school"
              class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
              placeholder="School name"
            />
          </div>
        </div>

        <!-- Tour Type -->
        <div>
          <label for="tour-type" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Preferred Tour Type</label>
          <select
            id="tour-type"
            name="tour_type"
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors appearance-none"
            style="background-image: url('data:image/svg+xml;utf8,<svg fill=\'none\' stroke=\'%231B2A4A\' stroke-width=\'2\' viewBox=\'0 0 24 24\' xmlns=\'http://www.w3.org/2000/svg\'><path d=\'m6 9 6 6 6-6\'/></svg>'); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1rem;"
          >
            <option value="in-person">In-Person Tour</option>
            <option value="virtual">Virtual Tour (Video Call)</option>
            <option value="open-morning">Open Morning</option>
          </select>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Anything We Should Know? (optional)</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors resize-y"
            placeholder="Questions, preferred dates, or anything that would help us prepare for your visit."
          ></textarea>
        </div>

        <!-- Submit -->
        <div class="pt-2">
          <button
            type="submit"
            class="inline-flex items-center px-10 py-3.5 border border-navy bg-navy text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy-light transition-colors duration-[var(--transition-base)] w-full sm:w-auto justify-center"
          >
            Request a Tour
          </button>
        </div>

        <!-- Success / Error Messages -->
        <div id="form-success" class="hidden bg-cream border border-gold/30 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-navy font-medium">Thank you for your enquiry.</p>
          <p class="text-[length:var(--text-sm)] text-charcoal-light mt-2">Our admissions team will be in touch within one working day to arrange your visit.</p>
        </div>

        <div id="form-error" class="hidden bg-red-50 border border-red-200 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-red-800 font-medium">Something went wrong.</p>
          <p class="text-[length:var(--text-sm)] text-red-600 mt-2">Please email us directly at <a href="mailto:admissions@isj.id" class="underline">admissions@isj.id</a> or WhatsApp <a href="https://wa.me/628111000767" class="underline">+62 811 1000 7672</a>.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ═══════ Or Get in Touch Directly ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="text-center reveal">
        <p class="label mb-5">Prefer to Talk?</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Get in Touch Directly</h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-[length:var(--text-base)] text-charcoal-light">
          <a href="https://wa.me/628111000767" class="inline-flex items-center gap-2 hover:text-navy transition-colors">
            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            +62 811 1000 7672
          </a>
          <span class="hidden sm:inline text-charcoal/30">|</span>
          <a href="mailto:admissions@isj.id" class="hover:text-navy transition-colors">
            admissions@isj.id
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Practical Info ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="text-center mb-16 reveal">
        <p class="label mb-5">Before You Visit</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Practical Details</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">When to Visit</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Tours run on school days during term time, typically between 8:30am and 11:00am. We schedule them when lessons are in full swing so you see the school at its best.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Where to Find Us</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            ISJ is in Pondok Indah, South Jakarta. When you arrive, reception will welcome you and your guide will meet you there. Visitor parking is available on site.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">What to Bring</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Just yourselves. Bring your child along if you would like them to see the school too. We will have all the information you need on the day.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">After the Tour</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            If you decide ISJ is right for your family, our admissions team will walk you through the next steps. There is no obligation and no time pressure.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ CTA ═══════ -->
  <CTABlock
    heading="Ready to Take the Next Step?"
    description="Find out about fees, entry requirements, and how to apply."
    primaryText="How to Apply"
    primaryHref="/admissions/how-to-apply"
    secondaryText="View fees"
    secondaryHref="/admissions/fees"
  />

</BaseLayout>

<script is:inline>
  // Form handling — currently sends via mailto fallback
  // Replace with Cloudflare Workers + Resend endpoint when available
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('tour-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var name = form.querySelector('#parent-name').value.trim();
      var email = form.querySelector('#email').value.trim();
      var phone = form.querySelector('#phone').value.trim();
      var childAge = form.querySelector('#child-age').value.trim();
      var currentSchool = form.querySelector('#current-school').value.trim();
      var tourType = form.querySelector('#tour-type').value;
      var message = form.querySelector('#message').value.trim();

      // Basic validation
      if (!name || !email) {
        form.querySelector('#parent-name').focus();
        return;
      }

      // Build mailto body
      var subject = 'Tour Request from ' + name;
      var body = 'Tour Request\n\n';
      body += 'Name: ' + name + '\n';
      body += 'Email: ' + email + '\n';
      if (phone) body += 'Phone/WhatsApp: ' + phone + '\n';
      if (childAge) body += 'Child\'s Age: ' + childAge + '\n';
      if (currentSchool) body += 'Current School: ' + currentSchool + '\n';
      body += 'Tour Type: ' + tourType + '\n';
      if (message) body += '\nMessage: ' + message + '\n';

      // Open mailto
      window.location.href = 'mailto:admissions@isj.id?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      // Show success message
      form.querySelectorAll('div, .pt-2').forEach(function(el) {
        if (el.id !== 'form-success' && el.id !== 'form-error') {
          el.style.display = 'none';
        }
      });
      document.getElementById('form-success').classList.remove('hidden');
    });
  });
</script>
