---
import { asset } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import ImageBlock from '../../components/ImageBlock.astro';
import Testimonial from '../../components/Testimonial.astro';
---

<BaseLayout
  title="Arrange a Tour | Visit ISJ Pondok Indah"
  description="Arrange a personalised tour of ISJ. See our Pondok Indah campus, meet the teachers, and discover why families choose a British education in Jakarta."
  canonicalUrl="/admissions/arrange-a-tour"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/happy-children-outdoor.jpg"
    imageAlt="Children at The Independent School of Jakarta"
    aspectRatio="standard"
    objectPosition="center 40%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <SectionIntro
      label="Admissions"
      heading="Come and See for Yourself"
    >
      <p>
        The best way to know whether ISJ is right for your family is to visit. Walk the corridors, look in on a lesson, meet the teachers who will know your child by name. Most families tell us the visit is what made their decision.
      </p>
      <p>
        Tours are personalised. We show you the parts of the school that matter to your family and give you the time you need.
      </p>
    </SectionIntro>
  </section>

  <!-- ═══════ What to Expect ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center reveal">
        <div>
          <p class="label mb-5">What to Expect</p>
          <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1] mb-6">A Morning with Us</h2>
          <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Your tour is guided by a senior member of staff who knows every child and every classroom. You will see lessons in progress, meet teachers, and get a real sense of the school day.
            </p>
            <p>
              Tours typically last around an hour. We schedule them during the school day so you see ISJ as it really is.
            </p>
            <p>
              We would encourage you to bring your child along. For families relocating to Jakarta, we also offer live video tours with the admissions team.
            </p>
          </div>
        </div>
        <div class="overflow-hidden">
          <img
            src={asset('/images/teacher-pupils.jpg')}
            alt="A teacher working with pupils at ISJ"
            loading="lazy"
            class="w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Full-bleed Image ═══════ -->
  <ImageBlock
    src="/images/playground.jpg"
    alt="Children playing at ISJ Pondok Indah"
  />

  <!-- ═══════ Testimonial ═══════ -->
  <Testimonial
    quote="A lovely campus with great teachers… it makes the place more joyful."
    attribution="ISJ Parent, Annual Survey 2025"
  />

  <!-- ═══════ Booking Form ═══════ -->
  <section id="book" class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="text-center mb-12 reveal">
        <p class="label mb-5">Arrange Your Visit</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Book a Tour</h2>
        <p class="text-[length:var(--text-base)] text-charcoal-light mt-4 leading-relaxed">
          Fill in the form below and our admissions team will be in touch within one working day to confirm your visit.
        </p>
      </div>

      <form id="tour-form" class="space-y-6 reveal" novalidate>
        <!-- Parent Name -->
        <div>
          <label for="parent-name" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Your Name</label>
          <input
            type="text"
            id="parent-name"
            name="parent_name"
            required
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="Full name"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="you@example.com"
          />
        </div>

        <!-- Phone -->
        <div>
          <label for="phone" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
            placeholder="+62 xxx xxxx xxxx"
          />
        </div>

        <!-- Children -->
        <div id="children-section">
          <p class="text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-4">Your Children</p>

          <div class="space-y-4" id="children-list">
            <!-- Child 1 -->
            <div class="grid grid-cols-2 gap-4 child-row">
              <div>
                <label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1.5">Child's Name</label>
                <input
                  type="text"
                  name="child_name_1"
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="First name"
                />
              </div>
              <div>
                <label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1.5">Age</label>
                <input
                  type="text"
                  name="child_age_1"
                  class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors"
                  placeholder="e.g. 4"
                />
              </div>
            </div>
          </div>

          <!-- Add another child -->
          <button
            type="button"
            id="add-child-btn"
            class="mt-4 text-[length:var(--text-sm)] text-navy/60 hover:text-navy transition-colors flex items-center gap-1.5"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add another child
          </button>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium text-navy mb-2">Anything Else? (optional)</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors resize-y"
            placeholder="Questions, preferred dates, or anything that would help us prepare for your visit."
          ></textarea>
        </div>

        <!-- Submit -->
        <div class="pt-2">
          <button
            type="submit"
            class="inline-flex items-center px-10 py-3.5 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)] w-full sm:w-auto justify-center"
          >
            Request a Tour
          </button>
        </div>

        <!-- Success / Error Messages -->
        <div id="form-success" class="hidden bg-cream border border-gold/30 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-navy font-medium">Thank you for your enquiry.</p>
          <p class="text-[length:var(--text-sm)] text-charcoal-light mt-2">Our admissions team will be in touch within one working day to arrange your visit.</p>
        </div>

        <div id="form-error" class="hidden bg-red-50 border border-red-200 p-6 text-center">
          <p class="text-[length:var(--text-base)] text-red-800 font-medium">Something went wrong.</p>
          <p class="text-[length:var(--text-sm)] text-red-600 mt-2">Please email us directly at <a href="mailto:admissions@isj.id" class="underline">admissions@isj.id</a>.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ═══════ Or Get in Touch Directly ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="text-center reveal">
        <p class="label mb-5">Prefer to Talk?</p>
        <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-6">Get in Touch Directly</h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-[length:var(--text-base)] text-charcoal-light">
          <a href="mailto:admissions@isj.id" class="hover:text-navy transition-colors">
            admissions@isj.id
          </a>
          <span class="hidden sm:inline text-charcoal/30">|</span>
          <a href="tel:+622127826788" class="hover:text-navy transition-colors">
            +62 21-2782-6788
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Practical Info ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="text-center mb-16 reveal">
        <p class="label mb-5">Before You Visit</p>
        <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Practical Details</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">When to Visit</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            Tours run on school days during term time, typically between 8:30am and 11:00am. We schedule them when lessons are in full swing so you see the school at its best.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Where to Find Us</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            ISJ is in Pondok Indah, South Jakarta. When you arrive, reception will welcome you and your guide will meet you there. Visitor parking is available on site.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">Video Tours</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            For families relocating to Jakarta, we offer a live video tour with the admissions team. The same personal experience, wherever you are.
          </p>
        </div>

        <div class="reveal">
          <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mb-3">After the Tour</h3>
          <p class="text-[length:var(--text-sm)] leading-relaxed text-charcoal-light">
            If you decide ISJ is right for your family, our admissions team will walk you through the next steps.
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Add another child row
  document.addEventListener('DOMContentLoaded', function() {
    var childCount = 1;
    var addBtn = document.getElementById('add-child-btn');
    var childrenList = document.getElementById('children-list');

    if (addBtn && childrenList) {
      addBtn.addEventListener('click', function() {
        childCount++;
        var row = document.createElement('div');
        row.className = 'grid grid-cols-2 gap-4 child-row';
        row.innerHTML = '<div>' +
          '<label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1.5">Child\'s Name</label>' +
          '<input type="text" name="child_name_' + childCount + '" class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="First name" />' +
          '</div><div>' +
          '<label class="block text-[length:var(--text-xs)] text-charcoal-light mb-1.5">Age</label>' +
          '<input type="text" name="child_age_' + childCount + '" class="w-full border border-charcoal/20 bg-white px-4 py-3 text-[length:var(--text-base)] text-charcoal focus:border-navy focus:outline-none transition-colors" placeholder="e.g. 4" />' +
          '</div>';
        childrenList.appendChild(row);
        if (childCount >= 5) addBtn.style.display = 'none';
      });
    }

    // Form handling — mailto fallback until Cloudflare Workers + Resend
    var form = document.getElementById('tour-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var name = form.querySelector('#parent-name').value.trim();
      var email = form.querySelector('#email').value.trim();
      var phone = form.querySelector('#phone').value.trim();
      var message = form.querySelector('#message').value.trim();

      if (!name || !email) {
        form.querySelector('#parent-name').focus();
        return;
      }

      // Gather children
      var children = [];
      var rows = form.querySelectorAll('.child-row');
      rows.forEach(function(row, i) {
        var cName = row.querySelector('input[name="child_name_' + (i+1) + '"]');
        var cAge = row.querySelector('input[name="child_age_' + (i+1) + '"]');
        if (cName && cName.value.trim()) {
          children.push(cName.value.trim() + (cAge && cAge.value.trim() ? ' (age ' + cAge.value.trim() + ')' : ''));
        }
      });

      var subject = 'Tour Request from ' + name;
      var body = 'Tour Request\n\n';
      body += 'Name: ' + name + '\n';
      body += 'Email: ' + email + '\n';
      if (phone) body += 'Phone: ' + phone + '\n';
      if (children.length) body += 'Children: ' + children.join(', ') + '\n';
      if (message) body += '\nMessage: ' + message + '\n';

      window.location.href = 'mailto:admissions@isj.id?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

      form.querySelectorAll(':scope > div, :scope > .pt-2').forEach(function(el) {
        if (el.id !== 'form-success' && el.id !== 'form-error') {
          el.style.display = 'none';
        }
      });
      document.getElementById('form-success').classList.remove('hidden');
    });
  });
</script>
