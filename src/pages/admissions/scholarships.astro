---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---

<BaseLayout
  title="Bursaries & Scholarships | ISJ Jakarta"
  description="Financial assistance for families at ISJ. The Global Continuity Bursary for expatriate families and the Ki Hajar Dewantara Scholarship for Indonesian pupils."
  canonicalUrl="/admissions/scholarships"
>

  <!-- ═══════ Hero ═══════ -->
  <Hero
    imageSrc="/images/bursaries-hero.jpg"
    imageAlt="Children at The Independent School of Jakarta"
    aspectRatio="standard"
    objectPosition="center 35%"
  />

  <!-- ═══════ Introduction ═══════ -->
  <section class="section-pad px-6">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <p class="label mb-5">Admissions</p>
        <h1 class="font-heading text-[length:var(--text-2xl)] md:text-[length:var(--text-3xl)] font-light text-navy leading-[1.1] mb-8">Bursaries and Scholarships</h1>
        <p class="text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
          With the support of The Schools Trust, ISJ offers financial assistance to broaden access. Two programmes exist for families where full tuition fees are a barrier but ISJ is the right school for the child.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════ Global Continuity Bursary ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <div class="border-t border-charcoal/10 pt-10 md:pt-14">
          <p class="label label-gold mb-4">For Expatriate Families</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">Global Continuity Bursary</h2>
          <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Financial assistance for expatriate families who are a strong fit for the ISJ community but find full tuition fees a significant hurdle. Specifically intended for families on local-plus contracts, the self-employed, or those privately funding education.
            </p>
            <p>
              The bursary is means-tested. Support levels are determined by a confidential review of each family's financial profile. Both the school and the recipient agree to keep the existence and amount of any award strictly confidential.
            </p>
            <p>
              If full fees are a barrier but ISJ is the right school for your child, this is worth a conversation. The process is straightforward and entirely confidential.
            </p>
          </div>
          <div class="mt-10">
            <a
              href="mailto:admissions@isj.id?subject=Global%20Continuity%20Bursary&body=Hi%20ISJ%2C%20we%20are%20interested%20in%20a%20place%20for%20our%20child%20and%20would%20like%20to%20discuss%20the%20Global%20Continuity%20Bursary."
              class="whisper-link text-[length:var(--text-sm)]"
            >
              Enquire about this bursary
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Ki Hajar Dewantara Scholarship ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <div class="border-t border-charcoal/10 pt-10 md:pt-14">
          <p class="label label-gold mb-4">For Indonesian Families</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mb-8">The Ki Hajar Dewantara Scholarship</h2>
          <div class="space-y-6 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
            <p>
              Named in honour of Indonesia's national education hero, Ki Hajar Dewantara (1889-1959), who founded the Taman Siswa movement and championed the idea that education should be accessible to all, regardless of background.
            </p>
            <p>
              Awarded to Indonesian pupils who demonstrate high academic potential but lack the financial means to attend. Awards of up to 100% fee relief are assessed on academic potential and family circumstances. A limited number of places are available each year.
            </p>
            <p>
              If you believe your child could thrive at ISJ, get in touch. The conversation is confidential and there is no obligation.
            </p>
          </div>
          <div class="mt-10">
            <a
              href="mailto:admissions@isj.id?subject=Ki%20Hajar%20Dewantara%20Scholarship&body=Hi%20ISJ%2C%20I%20would%20like%20to%20learn%20more%20about%20the%20Ki%20Hajar%20Dewantara%20Scholarship."
              class="whisper-link text-[length:var(--text-sm)]"
            >
              Enquire about this scholarship
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ Contact ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-narrow)]">
      <div class="reveal">
        <div class="border-t border-charcoal/10 pt-10 md:pt-14">
          <p class="label mb-5">Confidential Enquiries</p>
          <p class="text-[length:var(--text-base)] text-charcoal-light leading-relaxed">
            Contact the admissions team at <a href="mailto:admissions@isj.id" class="whisper-link">admissions@isj.id</a> or <a href="https://wa.me/6281110007672" class="whisper-link">+62 811 1000 7672</a> to start a confidential conversation about eligibility.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
