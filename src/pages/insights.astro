---
import { asset } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';

// Article data
const featured = {
  title: 'The Best International Schools in Jakarta: An Insider\'s Guide',
  excerpt: 'A comprehensive look at the international school landscape in Jakarta, covering curriculum options, fees, locations, and what to prioritise when choosing a school for your family.',
  date: '15 Feb 2026',
  category: 'Jakarta Life',
  href: '/insights/best-international-schools-jakarta',
  image: '/images/campus-aerial.jpg',
};

const recommended = [
  { title: 'Cost of Living in Jakarta: What Expats Should Budget', category: 'Jakarta Life', href: '/insights/cost-of-living-jakarta' },
  { title: 'The Particular Agony of the Jakarta Commute for Young Families', category: 'Jakarta Life', href: '/insights/jakarta-commute' },
  { title: '35 Best Things to Do with Kids in Jakarta', category: 'Jakarta Life', href: '/insights/things-to-do-kids-jakarta' },
  { title: 'Metacognition: Teaching Children How to Think About Thinking', category: 'Education', href: '/insights/metacognition' },
  { title: 'Healthcare and Health Insurance for Expats in Jakarta', category: 'Jakarta Life', href: '/insights/healthcare-expats-jakarta' },
];

const articles = [
  { title: 'New to Jakarta? A Contact List for Expats', excerpt: 'Essential contacts for families relocating to Jakarta.', date: '21 Jan 2026', category: 'Jakarta Life', href: '/insights/expat-contact-list-jakarta', image: '/images/happy-children-outdoor.jpg' },
  { title: 'The Power of Singing Across the Curriculum', excerpt: 'How music and singing are integrated across subjects at ISJ.', date: '14 Nov 2025', category: 'Education', href: '/insights/singing-across-curriculum', image: '/images/choir.jpg' },
  { title: 'The Benefits of Outdoor Learning in Early Years', excerpt: 'Why learning outside the classroom matters for young children.', date: '14 Nov 2025', category: 'Education', href: '/insights/outdoor-learning-early-years', image: '/images/playground.jpg' },
];

const moreArticles = [
  { title: 'The Power of Positive Feedback in Teaching', date: '3 Nov 2025', category: 'Education', href: '/insights/positive-feedback-teaching' },
  { title: 'The Benefits of Physical Activity on Academic Attainment', date: '31 Oct 2025', category: 'Education', href: '/insights/physical-activity-academic-attainment' },
  { title: 'The Historical Foundation of British Prep Schools', date: '20 Oct 2025', category: 'Education', href: '/insights/british-prep-schools-history' },
  { title: 'The Science of Happy Students: Why Well-Being Is a Prerequisite for Learning', date: '20 Oct 2025', category: 'Education', href: '/insights/science-happy-students' },
  { title: 'The Value of Positive Behaviour Management', date: '13 Oct 2025', category: 'Education', href: '/insights/positive-behaviour-management' },
  { title: 'A Residential Is Not Just a Trip', date: '13 Oct 2025', category: 'School Life', href: '/insights/residential-not-just-a-trip' },
];
---

<BaseLayout
  title="Insights | Education Blog | ISJ Jakarta"
  description="Expert insights on British education, expat life in Jakarta, and raising globally minded children. From The Independent School of Jakarta."
  canonicalUrl="/insights"
>

  <!-- ═══════ Header ═══════ -->
  <section class="pt-32 lg:pt-40 section-pad px-6">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div>
          <p class="label mb-4">Insights</p>
          <h1 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">Guides and Resources</h1>
        </div>
        <p class="text-[length:var(--text-base)] text-charcoal-light max-w-md md:text-right">
          Practical guides for families considering a British education in Jakarta.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════ Featured + Recommended ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12">

        <!-- Featured Article -->
        <a href={featured.href} class="lg:col-span-3 group reveal">
          <div class="overflow-hidden">
            <img
              src={asset(featured.image)}
              alt=""
              loading="lazy"
              class="w-full aspect-[16/10] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.02]"
            />
          </div>
          <p class="label label-gold mt-5">{featured.category}</p>
          <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy leading-[1.1] mt-2 mb-3">{featured.title}</h2>
          <p class="text-[length:var(--text-sm)] text-charcoal-light leading-relaxed line-clamp-2">{featured.excerpt}</p>
          <p class="text-[length:var(--text-xs)] text-charcoal-muted mt-3">{featured.date}</p>
        </a>

        <!-- Recommended List -->
        <div class="lg:col-span-2 reveal">
          <p class="label mb-6">Recommended</p>
          <div class="space-y-0">
            {recommended.map((item, i) => (
              <a href={item.href} class="flex gap-4 py-4 border-b border-charcoal/5 group">
                <span class="font-heading text-[length:var(--text-xl)] font-light text-charcoal-muted leading-none mt-0.5">{i + 1}</span>
                <div>
                  <p class="text-[length:var(--text-xs)] text-gold-muted uppercase tracking-wider mb-1">{item.category}</p>
                  <p class="text-[length:var(--text-base)] text-navy font-medium leading-snug group-hover:text-navy-light transition-colors">{item.title}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════ Three-up Cards ═══════ -->
  <section class="px-6 pb-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {articles.map((article) => (
          <a href={article.href} class="group reveal">
            <div class="overflow-hidden">
              <img
                src={asset(article.image)}
                alt=""
                loading="lazy"
                class="w-full aspect-[4/3] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.02]"
              />
            </div>
            <p class="label label-gold mt-4">{article.category}</p>
            <h3 class="text-[length:var(--text-base)] text-navy font-medium leading-snug mt-1 mb-2 group-hover:text-navy-light transition-colors">{article.title}</h3>
            <p class="text-[length:var(--text-sm)] text-charcoal-light leading-relaxed line-clamp-2">{article.excerpt}</p>
            <p class="text-[length:var(--text-xs)] text-charcoal-muted mt-3">{article.date}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ Latest List ═══════ -->
  <section class="section-pad px-6 border-t border-charcoal/10">
    <div class="mx-auto max-w-lg">
      <p class="label mb-8">All Articles</p>
      {moreArticles.map((article) => (
        <a href={article.href} class="flex justify-between items-baseline py-4 border-b border-charcoal/5 group reveal">
          <div>
            <p class="text-[length:var(--text-xs)] text-gold-muted uppercase tracking-wider mb-1">{article.category}</p>
            <p class="text-[length:var(--text-base)] text-navy group-hover:text-navy-light transition-colors">{article.title}</p>
          </div>
          <span class="text-[length:var(--text-xs)] text-charcoal-muted ml-4 shrink-0">{article.date}</span>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
