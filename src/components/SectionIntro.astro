---
/**
 * SectionIntro — Aman-style centred text block.
 * Label (all-caps tracked) above a heading, with body text below.
 * All centred within the narrow column.
 */
interface Props {
  label?: string;
  heading: string;
  headingLevel?: 'h1' | 'h2';
  class?: string;
}

const { label, heading, headingLevel = 'h2', class: className = '' } = Astro.props;
const Tag = headingLevel;
---

<div class={`text-column reveal ${className}`}>
  {label && (
    <p class="label mb-5">{label}</p>
  )}
  <Tag class="font-heading text-[length:var(--text-2xl)] font-light text-navy mb-6 leading-[1.1]">
    {heading}
  </Tag>
  <div class="space-y-5 text-[length:var(--text-base)] leading-relaxed text-charcoal-light">
    <slot />
  </div>
</div>
