---
/**
 * MobileCta — Aman-style fixed bottom bar on mobile.
 * Full-width, solid background. Contains CTA + WhatsApp.
 * Only visible below sm breakpoint (< 640px).
 * Hides when footer is in view.
 */
interface Props {
  hideCta?: boolean;
}
const { hideCta = false } = Astro.props;
---

{!hideCta && (
  <div id="mobile-cta-bar" class="mobile-bar">
    <div class="mobile-bar-inner">
      <a href="/admissions/arrange-a-tour" class="mobile-bar-cta">
        Arrange a Tour
      </a>
      <a
        href="https://wa.me/6281110007672"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Chat on WhatsApp"
        class="mobile-bar-wa"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
      </a>
    </div>
  </div>
)}

<style>
  .mobile-bar {
    display: none;
  }
  @media (max-width: 639px) {
    .mobile-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 90;
      display: block;
      padding: 0.75rem 1rem;
      padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
      transition: transform 0.3s ease;
    }
    .mobile-bar-inner {
      display: flex;
      align-items: center;
      background: var(--color-charcoal);
      border-radius: 4px;
    }
    .mobile-bar-cta {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.5rem;
      color: var(--color-cream);
      font-family: var(--font-body);
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .mobile-bar-cta:active {
      opacity: 0.8;
    }
    .mobile-bar-wa {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 3.5rem;
      flex-shrink: 0;
      padding: 1rem 0;
      color: #6B9B7D;
      border-left: 1px solid rgba(255,255,255,0.12);
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .mobile-bar-wa:active {
      opacity: 0.7;
    }
  }
</style>

<script is:inline>
(function() {
  var bar = document.getElementById('mobile-cta-bar');
  if (!bar) return;
  // Hide when footer is visible
  var footer = document.querySelector('footer');
  if (footer) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        bar.style.transform = entry.isIntersecting ? 'translateY(100%)' : 'translateY(0)';
      });
    }, { threshold: 0.05 });
    observer.observe(footer);
  }
})();
</script>
