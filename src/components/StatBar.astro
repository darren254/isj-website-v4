---
/**
 * StatBar — Key figures with count-up animation.
 * Gold numbers, thin dividers, staggered reveal.
 */
interface Props {
  stats: Array<{ value: string; label: string }>;
}

const { stats } = Astro.props;
---

<section class="section-pad-sm">
  <div class="mx-auto max-w-[var(--content-wide)] px-6">
    <div class="flex flex-wrap justify-center gap-y-8 reveal-stagger">
      {stats.map((stat, i) => (
        <div class={`reveal flex-1 min-w-[160px] max-w-[260px] text-center ${i > 0 ? 'border-l border-charcoal/10' : ''}`}>
          <p
            class="font-heading font-light text-gold-muted leading-none stat-value"
            style="font-size: clamp(2rem, 1.5rem + 1.75vw, 3rem);"
            data-value={stat.value}
          >
            {stat.value}
          </p>
          <p class="label mt-3">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var raw = el.getAttribute('data-value') || '';
        var match = raw.match(/^(\d+)/);
        if (!match) return;
        var target = parseInt(match[1]);
        var suffix = raw.slice(match[0].length);
        var duration = 1400;
        var start = performance.now();
        function tick(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }
        el.textContent = '0' + suffix;
        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.stat-value').forEach(function(el) {
      observer.observe(el);
    });
  })();
</script>
