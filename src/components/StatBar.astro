---
/**
 * StatBar — Key figures with count-up animation.
 * Gold numbers, muted labels, generous spacing.
 */
interface Props {
  stats: Array<{ value: string; label: string; detail?: string }>;
}

const { stats } = Astro.props;
---

<section class="section-pad-sm">
  <div class="mx-auto max-w-[var(--content-wide)] px-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-16 text-center reveal-stagger">
      {stats.map((stat) => (
        <div class="reveal">
          <p
            class="font-heading font-light leading-none text-gold-muted stat-value"
            style="font-size: clamp(3rem, 2.5rem + 2vw, 4.5rem);"
            data-value={stat.value}
          >
            {stat.value}
          </p>
          <p class="mt-4 text-[length:var(--text-sm)] font-medium text-navy tracking-wide uppercase" style="letter-spacing: 0.12em;">
            {stat.label}
          </p>
          {stat.detail && (
            <p class="mt-1.5 text-[length:var(--text-xs)] text-charcoal-muted leading-relaxed">
              {stat.detail}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Count-up animation for stat values
  function animateStats() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const raw = el.dataset.value || '';
          
          // Parse the numeric part
          const match = raw.match(/^(\d+)/);
          if (!match) return; // Non-numeric like "Top 10%" — skip animation
          
          const target = parseInt(match[1]);
          const suffix = raw.slice(match[0].length); // e.g., "+" or "%"
          const prefix = raw.slice(0, raw.indexOf(match[0])); // e.g., "" 
          const duration = 1200;
          const start = performance.now();
          
          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = Math.round(target * eased);
            el.textContent = prefix + current + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          }
          
          el.textContent = prefix + '0' + suffix;
          requestAnimationFrame(tick);
          observer.unobserve(el);
        });
      },
      { threshold: 0.3 }
    );

    document.querySelectorAll('.stat-value').forEach((el) => observer.observe(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateStats);
  } else {
    animateStats();
  }
</script>
