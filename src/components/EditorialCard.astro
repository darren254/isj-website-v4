---
import { asset } from '../utils/paths';
/**
 * EditorialCard — Image + label + title + link.
 * Aman-style: no container, no shadow, no border. Content floats.
 */
interface Props {
  imageSrc: string;
  imageAlt: string;
  label: string;
  title: string;
  description?: string;
  href: string;
  linkText?: string;
}

const { imageSrc, imageAlt, label, title, description, href, linkText = 'Discover more' } = Astro.props;
---

<a href={href} class="group block reveal">
  <div class="overflow-hidden">
    <img
      src={asset(imageSrc)}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      class="w-full aspect-[3/4] object-cover transition-transform duration-[var(--transition-glacial)] group-hover:scale-[1.03]"
    />
  </div>
  <div class="mt-6">
    <p class="label">{label}</p>
    <h3 class="font-heading text-[length:var(--text-lg)] font-light text-navy mt-3 leading-snug">
      {title}
    </h3>
    {description && (
      <p class="text-[length:var(--text-sm)] text-charcoal-light mt-3 leading-relaxed line-clamp-2">
        {description}
      </p>
    )}
    <span class="whisper-link inline-block mt-4 text-[length:var(--text-xs)]">
      {linkText}
    </span>
  </div>
</a>
