---
/**
 * CTABlock — Conversion section.
 * Centred heading with one or two action links.
 */
interface Props {
  heading: string;
  description?: string;
  primaryText: string;
  primaryHref: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const { heading, description, primaryText, primaryHref, secondaryText, secondaryHref } = Astro.props;
---

<section class="section-pad">
  <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
    <h2 class="font-heading text-[length:var(--text-2xl)] font-light text-navy leading-[1.1]">
      {heading}
    </h2>
    {description && (
      <p class="text-[length:var(--text-base)] text-charcoal-light mt-4 leading-relaxed">
        {description}
      </p>
    )}
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={primaryHref}
        class="inline-flex items-center px-8 py-3 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)]"
      >
        {primaryText}
      </a>
      {secondaryText && secondaryHref && (
        <a href={secondaryHref} class="whisper-link">
          {secondaryText}
        </a>
      )}
    </div>
  </div>
</section>
