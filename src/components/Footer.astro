---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);

const footerLinks = {
  'About ISJ': [
    { label: 'Why ISJ', href: link('/about/why-isj') },
    { label: 'Our Head', href: link('/about/our-head') },
    { label: 'The Schools Trust', href: link('/about/the-schools-trust') },
    { label: 'Campus & Facilities', href: link('/school-life/campus') },
    { label: 'Contact', href: link('/contact') },
  ],
  'Academics': [
    { label: 'Pre-Prep (Ages 2\u20136)', href: link('/academics/pre-prep') },
    { label: 'Prep School (Ages 7\u201313)', href: link('/academics/prep-school') },
    { label: 'Senior School (Ages 14\u201318)', href: link('/academics/senior-school') },
    { label: 'Curriculum', href: link('/academics/curriculum') },
    { label: 'Results & Outcomes', href: link('/academics/results') },
  ],
  'Admissions': [
    { label: 'How to Apply', href: link('/admissions/how-to-apply') },
    { label: 'Arrange a Tour', href: link('/admissions/arrange-a-tour') },
    { label: 'Tuition Fees', href: link('/admissions/fees') },
    { label: 'Age Guide', href: link('/admissions/age-guide') },
    { label: 'Scholarships', href: link('/admissions/scholarships') },
    { label: 'FAQs', href: link('/faqs') },
  ],
  'Resources': [
    { label: 'News & Events', href: link('/news') },
    { label: 'Insights', href: link('/insights') },
    { label: 'School Policies', href: link('/policies') },
  ],
};

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/isj.id' },
  { label: 'Facebook', href: 'https://facebook.com/isjjakarta' },
  { label: 'LinkedIn', href: 'https://linkedin.com/school/isjjakarta' },
  { label: 'YouTube', href: 'https://youtube.com/@isjjakarta' },
];
---

<footer class="text-navy">

  <!-- CTA band — warm stone -->
  <div class="bg-[#E8E4DD] px-6 py-14 lg:py-16">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center">
      <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy">Begin Your Journey</h2>
      <div class="mt-5 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={link('/admissions/arrange-a-tour')}
          class="inline-flex items-center px-7 py-2.5 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)]"
        >
          Arrange a Tour
        </a>
        <a href={link('/contact')} class="whisper-link">Contact Admissions</a>
      </div>
    </div>
  </div>

  <!-- Footer body — slightly darker stone -->
  <div class="bg-[#DDD9D1] px-6 py-12 lg:py-16">
    <div class="mx-auto max-w-[var(--content-wide)]">

      <!-- Link columns -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
        {Object.entries(footerLinks).map(([heading, links]) => (
          <div>
            <p class="label mb-4">{heading}</p>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  {'pending' in link && link.pending ? (
                    <span class="text-[length:var(--text-sm)] text-navy/25 cursor-default">
                      {link.label}
                    </span>
                  ) : (
                    <a
                      href={link.href}
                      class="text-[length:var(--text-sm)] text-navy/45 hover:text-navy transition-colors duration-[var(--transition-base)]"
                    >
                      {link.label}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Contact + address — single row, no divider -->
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 text-[length:var(--text-xs)] text-navy/35">
        <div>
          <p class="text-navy/50 font-medium mb-1">Reception</p>
          <p>+62 21-2782-6788</p>
          <a href="mailto:info@isj.id" class="hover:text-navy/60 transition-colors">info@isj.id</a>
        </div>
        <div>
          <p class="text-navy/50 font-medium mb-1">Admissions</p>
          <p>+62 811 1000 7672 (WhatsApp)</p>
          <a href="mailto:admissions@isj.id" class="hover:text-navy/60 transition-colors">admissions@isj.id</a>
        </div>
        <div>
          <p class="text-navy/50 font-medium mb-1">Address</p>
          <p>Jl. R.A. Kartini No. Kav. 12<br />Pondok Indah, South Jakarta 12310</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar — same darker stone, thin top line -->
  <div class="bg-[#DDD9D1] border-t border-navy/8 px-6 py-4">
    <div class="mx-auto max-w-[var(--content-wide)] flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="flex items-center gap-5 flex-wrap">
        <span class="text-[length:var(--text-xs)] text-navy/25">
          &copy; {new Date().getFullYear()} The Independent School of Jakarta
        </span>
        <span class="text-[length:var(--text-xs)] text-navy/25">
          Part of <a href="https://schoolstrust.co.uk" target="_blank" rel="noopener noreferrer" class="hover:text-navy/50 transition-colors">The Schools Trust</a>
        </span>
        <a href={link('/privacy')} class="text-[length:var(--text-xs)] text-navy/25 hover:text-navy/50 transition-colors">Privacy</a>
        <a href={link('/terms')} class="text-[length:var(--text-xs)] text-navy/25 hover:text-navy/50 transition-colors">Terms</a>
        <a href={link('/cookies')} class="text-[length:var(--text-xs)] text-navy/25 hover:text-navy/50 transition-colors">Cookies</a>
      </div>
      <div class="flex items-center gap-4">
        {socialLinks.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" class="text-navy/25 hover:text-navy/50 transition-colors" aria-label={social.label}>
            <span class="text-[length:var(--text-xs)] uppercase tracking-wider">{social.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

</footer>
