---
import { asset } from '../utils/paths';
const link = (path: string) => asset(path);
/**
 * Footer — Warm stone background, navy text. Gentle visual bookend.
 * CTA section with gold button, then full site index.
 */
const footerLinks = {
  'About ISJ': [
    { label: 'Why ISJ', href: link('/about/why-isj') },
    { label: 'Our Head', href: link('/about/our-head') },
    { label: 'The Schools Trust', href: link('/about/the-schools-trust') },
    { label: 'Campus & Facilities', href: link('/school-life/campus') },
    { label: 'Careers \u00d7', pending: true },
    { label: 'Contact', href: link('/contact') },
  ],
  'Academics': [
    { label: 'Pre-Prep (Ages 2\u20136)', href: link('/academics/pre-prep') },
    { label: 'Prep School (Ages 7\u201313)', href: link('/academics/prep-school') },
    { label: 'Senior School (Ages 14\u201318)', href: link('/academics/senior-school') },
    { label: 'Curriculum \u00d7', pending: true },
    { label: 'Results & Outcomes \u00d7', pending: true },
  ],
  'Admissions': [
    { label: 'How to Apply', href: link('/admissions/how-to-apply') },
    { label: 'Arrange a Tour', href: link('/admissions/arrange-a-tour') },
    { label: 'Tuition Fees', href: link('/admissions/fees') },
    { label: 'Age Guide', href: link('/admissions/age-guide') },
    { label: 'Scholarships & Bursaries', href: link('/admissions/scholarships') },
    { label: 'FAQs', href: link('/faqs') },
  ],
  'Resources': [
    { label: 'News & Events', href: link('/news') },
    { label: 'Insights', href: link('/insights') },
    { label: 'School Policies', href: link('/policies') },
    { label: 'School Calendar \u00d7', pending: true },
    { label: 'Virtual Tour \u00d7', pending: true },
  ],
};

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/isj.id' },
  { label: 'Facebook', href: 'https://facebook.com/isjjakarta' },
  { label: 'LinkedIn', href: 'https://linkedin.com/school/isjjakarta' },
  { label: 'YouTube', href: 'https://youtube.com/@isjjakarta' },
];
---

<footer class="bg-[#E8E4DD] text-navy">
  <!-- CTA row -->
  <div class="section-pad-sm px-6 border-b border-navy/10">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center">
      <h2 class="font-heading text-[length:var(--text-xl)] font-light text-navy">Begin Your Journey</h2>
      <div class="mt-5 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={link('/admissions/arrange-a-tour')}
          class="inline-flex items-center px-7 py-2.5 border border-navy-light bg-navy-light text-cream text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-navy transition-colors duration-[var(--transition-base)]"
        >
          Arrange a Tour
        </a>
        <a href={link('/contact')} class="whisper-link">Contact Admissions</a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="px-6 py-12 lg:py-16">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
        {Object.entries(footerLinks).map(([heading, links]) => (
          <div>
            <p class="label mb-4">{heading}</p>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  {'pending' in link && link.pending ? (
                    <span class="text-[length:var(--text-sm)] text-navy/25 cursor-default">
                      {link.label}
                    </span>
                  ) : (
                    <a
                      href={link.href}
                      class="text-[length:var(--text-sm)] text-navy/50 hover:text-navy transition-colors duration-[var(--transition-base)]"
                    >
                      {link.label}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Contact block -->
      <div class="mt-10 pt-8 border-t border-navy/10 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="label mb-3">Reception</p>
          <p class="text-[length:var(--text-sm)] text-navy/50">+62 21-2782-6788</p>
          <a href="mailto:info@isj.id" class="text-[length:var(--text-sm)] text-navy/50 hover:text-navy transition-colors">info@isj.id</a>
        </div>
        <div>
          <p class="label mb-3">Admissions</p>
          <p class="text-[length:var(--text-sm)] text-navy/50">+62 811 1000 7672 (WhatsApp)</p>
          <a href="mailto:admissions@isj.id" class="text-[length:var(--text-sm)] text-navy/50 hover:text-navy transition-colors">admissions@isj.id</a>
        </div>
      </div>

      <!-- Address -->
      <div class="mt-8 pt-6 border-t border-navy/10">
        <p class="text-[length:var(--text-xs)] text-navy/30 leading-relaxed">
          Jl. R.A. Kartini No. Kav. 12, Pondok Indah, South Jakarta 12310, Indonesia
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-navy/10 px-6 py-5">
    <div class="mx-auto max-w-[var(--content-wide)] flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <span class="text-[length:var(--text-xs)] text-navy/30">
          &copy; {new Date().getFullYear()} The Independent School of Jakarta
        </span>
        <span class="text-[length:var(--text-xs)] text-navy/30">
          Part of <a href="https://schoolstrust.co.uk" target="_blank" rel="noopener noreferrer" class="hover:text-navy/60 transition-colors">The Schools Trust</a>
        </span>
      </div>
      <div class="flex items-center gap-6">
        <a href={link('/privacy')} class="text-[length:var(--text-xs)] text-navy/30 hover:text-navy/60 transition-colors">Privacy</a>
        <a href={link('/terms')} class="text-[length:var(--text-xs)] text-navy/30 hover:text-navy/60 transition-colors">Terms</a>
        <a href={link('/cookies')} class="text-[length:var(--text-xs)] text-navy/30 hover:text-navy/60 transition-colors">Cookies</a>
      </div>
      <div class="flex items-center gap-4">
        {socialLinks.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" class="text-navy/30 hover:text-navy/60 transition-colors" aria-label={social.label}>
            <span class="text-[length:var(--text-xs)] uppercase tracking-wider">{social.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Attribution -->
  <div class="px-6 pb-4">
    <div class="mx-auto max-w-[var(--content-wide)] text-center">
      <a href="https://www.perplexity.ai/computer" target="_blank" rel="noopener noreferrer" class="text-[length:var(--text-xs)] text-navy/15 hover:text-navy/30 transition-colors">
        Created with Perplexity Computer
      </a>
    </div>
  </div>
</footer>
