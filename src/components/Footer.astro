---
/**
 * Footer — Navy background, cream text. Visual bookend to the page.
 * CTA section transitions from cream to navy, then full site index.
 */
const footerLinks = {
  'About ISJ': [
    { label: 'Why ISJ', href: '/about/why-isj' },
    { label: 'Our Head', href: '/about/our-head' },
    { label: 'The Schools Trust', href: '/about/the-schools-trust' },
    { label: 'Campus & Facilities', href: '/school-life/campus' },
    { label: 'Careers', href: '/careers' },
    { label: 'Contact', href: '/contact' },
  ],
  'Academics': [
    { label: 'Pre-Prep (Ages 2–6)', href: '/academics/pre-prep' },
    { label: 'Prep School (Ages 7–13)', href: '/academics/prep-school' },
    { label: 'Senior School (Ages 14–18)', href: '/academics/senior-school' },
    { label: 'Curriculum', href: '/academics/curriculum' },
    { label: 'Results & Outcomes', href: '/academics/results' },
  ],
  'Admissions': [
    { label: 'How to Apply', href: '/admissions/how-to-apply' },
    { label: 'Arrange a Tour', href: '/admissions/arrange-a-tour' },
    { label: 'Tuition Fees', href: '/admissions/fees' },
    { label: 'Age Guide', href: '/admissions/age-guide' },
    { label: 'Scholarships & Bursaries', href: '/admissions/scholarships' },
    { label: 'FAQs', href: '/faqs' },
  ],
  'Resources': [
    { label: 'News & Events', href: '/news' },
    { label: 'Insights', href: '/insights' },
    { label: 'School Policies', href: '/policies' },
    { label: 'School Calendar', href: '/school-life/calendar' },
    { label: 'Virtual Tour', href: '/admissions/virtual-tour' },
  ],
};

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/isj.id' },
  { label: 'Facebook', href: 'https://facebook.com/isjjakarta' },
  { label: 'LinkedIn', href: 'https://linkedin.com/school/isjjakarta' },
  { label: 'YouTube', href: 'https://youtube.com/@isjjakarta' },
];
---

<footer class="bg-navy text-white/80">
  <!-- CTA row -->
  <div class="section-pad-sm px-6 border-b border-white/10">
    <div class="mx-auto max-w-[var(--content-narrow)] text-center">
      <h2 class="font-heading text-[length:var(--text-xl)] font-light text-white">Begin Your Journey</h2>
      <div class="mt-5 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/admissions/arrange-a-tour"
          class="inline-flex items-center px-7 py-2.5 border border-gold bg-gold text-navy text-[length:var(--text-xs)] tracking-[0.15em] uppercase font-medium hover:bg-gold-muted transition-colors duration-[var(--transition-base)]"
        >
          Arrange a Tour
        </a>
        <a href="/contact" class="whisper-link-light">Contact Admissions</a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="px-6 py-12 lg:py-16">
    <div class="mx-auto max-w-[var(--content-wide)]">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
        {Object.entries(footerLinks).map(([heading, links]) => (
          <div>
            <p class="label label-light mb-4">{heading}</p>
            <ul class="space-y-2">
              {links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-[length:var(--text-sm)] text-white/50 hover:text-white transition-colors duration-[var(--transition-base)]"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Contact block -->
      <div class="mt-12 pt-8 border-t border-white/10 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="label label-light mb-3">Reception</p>
          <p class="text-[length:var(--text-sm)] text-white/50">+62 21-2782-6788</p>
          <a href="mailto:info@isj.id" class="text-[length:var(--text-sm)] text-white/50 hover:text-white transition-colors">info@isj.id</a>
        </div>
        <div>
          <p class="label label-light mb-3">Admissions</p>
          <p class="text-[length:var(--text-sm)] text-white/50">+62 811 1000 7672 (WhatsApp)</p>
          <a href="mailto:admissions@isj.id" class="text-[length:var(--text-sm)] text-white/50 hover:text-white transition-colors">admissions@isj.id</a>
        </div>
      </div>

      <!-- Address -->
      <div class="mt-8 pt-8 border-t border-white/10">
        <p class="text-[length:var(--text-xs)] text-white/30 leading-relaxed">
          Jl. R.A. Kartini No. Kav. 12, Pondok Indah, South Jakarta 12310, Indonesia
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 px-6 py-6">
    <div class="mx-auto max-w-[var(--content-wide)] flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <span class="text-[length:var(--text-xs)] text-white/30">
          &copy; {new Date().getFullYear()} The Independent School of Jakarta
        </span>
        <span class="text-[length:var(--text-xs)] text-white/30">
          Part of <a href="https://theschoolstrust.com" target="_blank" rel="noopener noreferrer" class="hover:text-white/60 transition-colors">The Schools Trust</a>
        </span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="text-[length:var(--text-xs)] text-white/30 hover:text-white/60 transition-colors">Privacy</a>
        <a href="/terms" class="text-[length:var(--text-xs)] text-white/30 hover:text-white/60 transition-colors">Terms</a>
        <a href="/cookies" class="text-[length:var(--text-xs)] text-white/30 hover:text-white/60 transition-colors">Cookies</a>
      </div>
      <div class="flex items-center gap-4">
        {socialLinks.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-white/60 transition-colors" aria-label={social.label}>
            <span class="text-[length:var(--text-xs)] uppercase tracking-wider">{social.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Attribution -->
  <div class="border-t border-white/5 px-6 py-4">
    <div class="mx-auto max-w-[var(--content-wide)] text-center">
      <a href="https://www.perplexity.ai/computer" target="_blank" rel="noopener noreferrer" class="text-[length:var(--text-xs)] text-white/15 hover:text-white/30 transition-colors">
        Created with Perplexity Computer
      </a>
    </div>
  </div>
</footer>
