---
/**
 * Testimonial — Large centred quote. Aman-style: quiet, editorial.
 */
interface Props {
  quote: string;
  attribution: string;
  detail?: string;
  variant?: 'light' | 'dark';
}

const { quote, attribution, detail, variant = 'light' } = Astro.props;

/* Variant is kept in the interface for future use but both render the same now */
const textClass = 'text-navy';
const attrClass = 'text-charcoal-muted';
---

<section class="section-pad-sm md:section-pad">
  <div class="mx-auto max-w-[var(--content-narrow)] text-center reveal">
    <blockquote>
      <p class={`font-heading text-[length:var(--text-xl)] font-light leading-snug italic ${textClass}`}>
        "{quote}"
      </p>
    </blockquote>
    <div class="mt-6">
      <p class={`text-[length:var(--text-sm)] font-medium ${attrClass}`}>{attribution}</p>
      {detail && (
        <p class={`text-[length:var(--text-xs)] mt-1 ${attrClass}`}>{detail}</p>
      )}
    </div>
  </div>
</section>
