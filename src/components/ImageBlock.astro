---
import { asset } from '../utils/paths';
/**
 * ImageBlock — Full-bleed or contained image with subtle parallax.
 * Optional slow zoom (Ken Burns) on scroll-into-view.
 */
interface Props {
  src: string;
  alt: string;
  aspect?: 'landscape' | 'portrait' | 'square' | 'wide';
  loading?: 'eager' | 'lazy';
  slowZoom?: boolean;
  class?: string;
}

const { src, alt, aspect = 'landscape', loading = 'lazy', slowZoom = false, class: className = '' } = Astro.props;

const aspectClass = {
  landscape: 'aspect-[16/10]',
  portrait: 'aspect-[3/4]',
  square: 'aspect-square',
  wide: 'aspect-[21/9]',
}[aspect];
---

<div class={`w-full overflow-hidden reveal parallax-wrap ${className}`}>
  <img
    src={asset(src)}
    alt={alt}
    loading={loading}
    decoding="async"
    class={`w-full object-cover parallax-img ${aspectClass} ${slowZoom ? 'slow-zoom' : ''}`}
  />
</div>

<style>
  .parallax-wrap {
    overflow: hidden;
  }
  .parallax-img {
    height: 110%;
    min-height: 100%;
    will-change: transform;
  }
  .slow-zoom {
    transition: transform 15s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  .slow-zoom.zooming {
    transform: scale(1.08);
  }
</style>

<script is:inline>
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.__parallaxInit) return;
    window.__parallaxInit = true;

    // Parallax on scroll
    var imgs = document.querySelectorAll('.parallax-img');
    window.addEventListener('scroll', function() {
      for (var i = 0; i < imgs.length; i++) {
        var img = imgs[i];
        var rect = img.parentElement.getBoundingClientRect();
        var viewH = window.innerHeight;
        if (rect.bottom < -100 || rect.top > viewH + 100) continue;
        var progress = (viewH - rect.top) / (viewH + rect.height);
        var shift = (progress - 0.5) * -5;
        var isZooming = img.classList.contains('zooming');
        img.style.transform = 'translateY(' + shift + '%)' + (isZooming ? ' scale(1.08)' : '');
      }
    }, { passive: true });

    // Slow zoom on enter
    var zoomObserver = new IntersectionObserver(function(entries) {
      for (var i = 0; i < entries.length; i++) {
        if (entries[i].isIntersecting) {
          entries[i].target.classList.add('zooming');
        }
      }
    }, { threshold: 0.15 });

    var zoomEls = document.querySelectorAll('.slow-zoom');
    for (var i = 0; i < zoomEls.length; i++) {
      zoomObserver.observe(zoomEls[i]);
    }
  })();
</script>
