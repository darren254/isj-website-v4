---
/**
 * ImageBlock — Full-bleed or contained image with subtle parallax.
 * No borders, no shadows, no rounded corners. Aman-style.
 */
interface Props {
  src: string;
  alt: string;
  aspect?: 'landscape' | 'portrait' | 'square' | 'wide';
  loading?: 'eager' | 'lazy';
  class?: string;
}

const { src, alt, aspect = 'landscape', loading = 'lazy', class: className = '' } = Astro.props;

const aspectClass = {
  landscape: 'aspect-[16/10]',
  portrait: 'aspect-[3/4]',
  square: 'aspect-square',
  wide: 'aspect-[21/9]',
}[aspect];
---

<div class={`w-full overflow-hidden reveal parallax-wrap ${className}`}>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
    class={`w-full object-cover parallax-img ${aspectClass}`}
    style="will-change: transform;"
  />
</div>

<style>
  .parallax-wrap {
    overflow: hidden;
  }
  .parallax-img {
    /* Slightly taller than container so there's room to shift */
    height: 110%;
    min-height: 100%;
  }
</style>

<script>
  function initParallax() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const images = document.querySelectorAll('.parallax-img');
    
    function onScroll() {
      images.forEach((img) => {
        const rect = img.parentElement!.getBoundingClientRect();
        const viewH = window.innerHeight;
        // Only process if in or near viewport
        if (rect.bottom < -100 || rect.top > viewH + 100) return;
        // Progress: 0 when element enters bottom, 1 when it exits top
        const progress = (viewH - rect.top) / (viewH + rect.height);
        // Shift by up to 5% of image height
        const shift = (progress - 0.5) * -5;
        (img as HTMLElement).style.transform = `translateY(${shift}%)`;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // Initial position
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initParallax);
  } else {
    initParallax();
  }
</script>
