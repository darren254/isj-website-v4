---
/**
 * ImageBlock — Full-bleed or contained image with subtle parallax.
 * Optional slow zoom (Ken Burns) on scroll-into-view.
 */
interface Props {
  src: string;
  alt: string;
  aspect?: 'landscape' | 'portrait' | 'square' | 'wide';
  loading?: 'eager' | 'lazy';
  slowZoom?: boolean;
  class?: string;
}

const { src, alt, aspect = 'landscape', loading = 'lazy', slowZoom = false, class: className = '' } = Astro.props;

const aspectClass = {
  landscape: 'aspect-[16/10]',
  portrait: 'aspect-[3/4]',
  square: 'aspect-square',
  wide: 'aspect-[21/9]',
}[aspect];
---

<div class={`w-full overflow-hidden reveal parallax-wrap ${className}`}>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
    class={`w-full object-cover parallax-img ${aspectClass} ${slowZoom ? 'slow-zoom' : ''}`}
    style="will-change: transform;"
  />
</div>

<style>
  .parallax-wrap {
    overflow: hidden;
  }
  .parallax-img {
    height: 110%;
    min-height: 100%;
  }
  .slow-zoom {
    transform: scale(1);
    transition: transform 15s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
  .slow-zoom.zooming {
    transform: scale(1.08);
  }
</style>

<script is:inline>
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Parallax
    var imgs = document.querySelectorAll('.parallax-img');
    window.addEventListener('scroll', function() {
      imgs.forEach(function(img) {
        var rect = img.parentElement.getBoundingClientRect();
        var viewH = window.innerHeight;
        if (rect.bottom < -100 || rect.top > viewH + 100) return;
        var progress = (viewH - rect.top) / (viewH + rect.height);
        var shift = (progress - 0.5) * -5;
        // Preserve zoom transform if active
        var isZooming = img.classList.contains('zooming');
        var scale = isZooming ? ' scale(1.08)' : '';
        img.style.transform = 'translateY(' + shift + '%)' + scale;
      });
    }, { passive: true });

    // Slow zoom
    var zoomObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('zooming');
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.slow-zoom').forEach(function(el) {
      zoomObserver.observe(el);
    });
  })();
</script>
